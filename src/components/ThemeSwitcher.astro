---
// src/components/ThemeSwitcher.astro
// Widget flottant pour basculer entre les 4 thèmes de fond ExecEd-style.
// Inclut dans `template-execed.mdx` uniquement. Le script ajoute le
// widget au <body>, le style global s'applique aux 5 composants gradient
// (CoverHero, SectionHero, NumberedSplit, SectionSplit, TitleSplitImage)
// via le sélecteur body[data-template-theme].
//
// Persistance localStorage : le thème choisi est mémorisé entre les visites
// de /p/template-execed/. Pas d'effet sur les autres decks puisque le
// composant n'est importé que dans ce template.
---

<style is:global>
  /* ============ Widget switcher ============ */
  .lm-theme-switcher {
    position: fixed;
    top: 50%;
    right: 20px;
    transform: translateY(-50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 12px 10px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(25, 25, 25, 0.08);
    border-radius: 10px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 12px 32px rgba(25, 25, 25, 0.12);
    font-family: 'Hanken Grotesk', sans-serif;
  }
  .lm-theme-switcher__label {
    padding: 0 2px 6px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #6B6F84;
    border-bottom: 1px solid rgba(25, 25, 25, 0.06);
    margin-bottom: 2px;
  }
  .lm-theme-switcher button {
    width: 36px;
    height: 36px;
    border: 2px solid rgba(25, 25, 25, 0.08);
    border-radius: 6px;
    cursor: pointer;
    background-position: center;
    background-size: cover;
    transition: border-color 0.18s ease, transform 0.18s ease;
    color: transparent;
    font-size: 0;
    padding: 0;
  }
  .lm-theme-switcher button:hover {
    transform: scale(1.06);
    border-color: rgba(25, 25, 25, 0.3);
  }
  .lm-theme-switcher button.is-active {
    border-color: #FFD838;
    box-shadow: 0 0 0 2px rgba(255, 216, 56, 0.3);
  }
  .lm-theme-switcher button[data-theme="cream-mist"] {
    background: linear-gradient(180deg, #FAF8F3 0%, #FFFFFF 100%);
  }
  .lm-theme-switcher button[data-theme="warm-blush"] {
    background: linear-gradient(135deg, #FAF8F3 0%, #FEE487 100%);
  }
  .lm-theme-switcher button[data-theme="pearl-stone"] {
    background: linear-gradient(180deg, #FFFFFF 0%, #EFEFF2 100%);
  }
  .lm-theme-switcher button[data-theme="halo-gold"] {
    background:
      radial-gradient(120% 90% at 95% 5%, #FEE487 0%, rgba(254, 228, 135, 0) 55%),
      linear-gradient(180deg, #FAF8F3 0%, #F4F1E8 100%);
  }

  /* ============ Theme overrides sur les composants ExecEd-style ============
     Quand le body porte data-template-theme="X", on remplace le background
     des 5 composants gradient. La règle !important bat le style scoped
     de chaque composant. */

  /* Cream Mist */
  body[data-template-theme="cream-mist"] .cover-hero,
  body[data-template-theme="cream-mist"] .section-hero,
  body[data-template-theme="cream-mist"] .numbered-split,
  body[data-template-theme="cream-mist"] .section-split,
  body[data-template-theme="cream-mist"] .title-split-image {
    background: linear-gradient(180deg, #FAF8F3 0%, #FFFFFF 100%) !important;
  }

  /* Warm Blush */
  body[data-template-theme="warm-blush"] .cover-hero,
  body[data-template-theme="warm-blush"] .section-hero,
  body[data-template-theme="warm-blush"] .numbered-split,
  body[data-template-theme="warm-blush"] .section-split,
  body[data-template-theme="warm-blush"] .title-split-image {
    background: linear-gradient(135deg, #FAF8F3 0%, #FEE487 100%) !important;
  }

  /* Pearl Stone */
  body[data-template-theme="pearl-stone"] .cover-hero,
  body[data-template-theme="pearl-stone"] .section-hero,
  body[data-template-theme="pearl-stone"] .numbered-split,
  body[data-template-theme="pearl-stone"] .section-split,
  body[data-template-theme="pearl-stone"] .title-split-image {
    background: linear-gradient(180deg, #FFFFFF 0%, #EFEFF2 100%) !important;
  }

  /* Halo Gold (par défaut, mais on l'expose pour le toggle) */
  body[data-template-theme="halo-gold"] .cover-hero,
  body[data-template-theme="halo-gold"] .section-hero,
  body[data-template-theme="halo-gold"] .numbered-split,
  body[data-template-theme="halo-gold"] .section-split,
  body[data-template-theme="halo-gold"] .title-split-image {
    background:
      radial-gradient(120% 90% at 95% 5%, #FEE487 0%, rgba(254, 228, 135, 0) 55%),
      linear-gradient(180deg, #FAF8F3 0%, #F4F1E8 100%) !important;
  }
</style>

<script>
  const themes = ['cream-mist', 'warm-blush', 'pearl-stone', 'halo-gold'] as const;
  type Theme = typeof themes[number];
  const labels: Record<Theme, string> = {
    'cream-mist': 'Cream Mist',
    'warm-blush': 'Warm Blush',
    'pearl-stone': 'Pearl Stone',
    'halo-gold': 'Halo Gold',
  };
  const storageKey = 'lm-template-execed-theme';

  function init() {
    // Évite la double injection si le script est rejoué par Astro view transitions
    if (document.querySelector('.lm-theme-switcher')) return;

    const stored = (localStorage.getItem(storageKey) as Theme | null);
    const initial: Theme = stored && themes.includes(stored) ? stored : 'halo-gold';
    document.body.dataset.templateTheme = initial;

    const widget = document.createElement('div');
    widget.className = 'lm-theme-switcher';
    widget.setAttribute('role', 'group');
    widget.setAttribute('aria-label', 'Choisir le thème de fond du template');

    const label = document.createElement('span');
    label.className = 'lm-theme-switcher__label';
    label.textContent = 'Fond';
    widget.appendChild(label);

    themes.forEach((theme) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.dataset.theme = theme;
      btn.title = labels[theme];
      btn.setAttribute('aria-label', labels[theme]);
      btn.textContent = labels[theme];
      if (theme === initial) btn.classList.add('is-active');

      btn.addEventListener('click', () => {
        document.body.dataset.templateTheme = theme;
        localStorage.setItem(storageKey, theme);
        widget.querySelectorAll('button').forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
      });

      widget.appendChild(btn);
    });

    document.body.appendChild(widget);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
