---
// src/components/slides/SectionHero.astro
// Slide de transition de section "ExecEd-style" : fond noir LM, image
// d'illustration sur une moitié, titre serif italique partiel sur
// l'autre moitié, attribution optionnelle (Prénom, Nom + rôle).
// Inspiration slides 15 et 17 du PPTX ExecEd.
//
// Différent du composant Section existant : Section LM affiche un gros
// numéro chiffre + eyebrow + titre sans-serif sur fond crème.
// SectionHero affiche une image hero + titre serif italique sur fond noir.
interface Props {
  title: string;
  italicPart?: string;
  image?: string;
  imageSide?: 'left' | 'right';
  personName?: string;
  personRole?: string;
  personAvatar?: string;
  brand?: string;
  brandSub?: string;
  tocLabel?: string;
}
const {
  title,
  italicPart,
  image,
  imageSide = 'left',
  personName,
  personRole,
  personAvatar,
  brand = 'Lausanne Marketing',
  brandSub,
  tocLabel,
} = Astro.props;
---
<section
  class:list={['section-hero', `section-hero--image-${imageSide}`]}
  data-layout="section-hero"
  data-section-title={tocLabel ?? title}
>
  <header class="section-hero__header">
    <div class="section-hero__brand">
      <p class="section-hero__brand-main">{brand}</p>
      {brandSub && <p class="section-hero__brand-sub">{brandSub}</p>}
    </div>
  </header>

  <div class="section-hero__body">
    {image && (
      <div class="section-hero__image" aria-hidden="true">
        <img src={image} alt="" loading="eager" decoding="async" />
      </div>
    )}

    <div class="section-hero__text">
      <h2 class="section-hero__title">
        {italicPart
          ? <>{title.split(italicPart)[0]}<em class="section-hero__title-italic">{italicPart}</em>{title.split(italicPart)[1]}</>
          : title}
      </h2>

      {personName && (
        <div class="section-hero__person">
          {personAvatar && (
            <span class="section-hero__avatar" aria-hidden="true">
              <img src={personAvatar} alt="" loading="lazy" decoding="async" />
            </span>
          )}
          <div>
            <p class="section-hero__person-name">{personName}</p>
            {personRole && <p class="section-hero__person-role">{personRole}</p>}
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .section-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 64px 96px !important;
    background: #191919;
    color: #FAF8F3;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .section-hero__header {
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(250, 248, 243, 0.18);
  }
  .section-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: #FAF8F3;
  }
  .section-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: rgba(250, 248, 243, 0.65);
  }

  .section-hero__body {
    flex: 1 1 auto !important;
    display: flex;
    align-items: center;
    gap: 96px;
    min-height: 0;
  }
  .section-hero--image-right .section-hero__body {
    flex-direction: row-reverse;
  }

  .section-hero__image {
    flex: 0 0 auto;
    width: 460px;
    aspect-ratio: 1 / 1;
    background: #2a2a2a;
    overflow: hidden;
  }
  .section-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-hero__text {
    flex: 1 1 auto;
    min-width: 0;
  }

  .section-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(72px, 7vw, 116px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: #FAF8F3;
    text-wrap: balance;
  }
  .section-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .section-hero__person {
    margin-top: 48px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .section-hero__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(250, 248, 243, 0.15);
    flex: 0 0 auto;
  }
  .section-hero__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .section-hero__person-name {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 600;
    margin: 0;
    color: #FAF8F3;
  }
  .section-hero__person-role {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 400;
    margin: 4px 0 0;
    color: rgba(250, 248, 243, 0.65);
  }
</style>
