---
// src/components/slides/InfoCards.astro
// Grille de cards "info" : icône Phosphor + LABEL CAPS + valeur ou
// description courte. Header marque + logo LM (RÈGLE ABSOLUE), fond pearl,
// titre serif italique partiel + sous-titre optionnel, cards larges (2 col).
// Inspiration slides 35 (Informations clés) et 40 (Aides financières)
// du PPTX ExecEd.
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';

interface InfoCard {
  /** Icône Phosphor (ex: "ph:certificate", "ph:calendar-blank"). */
  icon: string;
  /** Label affiché en CAPS lettrées au-dessus de la valeur. */
  label: string;
  /** Valeur ou description courte (1 à 2 phrases max). */
  value: string;
}
interface Props {
  title: string;
  italicPart?: string;
  /** Description optionnelle affichée sous le titre. */
  subtitle?: string;
  /** Auto-fit : cards larges, 2 colonnes sur une slide 1920. */
  cards: InfoCard[];
  /** Force un nombre de colonnes fixe (sinon auto-fit 2 col). Ex: columns={3}. */
  columns?: number;
  /** Décor optionnel : soleil qui se lève et se couche en fond (slide horaires). */
  sunArc?: boolean;
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  cards,
  columns,
  sunArc,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="info-cards" data-layout="info-cards">
  {sunArc && (
    <div class="info-cards__sky" aria-hidden="true">
      <span class="info-cards__cloud info-cards__cloud--1"></span>
      <span class="info-cards__cloud info-cards__cloud--2"></span>
      <span class="info-cards__horizon"></span>
      <div class="info-cards__sun-track">
        <div class="info-cards__sun"><span class="info-cards__sun-disc"></span></div>
      </div>
    </div>
  )}
  <header class="info-cards__header">
    <div class="info-cards__brand">
      <p class="info-cards__brand-main">{brand}</p>
      {brandSub && <p class="info-cards__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="info-cards__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="info-cards__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="info-cards__body">
    <h2 class="info-cards__title">
      {titleParts
        ? <>{titleParts.before}<em class="info-cards__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
        : title}
    </h2>
    {subtitle && <p class="info-cards__subtitle">{subtitle}</p>}

    <div class:list={['info-cards__grid', columns && 'info-cards__grid--fixed']} style={columns ? `--cols: ${columns}` : undefined}>
      {cards.map((card) => (
        <article class="info-cards__card">
          <span class="info-cards__icon" aria-hidden="true">
            <Icon name={card.icon} />
          </span>
          <p class="info-cards__label">{card.label}</p>
          <p class="info-cards__value">{card.value}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .info-cards {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom. */
  .info-cards__header {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .info-cards__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
  }
  .info-cards__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
  }
  .info-cards__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .info-cards__body {
    position: relative;
    z-index: 1;
    flex: 1 1 auto !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    padding-top: 32px;
  }

  .info-cards__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .info-cards__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .info-cards__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    margin: 0 0 48px;
    color: var(--c-muted);
    max-width: none;
    text-align: left;
  }

  /* Cards larges : 2 colonnes sur 1920, auto-fit. */
  .info-cards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(560px, 1fr));
    gap: 28px;
  }
  /* Override : nombre de colonnes fixe via --cols (ex: columns={3}). */
  .info-cards__grid--fixed {
    grid-template-columns: repeat(var(--cols, 2), 1fr);
  }

  .info-cards__card {
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 6%, transparent);
    padding: 36px 44px;
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .info-cards__icon {
    width: 44px;
    height: 44px;
    color: var(--c-accent);
    margin-bottom: 4px;
  }
  .info-cards__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .info-cards__label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 0;
    color: var(--c-muted);
  }
  .info-cards__value {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    font-weight: 500;
    line-height: var(--lh-lead);
    margin: 0;
    color: var(--c-ink);
  }

  /* Décor « ciel » (prop sunArc) sur la slide horaires : soleil rouge qui se lève
     à gauche, passe au zénith et se couche à droite ; ligne d'horizon ; nuages en
     dérive très lente. Couleurs réalistes self-contained, derrière le contenu. */
  .info-cards__sky {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  /* Horizon terrestre : grand cercle dont seul l'arc supérieur est visible (le reste
     déborde, rogné par .info-cards__sky), donnant un net arc de cercle (courbure de
     la planète). Léger remplissage sous l'arc = le sol. */
  .info-cards__horizon {
    position: absolute;
    top: 72%;
    left: 50%;
    width: 2600px;
    height: 2600px;
    transform: translateX(-50%);
    border-radius: 50%;
    border: 2px solid color-mix(in srgb, var(--c-ink) 20%, transparent);
    background: color-mix(in srgb, var(--c-ink) 4%, transparent);
  }
  .info-cards__sun-track {
    position: absolute;
    top: 0;
    left: 0;
    width: 160px;
    height: 100%;
    animation: ic-sun-x 13s linear infinite;
  }
  .info-cards__sun {
    position: absolute;
    top: 76%;
    left: 0;
    width: 160px;
    height: 160px;
    margin-top: -80px;
    animation: ic-sun-y 13s ease-in-out infinite;
  }
  .info-cards__sun-disc {
    display: block;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%,
      rgba(255, 202, 51, 0.95) 0%,
      rgba(255, 196, 40, 0.55) 45%,
      rgba(255, 196, 40, 0) 72%);
  }
  @keyframes ic-sun-x {
    from { transform: translateX(-220px); }
    to { transform: translateX(2000px); }
  }
  @keyframes ic-sun-y {
    0% { transform: translateY(40px); opacity: 0; }
    12% { opacity: 1; }
    50% { transform: translateY(-560px); }
    88% { opacity: 1; }
    100% { transform: translateY(40px); opacity: 0; }
  }
  .info-cards__cloud {
    position: absolute;
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-ink) 7%, transparent);
    filter: blur(18px);
  }
  .info-cards__cloud--1 {
    top: 15%;
    left: 14%;
    width: 320px;
    height: 88px;
    animation: ic-cloud-1 36s ease-in-out infinite;
  }
  .info-cards__cloud--2 {
    top: 24%;
    left: 55%;
    width: 420px;
    height: 104px;
    animation: ic-cloud-2 48s ease-in-out infinite;
  }
  @keyframes ic-cloud-1 {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(48px); }
  }
  @keyframes ic-cloud-2 {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-38px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .info-cards__sun-track,
    .info-cards__sun,
    .info-cards__cloud { animation: none; }
    .info-cards__sun { transform: translateY(-560px); opacity: 0.9; }
  }
</style>
