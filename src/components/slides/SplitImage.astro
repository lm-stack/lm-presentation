---
// src/components/slides/SplitImage.astro
// Layout titre + 2 colonnes + image droite : fond noir LM, titre serif
// italique partiel, sous-titre avec carré jaune, 2 colonnes "label /
// body" courtes, image illustrative à droite.
// Inspiration slide 25 du PPTX ExecEd.
interface Column {
  /** Icône Phosphor optionnelle (ex: "ph:gear-six", "ph:robot"). */
  icon?: string;
  label: string;
  text: string;
}
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  columns: Column[];
  image?: string;
  /** 'cover' (défaut : crop 4:5) ou 'contain' (image entière, cadre carré). */
  imageFit?: 'cover' | 'contain';
  brand?: string;
  brandSub?: string;
}
import { splitHighlight } from '@/utils/highlight';
import { Icon } from 'astro-icon/components';
const {
  title,
  italicPart,
  subtitle,
  columns,
  image,
  imageFit = 'cover',
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="split-image" data-layout="split-image">
  <header class="split-image__header">
    <div class="split-image__brand-text">
      <p class="split-image__brand-main">{brand}</p>
      {brandSub && <p class="split-image__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="split-image__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="split-image__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="split-image__body">
    <div class="split-image__text">
      <h2 class="split-image__title">
        {titleParts
          ? <>{titleParts.before}<em class="split-image__title-italic">{titleParts.match}</em>{titleParts.after}</>
          : title}
      </h2>

      {subtitle && <p class="split-image__lead">{subtitle}</p>}

      <div class="split-image__columns">
        {columns.map((col) => (
          <div class="split-image__card">
            {col.icon && (
              <span class="split-image__card-icon" aria-hidden="true">
                <Icon name={col.icon} />
              </span>
            )}
            <div class="split-image__card-text-wrap">
              <p class="split-image__card-label">{col.label}</p>
              <p class="split-image__card-text">{col.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    {image && (
      <div class:list={['split-image__image', { 'split-image__image--contain': imageFit === 'contain' }]} aria-hidden="true">
        <img src={image} alt="" loading="lazy" decoding="async" />
      </div>
    )}
  </div>
</section>

<style>
  .split-image {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .split-image__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .split-image__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
  }
  .split-image__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
  }
  .split-image__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .split-image__body {
    flex: 1 1 auto !important;
    display: flex;
    align-items: center;
    gap: 96px;
    min-height: 0;
    padding-top: 32px;
  }
  .split-image__text {
    flex: 1 1 auto;
    min-width: 0;
  }

  .split-image__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .split-image__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .split-image__lead {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 24px 0 0;
    max-width: var(--measure-l);
  }

  .split-image__columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 40px;
  }
  .split-image__card {
    display: flex;
    align-items: flex-start;
    gap: 22px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 26px 30px;
  }
  .split-image__card-icon {
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    color: var(--c-accent);
    margin-top: 2px;
  }
  .split-image__card-icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .split-image__card-text-wrap {
    min-width: 0;
  }
  .split-image__card-label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--c-ink);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .split-image__card-text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--c-muted);
    margin: 0;
  }

  .split-image__image {
    flex: 0 0 auto;
    width: 400px;
    aspect-ratio: 4 / 5;
    background: var(--c-surface);
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--c-ink) 10%, transparent);
  }
  .split-image__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Variante image entière (imageFit="contain") : cadre carré un peu plus large,
     pour un visuel non rogné (mème, schéma, capture carrée). */
  .split-image__image--contain {
    width: 560px;
    aspect-ratio: 1 / 1;
  }
  .split-image__image--contain img {
    object-fit: contain;
  }
</style>
