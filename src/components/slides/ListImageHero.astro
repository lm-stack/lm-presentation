---
// src/components/slides/ListImageHero.astro
// "Liste sur image" ExecEd-style, transposition LIGHT du slide listing HEC :
// header full-width (brand + logo + border pleine largeur), à gauche titre serif
// italique partiel + sous-titre (carré jaune) + paragraphe, à droite une pile de
// cards (label + titre) posées sur une image floutée. Charte LM light (pas de
// fond dark : fond pearl + voile clair sur l'image).
interface ListItem {
  /** Petit sur-titre de la card, ex "Module 1". */
  label?: string;
  title: string;
  /** Portion du titre rendue en italique serif. */
  italicPart?: string;
}
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  body?: string;
  /** Image de fond (floutée) de la colonne droite. */
  image: string;
  items: ListItem[];
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  body,
  image,
  items,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="list-image-hero" data-layout="list-image-hero">
  <div class="list-image-hero__image" aria-hidden="true">
    <img src={image} alt="" loading="lazy" decoding="async" />
    <div class="list-image-hero__image-overlay"></div>
  </div>

  <header class="list-image-hero__header">
    <div class="list-image-hero__brand-text">
      <p class="list-image-hero__brand-main">{brand}</p>
      {brandSub && <p class="list-image-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="list-image-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo-white-letter.svg" class="list-image-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="list-image-hero__content">
    <div class="list-image-hero__left">
      <h2 class="list-image-hero__title">
        {italicPart
          ? <>{title.split(italicPart)[0]}<em class="list-image-hero__title-italic"><span class="underline">{italicPart}</span></em>{title.split(italicPart)[1]}</>
          : title}
      </h2>
      {subtitle && (
        <p class="list-image-hero__subtitle">
          <span class="list-image-hero__subtitle-square" aria-hidden="true"></span>
          {subtitle}
        </p>
      )}
      {body && <p class="list-image-hero__body">{body}</p>}
    </div>

    <div class="list-image-hero__right">
      <ol class="list-image-hero__cards">
        {items.map((item) => (
          <li class="list-image-hero__card">
            {item.label && <span class="list-image-hero__card-label">{item.label}</span>}
            <span class="list-image-hero__card-title">
              {item.italicPart
                ? <>{item.title.split(item.italicPart)[0]}<em>{item.italicPart}</em>{item.title.split(item.italicPart)[1]}</>
                : item.title}
            </span>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .list-image-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, #FFFFFF 0%, #EFEFF2 100%);
    color: #191919;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width intangible (border-bottom pleine largeur). */
  .list-image-hero__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 64px 96px 24px;
    border-bottom: 1px solid rgba(25, 25, 25, 0.12);
  }
  .list-image-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: #191919;
    text-align: left;
  }
  .list-image-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: #6B6F84;
    text-align: left;
  }
  .list-image-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Sous le header : texte à gauche (58%), pile de cards sur image à droite (42%). */
  .list-image-hero__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
  }

  .list-image-hero__left {
    position: relative;
    z-index: 1;
    width: 58%;
    padding: 40px 56px 64px 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }
  .list-image-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(56px, 5.4vw, 92px);
    line-height: 1.04;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: #191919;
    text-wrap: balance;
    text-align: left;
  }
  .list-image-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .list-image-hero__subtitle {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 500;
    color: #6B6F84;
    margin: 28px 0 0;
  }
  .list-image-hero__subtitle-square {
    width: 14px;
    height: 14px;
    background: #FFD838;
    display: inline-block;
    flex: 0 0 auto;
  }
  .list-image-hero__body {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.5;
    color: #6B6F84;
    margin: 28px 0 0;
    max-width: 760px;
  }

  /* Colonne droite : image floutée en fond + voile clair, cards posées dessus. */
  .list-image-hero__right {
    position: relative;
    width: 42%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    padding: 40px 96px 40px 24px;
    min-height: 0;
  }
  .list-image-hero__image {
    position: absolute;
    top: 0;
    right: 0;
    width: 42%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }
  .list-image-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px) saturate(0.7);
    transform: scale(1.08);
  }
  .list-image-hero__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.2) 100%);
  }

  .list-image-hero__cards {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .list-image-hero__card {
    background: #FFFFFF;
    border: 1px solid rgba(25, 25, 25, 0.08);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px rgba(25, 25, 25, 0.08);
    padding: 16px 24px;
    text-align: center;
  }
  .list-image-hero__card-label {
    display: block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #6B6F84;
    margin-bottom: 4px;
  }
  .list-image-hero__card-title {
    display: block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.2;
    color: #191919;
  }
  .list-image-hero__card-title em {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
</style>
