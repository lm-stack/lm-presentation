---
// src/components/slides/ListImageHero.astro
// "Liste sur image" ExecEd-style, transposition LIGHT du slide listing HEC :
// header full-width (brand + logo + border pleine largeur), à gauche titre serif
// italique partiel + sous-titre (carré jaune) + paragraphe, à droite une pile de
// cards (label + titre) posées sur une image floutée. Charte LM light (pas de
// fond dark : fond pearl + voile clair sur l'image).
interface ListItem {
  /** Petit sur-titre de la card, ex "Module 1". */
  label?: string;
  title: string;
  /** Portion du titre rendue en italique serif. */
  italicPart?: string;
  /** Ligne d'objectif affichée sous le titre de la card. */
  objective?: string;
  /** Met la card en avant (cadre jaune) + puce "Vous êtes ici". */
  current?: boolean;
}
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  body?: string;
  /** Image de fond (floutée) de la colonne droite. */
  image: string;
  items: ListItem[];
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  body,
  image,
  items,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="list-image-hero" data-layout="list-image-hero">
  <div class="list-image-hero__image" aria-hidden="true">
    <img src={image} alt="" loading="lazy" decoding="async" />
    <div class="list-image-hero__image-overlay"></div>
  </div>

  <header class="list-image-hero__header">
    <div class="list-image-hero__brand-text">
      <p class="list-image-hero__brand-main">{brand}</p>
      {brandSub && <p class="list-image-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="list-image-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo-white-letter.svg" class="list-image-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="list-image-hero__content">
    <div class="list-image-hero__left">
      <h2 class="list-image-hero__title">
        {italicPart
          ? <>{title.split(italicPart)[0]}<em class="list-image-hero__title-italic"><span class="underline">{italicPart}</span></em>{title.split(italicPart)[1]}</>
          : title}
      </h2>
      {subtitle && (
        <p class="list-image-hero__subtitle">{subtitle}</p>
      )}
      {body && <p class="list-image-hero__body">{body}</p>}
    </div>

    <div class="list-image-hero__right">
      <ol class="list-image-hero__cards">
        {items.map((item) => (
          <li class={`list-image-hero__card${item.current ? ' is-current' : ''}`}>
            {(item.label || item.current) && (
              <span class="list-image-hero__card-label">
                {item.label}
                {item.current && <span class="list-image-hero__card-here">Vous êtes ici</span>}
              </span>
            )}
            <span class="list-image-hero__card-title">
              {item.italicPart
                ? <>{item.title.split(item.italicPart)[0]}<em>{item.italicPart}</em>{item.title.split(item.italicPart)[1]}</>
                : item.title}
            </span>
            {item.objective && <span class="list-image-hero__card-obj">{item.objective}</span>}
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .list-image-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width intangible (border-bottom pleine largeur). */
  .list-image-hero__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .list-image-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .list-image-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .list-image-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Sous le header : texte à gauche (58%), pile de cards sur image à droite (42%). */
  .list-image-hero__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
  }

  .list-image-hero__left {
    position: relative;
    z-index: 1;
    width: 58%;
    padding: 40px 56px 64px 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }
  .list-image-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(56px, 5.4vw, 92px);
    line-height: 1.04;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .list-image-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .list-image-hero__subtitle {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    font-weight: 500;
    color: var(--c-muted);
    margin: 28px 0 0;
  }
  .list-image-hero__subtitle-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    display: inline-block;
    flex: 0 0 auto;
  }
  .list-image-hero__body {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--c-muted);
    margin: 28px 0 0;
    max-width: 760px;
  }

  /* Colonne droite : image floutée en fond + voile clair, cards posées dessus. */
  .list-image-hero__right {
    position: relative;
    width: 42%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    padding: 40px 56px;
    min-height: 0;
  }
  .list-image-hero__image {
    position: absolute;
    top: 0;
    right: 0;
    width: 42%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }
  .list-image-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px) saturate(0.7);
    transform: scale(1.08);
  }
  .list-image-hero__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.2) 100%);
  }

  .list-image-hero__cards {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .list-image-hero__card {
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 16px 24px;
    text-align: center;
  }
  .list-image-hero__card-label {
    display: block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    margin-bottom: 4px;
  }
  .list-image-hero__card-title {
    display: block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--c-ink);
  }
  .list-image-hero__card-title em {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  /* Objectif sous le titre de la card (un objectif par module). */
  .list-image-hero__card-obj {
    display: block;
    margin-top: 8px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 17px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--c-muted);
  }

  /* Card mise en avant : le module courant du parcours. */
  .list-image-hero__card.is-current {
    border-color: var(--c-accent);
    background: color-mix(in srgb, var(--c-accent) 8%, var(--c-surface));
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .list-image-hero__card-here {
    display: inline-block;
    margin-left: 10px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-on-accent);
    background: var(--c-accent);
    border-radius: 4px;
    padding: 2px 8px;
    vertical-align: middle;
  }
</style>
