---
// src/components/slides/Exchange.astro
// Slide "Échange" ExecEd-style : header standard (brand + logo LM + border, 44/40),
// à gauche une pastille "Échange" (carré jaune) + titre (Hanken Grotesk, portion
// en serif italique soulignée jaune) + sous-titre + liste optionnelle de points de
// discussion ; à droite un motif "discussion" (icône chats-circle posée dans un
// halo doré, écho du thème halo-gold de Cover). Charte LM light, fond pearl.
//
// Pendant ExecEd de la transition Exchange (ancien format, pleine page rouge) :
// un temps d'échange devient un slide de contenu cohérent avec la famille Hero
// (même header, même fond, même grammaire typographique que Demo/Workshop/Statement).
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';

interface Props {
  title: string;
  /** Portion du titre en serif italique soulignée jaune. */
  italicPart?: string;
  subtitle?: string;
  /** Libellé de la pastille en haut à gauche. Défaut "Échange". */
  eyebrow?: string;
  /** Points de discussion optionnels, listés sous le sous-titre. */
  prompts?: string[];
  /** Icône Phosphor du motif de droite. Défaut "ph:chats-circle-fill". */
  icon?: string;
  brand?: string;
  brandSub?: string;
  tocLabel?: string;
}
const {
  title,
  italicPart,
  subtitle,
  eyebrow = 'Échange',
  prompts = [],
  icon = 'ph:chats-circle-fill',
  brand = 'Titre de la présentation',
  brandSub,
  tocLabel,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="exchange" data-layout="exchange" data-section-title={tocLabel}>
  <header class="exchange__header">
    <div class="exchange__brand-text">
      <p class="exchange__brand-main">{brand}</p>
      {brandSub && <p class="exchange__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="exchange__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="exchange__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="exchange__content">
    <div class="exchange__text">
      <p class="exchange__eyebrow">
        <span class="exchange__eyebrow-square" aria-hidden="true"></span>{eyebrow}
      </p>
      <h2 class="exchange__title">
        {titleParts
          ? <>{titleParts.before}<em class="exchange__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="exchange__subtitle">{subtitle}</p>}
      {prompts.length > 0 && (
        <ul class="exchange__prompts">
          {prompts.map((p) => (
            <li class="exchange__prompt">
              <span class="exchange__prompt-mark" aria-hidden="true"></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <div class="exchange__visual" aria-hidden="true">
      <span class="exchange__halo"></span>
      <span class="exchange__icon">
        <Icon name={icon} />
      </span>
    </div>
  </div>
</section>

<style>
  .exchange {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header standard intangible : brand gauche + logo LM droite + border-bottom. */
  .exchange__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .exchange__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .exchange__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .exchange__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Corps centré verticalement dans l'espace sous le header. */
  .exchange__content {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    gap: 80px;
  }
  .exchange__text {
    flex: 1 1 0;
    min-width: 0;
  }

  .exchange__eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    margin: 0 0 24px;
    opacity: 0;
    animation: ex-fade-left 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both;
  }
  .exchange__eyebrow-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    display: inline-block;
    flex: 0 0 auto;
  }

  .exchange__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
    opacity: 0;
    animation: ex-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.28s both;
  }
  .exchange__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .exchange__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    color: var(--c-muted);
    margin: 28px 0 0;
    max-width: var(--measure-m);
    opacity: 0;
    animation: ex-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.42s both;
  }

  /* Liste optionnelle de points de discussion. */
  .exchange__prompts {
    list-style: none;
    margin: 36px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: var(--measure-m);
    opacity: 0;
    animation: ex-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.54s both;
  }
  .exchange__prompt {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 400;
    color: var(--c-ink);
  }
  .exchange__prompt-mark {
    flex: 0 0 auto;
    width: 12px;
    height: 12px;
    margin-top: 11px;
    background: var(--c-accent);
    display: inline-block;
  }

  /* Colonne droite : motif "discussion", icône dans un halo doré, centré. */
  .exchange__visual {
    flex: 0 0 38%;
    position: relative;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .exchange__halo {
    position: absolute;
    width: 460px;
    height: 460px;
    max-width: 90%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--c-accent) 30%, transparent) 0%, color-mix(in srgb, var(--c-accent) 0%, transparent) 68%);
    opacity: 0;
    animation: ex-scale-in 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }
  .exchange__icon {
    position: relative;
    display: block;
    width: clamp(240px, 22vw, 340px);
    height: clamp(240px, 22vw, 340px);
    color: var(--c-ink);
    opacity: 0;
    animation: ex-scale-in 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) 0.34s both;
  }
  .exchange__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  @keyframes ex-fade-up {
    from { opacity: 0; transform: translateY(26px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes ex-fade-left {
    from { opacity: 0; transform: translateX(-22px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes ex-scale-in {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
