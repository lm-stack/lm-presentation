---
// src/components/slides/Media.astro
// Figure / média en grand "ExecEd-style" : header marque + logo (44/40), titre
// serif italique partiel + sous-titre + body optionnels, puis une grande image
// (chart, capture, diagramme) affichée ENTIÈRE (object-fit: contain par défaut)
// dans un cadre radius 4px. Légende optionnelle sous l'image.
//
// Conçu pour ne RIEN rogner d'un chart : remplace l'ancien BigImage du format
// SlideTitle. Avec fit="cover", sert aussi d'illustration pleine (statements).
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  /** Paragraphe optionnel (message clé), sous le sous-titre. */
  body?: string;
  image: string;
  alt?: string;
  /** 'contain' (défaut : chart/diagramme entier) ou 'cover' (illustration pleine). */
  fit?: 'contain' | 'cover';
  /** Légende sous l'image (source, précision). */
  caption?: string;
  brand?: string;
  brandSub?: string;
  tocLabel?: string;
}
import { splitHighlight } from '@/utils/highlight';
const {
  title,
  italicPart,
  subtitle,
  body,
  image,
  alt = '',
  fit = 'contain',
  caption,
  brand = 'Titre de la présentation',
  brandSub,
  tocLabel,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="media" data-layout="media">
  <header class="media__header">
    <div class="media__brand-text">
      <p class="media__brand-main">{brand}</p>
      {brandSub && <p class="media__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="media__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="media__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="media__body">
    <div class="media__heading">
      <h2 class="media__title">
        {titleParts
          ? <>{titleParts.before}<em class="media__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="media__subtitle">{subtitle}</p>}
      {body && <p class="media__text">{body}</p>}
    </div>

    <figure class:list={['media__figure', `media__figure--${fit}`]}>
      <img src={image} alt={alt} loading="lazy" decoding="async" />
    </figure>

    {caption && <p class="media__caption">{caption}</p>}
  </div>
</section>

<style>
  .media {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom (44/40). */
  .media__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .media__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .media__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .media__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Corps : heading compact en haut, figure qui prend l'espace restant. */
  .media__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding-top: 28px;
    gap: 20px;
  }
  .media__heading {
    flex: 0 0 auto;
  }
  .media__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .media__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .media__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 12px 0 0;
    max-width: 1500px;
  }
  .media__text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 400;
    color: var(--c-muted);
    margin: 12px 0 0;
    max-width: 1200px;
  }

  /* Figure : prend l'espace restant, image entière (contain) ou remplie (cover). */
  .media__figure {
    flex: 1 1 auto;
    min-height: 0;
    margin: 0;
    border-radius: 4px;
    overflow: hidden;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 6%, transparent);
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .media__figure img {
    width: 100%;
    height: 100%;
    display: block;
  }
  .media__figure--contain img {
    object-fit: contain;
  }
  .media__figure--cover img {
    object-fit: cover;
  }
  .media__caption {
    flex: 0 0 auto;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-source);
    font-weight: 500;
    color: var(--c-muted);
    margin: 0;
    text-align: left;
  }
</style>
