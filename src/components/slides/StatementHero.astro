---
// src/components/slides/StatementHero.astro
// Slide "déclaration / chiffre-clé" ExecEd-style : header standard (brand + logo
// + border, 44/40), à gauche eyebrow + titre statement (serif italique souligné,
// sur deux lignes via \n) + corps, à droite un grand chiffre (stat) optionnel +
// légende centrés. Footer "Source" cliquable en bas à gauche (.slide-source).
interface Props {
  eyebrow?: string;
  /** Titre statement. Un \n force un saut de ligne (white-space: pre-line). */
  title: string;
  italicPart?: string;
  body?: string;
  /** Grand chiffre mis en avant, ex "21%". Optionnel. */
  stat?: string;
  /** Légende sous le chiffre. */
  statCaption?: string;
  /** Étude citée, affichée en bas à gauche. Ex "Wavestone, 2024". */
  source?: string;
  /** Lien vers l'étude : rend la source cliquable. */
  sourceUrl?: string;
  brand?: string;
  brandSub?: string;
  /** Affiche une animation "réseau" (noeuds reliés) dans la colonne de droite. */
  network?: boolean;
}
import { splitHighlight } from '@/utils/highlight';
const {
  eyebrow,
  title,
  italicPart,
  body,
  stat,
  statCaption,
  source,
  sourceUrl,
  brand = 'Titre de la présentation',
  brandSub,
  network = false,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="statement-hero" data-layout="statement-hero">
  <header class="statement-hero__header">
    <div class="statement-hero__brand-text">
      <p class="statement-hero__brand-main">{brand}</p>
      {brandSub && <p class="statement-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="statement-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="statement-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="statement-hero__content">
    <div class="statement-hero__text">
      {eyebrow && (
        <p class="statement-hero__eyebrow">
          <span class="statement-hero__eyebrow-square" aria-hidden="true"></span>{eyebrow}
        </p>
      )}
      <h2 class="statement-hero__title">
        {titleParts
          ? <>{titleParts.before}<em class="statement-hero__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {body && <p class="statement-hero__body">{body}</p>}
    </div>

    {stat && (
      <div class="statement-hero__stat-block">
        <span class="statement-hero__stat">{stat}</span>
        {statCaption && <span class="statement-hero__stat-caption">{statCaption}</span>}
      </div>
    )}

    {network && (
      <div class="statement-hero__network" aria-hidden="true">
        <canvas class="statement-hero__network-canvas"></canvas>
      </div>
    )}
  </div>

  {source && (sourceUrl
    ? <a class="slide-source" href={sourceUrl} target="_blank" rel="noopener">Source : {source}</a>
    : <p class="slide-source">Source : {source}</p>)}
</section>

<style>
  .statement-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .statement-hero__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .statement-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .statement-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .statement-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .statement-hero__content {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    gap: 80px;
  }
  .statement-hero__text {
    flex: 1 1 0;
    min-width: 0;
  }
  .statement-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    margin: 0 0 24px;
  }
  .statement-hero__eyebrow-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    display: inline-block;
    flex: 0 0 auto;
  }
  .statement-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(56px, 5.6vw, 96px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    white-space: pre-line;
    text-align: left;
  }
  .statement-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .statement-hero__body {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    line-height: 1.45;
    font-weight: 400;
    color: var(--c-muted);
    margin: 28px 0 0;
    max-width: 760px;
  }

  /* Chiffre-clé à droite, centré horizontalement dans sa colonne. */
  .statement-hero__stat-block {
    flex: 0 0 auto;
    width: 38%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .statement-hero__stat {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(120px, 13vw, 220px);
    line-height: 0.95;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--c-ink);
  }
  .statement-hero__stat-caption {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.35;
    font-weight: 500;
    color: var(--c-muted);
    margin-top: 12px;
    max-width: 420px;
    text-align: center;
  }

  /* Colonne droite : champ de noeuds reliés (canvas), bleed sans cadre. */
  .statement-hero__network {
    flex: 0 0 38%;
    align-self: stretch;
    position: relative;
    overflow: hidden;
  }
  .statement-hero__network-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<style is:global>
  /* Footer "Source" réutilisable, en bas à gauche, pour citer une étude sur
     n'importe quelle slide. Positionné par rapport à la <section> (relative).
     Toujours cliquable quand un lien est fourni. */
  [data-layout] .slide-source {
    position: absolute;
    left: 96px;
    bottom: 40px;
    margin: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--c-faint);
    letter-spacing: 0.01em;
    z-index: 3;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  [data-layout] a.slide-source:hover {
    color: var(--c-ink);
    text-decoration: underline;
  }
</style>

<script>
  // Champ de noeuds reliés ("réseau" entités/relations) pour la colonne droite
  // du StatementHero quand network={true}. Même esprit que le matrix rain, motif
  // différent : des points qui dérivent, reliés par une ligne quand ils sont proches.
  function initStatementNetwork(canvas: HTMLCanvasElement) {
    const parent = canvas.parentElement;
    if (!parent) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const slide = canvas.closest<HTMLElement>('[data-layout="statement-hero"]');
    const cs = getComputedStyle(slide ?? document.documentElement);
    const accent = cs.getPropertyValue('--c-accent').trim() || '#C8A24B';
    const ink = cs.getPropertyValue('--c-ink').trim() || '#191919';

    let W = 0, H = 0;
    interface Pt { x: number; y: number; vx: number; vy: number; }
    let nodes: Pt[] = [];
    const LINK = 150;

    function build() {
      W = canvas.width = parent!.offsetWidth;
      H = canvas.height = parent!.offsetHeight;
      const count = Math.max(14, Math.min(40, Math.floor((W * H) / 16000)));
      nodes = [];
      for (let i = 0; i < count; i++) {
        nodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
        });
      }
    }
    build();

    function step() {
      for (const n of nodes) {
        n.x += n.vx; n.y += n.vy;
        if (n.x < 0 || n.x > W) n.vx = -n.vx;
        if (n.y < 0 || n.y > H) n.vy = -n.vy;
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, W, H);
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const dx = a.x - b.x, dy = a.y - b.y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < LINK) {
            ctx!.globalAlpha = (1 - d / LINK) * 0.22;
            ctx!.strokeStyle = ink;
            ctx!.lineWidth = 1;
            ctx!.beginPath();
            ctx!.moveTo(a.x, a.y);
            ctx!.lineTo(b.x, b.y);
            ctx!.stroke();
          }
        }
      }
      ctx!.globalAlpha = 0.85;
      ctx!.fillStyle = accent;
      for (const n of nodes) {
        ctx!.beginPath();
        ctx!.arc(n.x, n.y, 3, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
    }

    let running = true;
    new IntersectionObserver(([e]) => { running = e.isIntersecting; }, { threshold: 0 }).observe(canvas);
    new ResizeObserver(() => build()).observe(parent);

    function loop() { if (running) { step(); draw(); } requestAnimationFrame(loop); }
    loop();
  }

  function initStatementNetworks() {
    document.querySelectorAll<HTMLCanvasElement>('.statement-hero__network-canvas').forEach((c) => {
      if (c.dataset.netInit) return;
      c.dataset.netInit = '1';
      initStatementNetwork(c);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStatementNetworks);
  } else {
    initStatementNetworks();
  }
</script>
