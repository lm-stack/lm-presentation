---
// src/components/slides/BarChartHero.astro
// Graphique en barres horizontales "ExecEd-style", 100% CSS (aucune librairie).
// Layout : valeur + barre calees a GAUCHE (alignees au titre), description a
// DROITE de chaque barre (text-align: left). Header marque + logo, titre serif
// italique partiel + sous-titre. Barres jaunes animees en cascade au reveal.
// Source citee via le footer global .slide-source (defini dans src/styles/slides.css,
// activable sur tout slide), cliquable si `sourceUrl` fourni. Data-driven via `items`.
import { splitHighlight } from '@/utils/highlight';
interface BarItem {
  label: string;
  value: number;
  emphasis?: boolean;
}
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  items: BarItem[];
  /** Valeur max de l'échelle (défaut 100 pour des pourcentages). */
  max?: number;
  /** Suffixe affiché après chaque valeur (défaut "%"). */
  unit?: string;
  /** Texte de la source (échantillon, étude, note méthodo) : footer bas-gauche. */
  source?: string;
  /** Lien rendant la source cliquable (ex : le rapport). */
  sourceUrl?: string;
  brand?: string;
  brandSub?: string;
  tocLabel?: string;
}
const {
  title,
  italicPart,
  subtitle,
  items,
  max = 100,
  unit = '%',
  source,
  sourceUrl,
  brand = 'Titre de la présentation',
  brandSub,
  tocLabel,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
const hasEmphasis = items.some((it) => it.emphasis);
---
<section class="bar-chart-hero" data-layout="bar-chart-hero">
  <header class="bar-chart-hero__header">
    <div class="bar-chart-hero__brand-text">
      <p class="bar-chart-hero__brand-main">{brand}</p>
      {brandSub && <p class="bar-chart-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="bar-chart-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="bar-chart-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="bar-chart-hero__body">
    <div class="bar-chart-hero__heading">
      <h2 class="bar-chart-hero__title">
        {titleParts
          ? <>{titleParts.before}<em class="bar-chart-hero__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="bar-chart-hero__subtitle">{subtitle}</p>}
    </div>

    <ul class="bar-chart-hero__chart">
      {items.map((item, i) => {
        const pct = Math.max(0, Math.min(100, (item.value / max) * 100));
        const dim = hasEmphasis && !item.emphasis;
        return (
          <li class:list={['bar-chart-hero__row', dim && 'is-dim']}>
            <span class="bar-chart-hero__value">{item.value}{unit}</span>
            <span class="bar-chart-hero__track">
              <span class="bar-chart-hero__fill" style={`width: ${pct}%; --i: ${i};`}></span>
            </span>
            <span class="bar-chart-hero__label">{item.label}</span>
          </li>
        );
      })}
    </ul>
  </div>

  {source && (sourceUrl
    ? <a class="slide-source" href={sourceUrl} target="_blank" rel="noopener">Source : {source}</a>
    : <p class="slide-source">Source : {source}</p>)}
</section>

<style>
  .bar-chart-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }
  .bar-chart-hero__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .bar-chart-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; margin: 0; color: var(--c-ink); text-align: left;
  }
  .bar-chart-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px; font-weight: 500; text-transform: uppercase;
    letter-spacing: 0.18em; margin: 4px 0 0; color: var(--c-muted); text-align: left;
  }
  .bar-chart-hero__brand-logo { height: 48px; width: auto; display: block; flex: 0 0 auto; }

  .bar-chart-hero__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 28px;
    gap: 60px;
  }
  .bar-chart-hero__heading { flex: 0 0 auto; }
  .bar-chart-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(40px, 4vw, 64px);
    line-height: 1.06; font-weight: 600; letter-spacing: -0.02em;
    margin: 0; color: var(--c-ink); text-wrap: balance; text-align: left;
  }
  .bar-chart-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic; font-weight: 400;
  }
  .bar-chart-hero__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px; line-height: 1.4; font-weight: 500; color: var(--c-muted);
    margin: 12px 0 0; max-width: 1200px;
  }

  .bar-chart-hero__chart {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 18px;
  }
  /* valeur (gauche) | piste fixe | description (droite, alignée gauche) */
  .bar-chart-hero__row {
    display: grid;
    grid-template-columns: 72px 660px 1fr;
    align-items: center;
    gap: 28px;
  }
  .bar-chart-hero__value {
    font-family: 'Space Grotesk', 'Hanken Grotesk', monospace;
    font-size: 26px; font-weight: 700; color: var(--c-ink);
    font-variant-numeric: tabular-nums; text-align: right;
  }
  .bar-chart-hero__track {
    height: 44px; background: color-mix(in srgb, var(--c-ink) 6%, transparent);
    border-radius: 4px; overflow: hidden; position: relative;
  }
  .bar-chart-hero__fill {
    display: block; height: 100%; background: var(--c-accent); border-radius: 4px;
    transform-origin: left center;
    animation: bar-chart-hero-grow 0.85s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--i, 0) * 0.09s);
  }
  .bar-chart-hero__label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px; font-weight: 600; line-height: 1.25;
    color: var(--c-ink); text-align: left;
  }
  .bar-chart-hero__row.is-dim .bar-chart-hero__fill { background: color-mix(in srgb, var(--c-accent) 34%, transparent); }
  .bar-chart-hero__row.is-dim .bar-chart-hero__value,
  .bar-chart-hero__row.is-dim .bar-chart-hero__label { color: var(--c-muted); }

  @keyframes bar-chart-hero-grow {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
</style>
