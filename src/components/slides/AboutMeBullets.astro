---
// src/components/slides/AboutMeBullets.astro
// Slide complement de AboutMe : 4 bullets numerotes en grid 2x2, sans photo.
// Optionnellement on rappelle nom + eyebrow en chapo discret en haut.
// Charte LM (gold/noir, Hanken+Space Grotesk).

interface Bullet {
  label: string;
  text: string;
}

interface Props {
  eyebrow?: string;
  firstName?: string;
  lastName?: string;
  highlight?: string;
  watermark?: string;
  bullets: Bullet[];
}

const {
  eyebrow = 'En 4 points',
  firstName,
  lastName,
  highlight,
  watermark,
  bullets,
} = Astro.props;

import { splitHighlight } from '@/utils/highlight';

const lastNameParts = lastName ? splitHighlight(lastName, highlight) : null;
const showHeader = Boolean(firstName || lastName);
---
<section
  class="about-me-bullets"
  data-layout="about-me-bullets"
  data-section-title="À propos"
>
  <span class="about-me-bullets__wash" aria-hidden="true"></span>
  {watermark && <span class="about-me-bullets__watermark" aria-hidden="true">{watermark}</span>}

  <div class="about-me-bullets__layout">
    {showHeader && (
      <div class="about-me-bullets__header">
        <p class="about-me-bullets__eyebrow">{eyebrow}</p>
        {(firstName || lastName) && (
          <h2 class="about-me-bullets__name">
            {firstName && <span class="about-me-bullets__first">{firstName} </span>}
            {lastName && (
              <span class="about-me-bullets__last">
                {lastNameParts
                  ? <>{lastNameParts.before}<span class="about-me-bullets__mark">{lastNameParts.match}</span>{lastNameParts.after}</>
                  : lastName}
              </span>
            )}
          </h2>
        )}
        <span class="about-me-bullets__rule" aria-hidden="true"></span>
      </div>
    )}

    <ul class="about-me-bullets__list">
      {bullets.map((b, i) => (
        <li class="about-me-bullets__item" style={`--i: ${i}`}>
          <span class="about-me-bullets__num">{String(i + 1).padStart(2, '0')}</span>
          <div class="about-me-bullets__body">
            <span class="about-me-bullets__label">{b.label}</span>
            <span class="about-me-bullets__text">{b.text}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .about-me-bullets {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 96px 96px !important;
    background: var(--slide-bg, #FAF8F3);
    color: #191919;
    display: flex !important;
    flex-direction: column;
    justify-content: center !important;
  }

  .about-me-bullets__wash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 100% 0%, rgba(255, 216, 56, 0.28) 0%, rgba(255, 216, 56, 0) 55%);
    z-index: 0;
  }

  .about-me-bullets__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding-left: -32px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 800;
    font-size: 880px;
    line-height: 0.78;
    letter-spacing: -0.07em;
    color: #FFD838;
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
    z-index: 0;
    opacity: 0.85;
    -webkit-mask-image: linear-gradient(to left, #000 30%, rgba(0, 0, 0, 0.18) 100%);
    mask-image: linear-gradient(to left, #000 30%, rgba(0, 0, 0, 0.18) 100%);
    animation: about-bullets-watermark 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .about-me-bullets__layout {
    position: relative;
    z-index: 1;
    max-width: 1700px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .about-me-bullets__header {
    animation: about-bullets-stagger 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .about-me-bullets__eyebrow {
    display: inline-block;
    font-family: 'Space Grotesk', monospace;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: #191919;
    margin: 0 0 24px;
    padding: 10px 20px;
    background: #FFD838;
    border: 2px solid #191919;
    border-radius: 4px;
  }

  .about-me-bullets__name {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 800;
    font-size: clamp(72px, 8vw, 120px);
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: #191919;
    margin: 0 0 16px;
    text-align: left;
    text-wrap: balance;
  }
  .about-me-bullets__first {
    opacity: 0.45;
    font-weight: 400;
  }
  .about-me-bullets__last { color: #191919; }
  .about-me-bullets__mark {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .about-me-bullets__mark::after {
    content: '';
    position: absolute;
    left: -6px;
    right: -6px;
    bottom: 4px;
    height: 12px;
    background: #191919;
    z-index: -1;
    transform: rotate(-1.5deg);
  }
  .about-me-bullets__rule {
    display: block;
    width: 96px;
    height: 6px;
    background: #FFD838;
  }

  .about-me-bullets__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px 64px;
  }

  .about-me-bullets__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 28px;
    align-items: center;
    padding-bottom: 24px;
    border-bottom: 2px solid rgba(25, 25, 25, 0.10);
    animation: about-bullets-stagger 0.55s cubic-bezier(0.16, 1, 0.3, 1) calc(0.15s + var(--i, 0) * 0.08s) both;
  }

  .about-me-bullets__num {
    font-family: 'Space Grotesk', monospace;
    font-weight: 700;
    font-size: 88px;
    line-height: 1;
    color: #FFD838;
    -webkit-text-stroke: 2.5px #191919;
    letter-spacing: -0.02em;
  }

  .about-me-bullets__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .about-me-bullets__label {
    font-family: 'Space Grotesk', monospace;
    font-size: 24px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #191919;
  }

  .about-me-bullets__text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 30px;
    font-weight: 400;
    line-height: 1.35;
    color: #6B6F84;
  }

  @keyframes about-bullets-stagger {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes about-bullets-watermark {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 0.85; transform: translateX(0); }
  }
</style>
