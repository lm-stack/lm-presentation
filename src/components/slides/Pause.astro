---
// src/components/slides/Pause.astro
// Slide Pause ExecEd-style : header full-width standard, fond pearl, titre serif
// italique partiel, puis un TimerControl (sélection de durée -> compteur géant).
// Lecteur Spotify optionnel à droite (logique reprise de Timer.astro).
import TimerControl from '@/components/slides/TimerControl.astro';
import { splitHighlight } from '@/utils/highlight';

interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  /** Durées proposées en minutes. */
  presets?: number[];
  /** Durée affichée par défaut (démarre directement en mode décompte). */
  defaultMinutes?: number;
  /** URL Spotify de la playlist (track/album/playlist/episode/show/artist).
      Le lecteur est TOUJOURS affiché : sans valeur (ou valeur invalide), on
      retombe sur DEFAULT_SPOTIFY. C'est le moyen de choisir la musique par deck. */
  spotify?: string;
  brand?: string;
  brandSub?: string;
  /** Libellé ToC. Sans lui, la pause n'apparaît pas au Sommaire (opt-in). */
  tocLabel?: string;
}
const {
  title = 'Pause',
  italicPart = 'Pause',
  subtitle,
  presets = [5, 10, 15],
  defaultMinutes = 15,
  spotify,
  brand = 'Titre de la présentation',
  brandSub,
  tocLabel,
} = Astro.props;

const titleParts = splitHighlight(title, italicPart);
// Pas de Spotify en mode handout (PDF) : l'iframe n'a pas de sens imprimée.
const isHandout = Astro.url.pathname.includes('/handout/');

// Playlist Spotify par défaut du lecteur de pause (le lecteur est OBLIGATOIRE).
// CHOISIR LA MUSIQUE : éditer cette constante (défaut global de tous les decks),
// ou passer la prop spotify="https://open.spotify.com/playlist/..." sur un
// <Pause> précis (choix par deck, prioritaire sur ce défaut).
const DEFAULT_SPOTIFY = 'https://open.spotify.com/playlist/37i9dQZF1DWZeKCadgRdKQ';

const VALID_SPOTIFY_TYPES = new Set(['track', 'album', 'playlist', 'episode', 'show', 'artist']);
function parseSpotifyUrl(raw?: string): { type: string; id: string } | null {
  if (!raw) return null;
  try {
    const u = new URL(raw);
    if (!u.hostname.endsWith('spotify.com')) return null;
    const segments = u.pathname.split('/').filter(Boolean);
    const typeIdx = segments.findIndex((s) => VALID_SPOTIFY_TYPES.has(s));
    if (typeIdx === -1 || !segments[typeIdx + 1]) return null;
    return { type: segments[typeIdx], id: segments[typeIdx + 1] };
  } catch {
    return null;
  }
}
// Lecteur OBLIGATOIRE et non désactivable : un lien vide ou invalide retombe sur
// la playlist par défaut. La prop spotify reste le moyen de CHOISIR la musique.
const spotifyParsed =
  (typeof spotify === 'string' && spotify.trim() ? parseSpotifyUrl(spotify) : null)
  ?? parseSpotifyUrl(DEFAULT_SPOTIFY);
const spotifyEmbed = spotifyParsed
  ? `https://open.spotify.com/embed/${spotifyParsed.type}/${spotifyParsed.id}?utm_source=generator&theme=0`
  : null;
// Toujours visible sur les slides ; omis seulement en handout/PDF (un iframe ne
// se joue pas dans un document imprimé).
const showSpotify = !!spotifyEmbed && !isHandout;
---
<section class="pause" data-layout="pause" data-section-title={tocLabel}>
  <header class="pause__header">
    <div class="pause__brand-text">
      <p class="pause__brand-main">{brand}</p>
      {brandSub && <p class="pause__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="pause__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="pause__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class:list={['pause__body', { 'pause__body--spotify': showSpotify }]}>
    <div class="pause__main">
      <h2 class="pause__title">
        {titleParts
          ? <>{titleParts.before}<em class="pause__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="pause__subtitle">{subtitle}</p>}

      <div class="pause__timer">
        <TimerControl size="large" presets={presets} allowCustom={true} defaultMinutes={defaultMinutes} />
      </div>
    </div>

    {showSpotify && (
      <div class="pause__spotify" aria-label="Lecteur audio">
        <iframe
          src={spotifyEmbed}
          width="100%"
          height="100%"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          title="Lecteur Spotify"
        ></iframe>
      </div>
    )}
  </div>
</section>

<style>
  .pause {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .pause__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .pause__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .pause__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .pause__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .pause__body {
    flex: 1 1 auto;
    min-height: 0;
    padding: 32px 96px 64px;
    display: flex;
    align-items: center;
    gap: 64px;
  }
  .pause__main {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .pause__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-xl);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 32px;
    color: var(--c-ink);
    text-align: left;
  }
  .pause__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .pause__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    font-weight: 500;
    line-height: var(--lh-lead);
    color: var(--c-muted);
    margin: 0 0 32px;
    max-width: 900px;
  }
  .pause__timer {
    margin-top: 8px;
  }

  /* Lecteur Spotify : carte verticale à droite. */
  .pause__spotify {
    flex: 0 0 460px;
    align-self: center;
    height: 520px;
    margin-right: 40px;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 12px 32px -12px color-mix(in srgb, var(--c-ink) 25%, transparent);
  }
  .pause__spotify iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
