{/* Le style du footer source (.slide-source) est canonique dans
    src/styles/slides.css (bleu --c-secondary, bordure, icône lien externe).
    L'ancien override global qui vivait ici (color: --c-faint) a été retiré :
    il écrasait le bleu sur tout deck contenant un Statement. */}

<script>
  // Champ de noeuds reliés ("réseau" entités/relations) pour la colonne droite
  // du Statement quand network={true}. Même esprit que le matrix rain, motif
  // différent : des points qui dérivent, reliés par une ligne quand ils sont proches.
  function initStatementNetwork(canvas: HTMLCanvasElement) {
    const parent = canvas.parentElement;
    if (!parent) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const slide = canvas.closest<HTMLElement>('[data-layout="statement"]');
    const cs = getComputedStyle(slide ?? document.documentElement);
    const accent = cs.getPropertyValue('--c-accent').trim() || '#FFD838';
    const ink = cs.getPropertyValue('--c-ink').trim() || '#191919';

    let W = 0, H = 0;
    interface Pt { x: number; y: number; vx: number; vy: number; }
    let nodes: Pt[] = [];
    const LINK = 150;

    function build() {
      W = canvas.width = parent!.offsetWidth;
      H = canvas.height = parent!.offsetHeight;
      const count = Math.max(14, Math.min(40, Math.floor((W * H) / 16000)));
      nodes = [];
      for (let i = 0; i < count; i++) {
        nodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
        });
      }
    }
    build();

    function step() {
      for (const n of nodes) {
        n.x += n.vx; n.y += n.vy;
        if (n.x < 0 || n.x > W) n.vx = -n.vx;
        if (n.y < 0 || n.y > H) n.vy = -n.vy;
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, W, H);
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const dx = a.x - b.x, dy = a.y - b.y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < LINK) {
            ctx!.globalAlpha = (1 - d / LINK) * 0.22;
            ctx!.strokeStyle = ink;
            ctx!.lineWidth = 1;
            ctx!.beginPath();
            ctx!.moveTo(a.x, a.y);
            ctx!.lineTo(b.x, b.y);
            ctx!.stroke();
          }
        }
      }
      ctx!.globalAlpha = 0.85;
      ctx!.fillStyle = accent;
      for (const n of nodes) {
        ctx!.beginPath();
        ctx!.arc(n.x, n.y, 3, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
    }

    let running = true;
    new IntersectionObserver(([e]) => { running = e.isIntersecting; }, { threshold: 0 }).observe(canvas);
    new ResizeObserver(() => build()).observe(parent);

    function loop() { if (running) { step(); draw(); } requestAnimationFrame(loop); }
    loop();
  }

  function initStatementNetworks() {
    document.querySelectorAll<HTMLCanvasElement>('.statement__network-canvas').forEach((c) => {
      if (c.dataset.netInit) return;
      c.dataset.netInit = '1';
      initStatementNetwork(c);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStatementNetworks);
  } else {
    initStatementNetworks();
  }
</script>

<script>
  // Carte abstraite (entityCard.abstract) : les champs se "peuplent" de data en
  // boucle, avec un bref effet de "réparation" (valeur brouillée -> valeur propre
  // en accent) qui illustre la donnée qui se nettoie. Décor (carte aria-hidden).
  function initEntityFill(card: HTMLElement) {
    if (card.dataset.fillInit) return;
    card.dataset.fillInit = '1';
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fills = Array.from(card.querySelectorAll<HTMLElement>('.ec-fill'));
    fills.forEach((el, idx) => {
      let vals: string[] = [];
      try { vals = JSON.parse(el.dataset.vals || '[]'); } catch { vals = []; }
      if (vals.length < 2) return;
      let i = 0;
      const cycle = () => {
        el.classList.add('ec-fill--repair');
        el.textContent = '••••••••';
        window.setTimeout(() => {
          i = (i + 1) % vals.length;
          el.textContent = vals[i];
          el.classList.remove('ec-fill--repair');
          el.classList.add('ec-fill--set');
          window.setTimeout(() => el.classList.remove('ec-fill--set'), 650);
        }, 420);
      };
      if (reduce) return;
      window.setInterval(cycle, 3400 + idx * 260);
      window.setTimeout(cycle, 700 + idx * 320);
    });
  }
  function initEntityFills() {
    document.querySelectorAll<HTMLElement>('.ec-card--abstract').forEach(initEntityFill);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEntityFills);
  } else {
    initEntityFills();
  }
</script>
