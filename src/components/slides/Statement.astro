---
// src/components/slides/Statement.astro
// Slide "déclaration / chiffre-clé" ExecEd-style : header standard (brand + logo
// + border, 44/40), à gauche eyebrow + titre statement (serif italique souligné,
// sur deux lignes via \n) + corps, à droite un grand chiffre (stat) optionnel +
// légende centrés. Footer "Source" cliquable en bas à gauche (.slide-source).
interface Props {
  eyebrow?: string;
  /** Titre statement. Un \n force un saut de ligne (white-space: pre-line). */
  title: string;
  italicPart?: string;
  /** Taille du titre : 'xl' (défaut), 'l' (réduit, Statement denses avec bullets)
   *  ou 'm' (fs-hero-m, pour tenir un titre long sur une seule ligne en pleine largeur). */
  titleSize?: 'xl' | 'l' | 'm';
  body?: string;
  /** Liste à puces avec icône Phosphor devant chaque item (colonne gauche). */
  bullets?: { icon: string; text: string }[];
  /** Grand chiffre mis en avant, ex "21%". Optionnel. */
  stat?: string;
  /** Légende sous le chiffre. */
  statCaption?: string;
  /** Étude citée, affichée en bas à gauche. Ex "Wavestone, 2024". */
  source?: string;
  /** Lien vers l'étude : rend la source cliquable. */
  sourceUrl?: string;
  brand?: string;
  brandSub?: string;
  /** Affiche une animation "réseau" (noeuds reliés) dans la colonne de droite. */
  network?: boolean;
  /** Mini-ERD à droite : boîtes nommées + liens. Coordonnées dans une scène 220x260. */
  diagram?: {
    nodes: { label: string; x: number; y: number; accent?: boolean }[];
    links: { from: string; to: string; dashed?: boolean }[];
  };
  /** Carte Entité (ERD TableNode) mise en avant à droite, avec des dots (entités
   *  liées) reliées par des connecteurs qui la rejoignent. */
  entityCard?: {
    name: string;
    fields: { name: string; key?: 'pk' | 'fk' }[];
    satellites?: string[];
    /** Rendu abstrait : titre et champs en barres placeholder (sans texte),
     *  satellites nommés masqués au profit d'un nuage de points autour de la carte. */
    abstract?: boolean;
  };
}
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';
const {
  eyebrow,
  title,
  italicPart,
  titleSize = 'xl',
  body,
  bullets,
  stat,
  statCaption,
  source,
  sourceUrl,
  brand = 'Titre de la présentation',
  brandSub,
  network = false,
  diagram,
  entityCard,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);

// Mini-ERD optionnel (colonne droite) : extrémités des liens calculées au bord
// des boîtes (intersection ligne-rectangle), même principe que Erd.astro.
const DNW = 66;
const DNH = 30;
const dmap = new Map((diagram?.nodes ?? []).map((n) => [n.label, n]));
function dborder(n: { x: number; y: number }, tx: number, ty: number) {
  const cx = n.x + DNW / 2;
  const cy = n.y + DNH / 2;
  const dx = tx - cx;
  const dy = ty - cy;
  if (dx === 0 && dy === 0) return { x: cx, y: cy };
  const sx = dx !== 0 ? (DNW / 2) / Math.abs(dx) : Infinity;
  const sy = dy !== 0 ? (DNH / 2) / Math.abs(dy) : Infinity;
  const s = Math.min(sx, sy);
  return { x: cx + dx * s, y: cy + dy * s };
}
const dlinks = (diagram?.links ?? [])
  .map((l) => {
    const a = dmap.get(l.from);
    const b = dmap.get(l.to);
    if (!a || !b) return null;
    const ac = { x: a.x + DNW / 2, y: a.y + DNH / 2 };
    const bc = { x: b.x + DNW / 2, y: b.y + DNH / 2 };
    const p1 = dborder(a, bc.x, bc.y);
    const p2 = dborder(b, ac.x, ac.y);
    return { x1: p1.x, y1: p1.y, x2: p2.x, y2: p2.y, dashed: !!l.dashed };
  })
  .filter((l): l is NonNullable<typeof l> => l !== null);

// Carte Entité (option entityCard). Mode standard : TableNode + satellites (entités
// liées) reliés à gauche. Mode abstrait : carte plus grande et CENTRÉE dans la scène,
// champs qui se peuplent de data côté client, entourée d'un nuage de points. Scène
// fixe en px (espace 1920x1080 du slide, scalé uniformément par Reveal).
const ecAbstract = !!entityCard?.abstract;
const EC_STAGE_W = ecAbstract ? 760 : 584;
const EC_STAGE_H = ecAbstract ? 780 : 560;
const EC_CARD_W = ecAbstract ? 500 : 290;
const EC_HEAD_H = ecAbstract ? 78 : 56;
const EC_ROW_H = ecAbstract ? 62 : 40;
const EC_DOT_X = 124;
const ecCardH = entityCard ? EC_HEAD_H + entityCard.fields.length * EC_ROW_H : 0;
const ecCardY = (EC_STAGE_H - ecCardH) / 2;
// Carte centrée dans la scène en mode abstrait (plus de satellites) ; ancrée à
// droite (satellites reliés à sa gauche) en mode standard.
const EC_CARD_X = ecAbstract ? (EC_STAGE_W - EC_CARD_W) / 2 : 264;
const ecSats = ecAbstract ? [] : (entityCard?.satellites ?? []);
const ecSatPts = ecSats.map((label, i) => {
  const top = ecCardY + 30;
  const bot = ecCardY + ecCardH - 30;
  const y = ecSats.length <= 1 ? (top + bot) / 2 : top + (bot - top) * (i / (ecSats.length - 1));
  return { label, y };
});

// Nuage de points décoratif réparti sur TOUTE la scène (la carte masque le centre).
// Positions déterministes (hash sin-based : pas de Math.random, stable au build).
const ecFract = (x: number) => x - Math.floor(x);
const EC_DOTS_N = 64;
const ecDotCloud = ecAbstract
  ? Array.from({ length: EC_DOTS_N }, (_, i) => {
      const hx = ecFract(Math.sin((i + 1) * 12.9898) * 43758.5453);
      const hy = ecFract(Math.sin((i + 1) * 78.233) * 12721.531);
      const hr = ecFract(Math.sin((i + 1) * 3.137) * 9281.77);
      const ho = ecFract(Math.cos((i + 1) * 1.71) * 6571.33);
      return {
        x: hx * EC_STAGE_W,
        y: hy * EC_STAGE_H,
        r: 2.2 + hr * 4,
        o: 0.1 + ho * 0.5,
        accent: i % 3 === 0,
      };
    })
  : [];

// Valeurs de data qui "se peuplent" dans les champs de la carte abstraite (animées
// côté client : remplissage + brève réparation). Un jeu de valeurs par ligne.
const ecFillData = [
  ['CRM-1048', 'CRM-2271', 'CRM-3392', 'CRM-5067'],
  ['A. Dupont', 'M. Rey', 'L. Martin', 'C. Nord'],
  ['contact@dupont.ch', 'hello@rey.ch', 'info@martin.co', 'a.nord@studio.ch'],
  ['+41 21 312 44 90', '+41 79 644 12 08', '+41 22 731 55 20', '+41 26 422 18 73'],
  ['Dupont SA', 'Atelier Rey', 'Martin & Co', 'Studio Nord'],
  ['Resp. RH', 'Directrice', 'Gérant', 'Fondateur'],
  ['Cliente', 'Prospect', 'Cliente', 'Prospect'],
];
---
<section class="statement" data-layout="statement">
  <header class="statement__header">
    <div class="statement__brand-text">
      <p class="statement__brand-main">{brand}</p>
      {brandSub && <p class="statement__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="statement__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="statement__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="statement__content" data-dense={ecAbstract ? 'true' : undefined}>
    <div class="statement__text">
      {eyebrow && (
        <p class="statement__eyebrow">
          <span class="statement__eyebrow-square" aria-hidden="true"></span>{eyebrow}
        </p>
      )}
      <h2 class:list={['statement__title', titleSize === 'l' && 'statement__title--l', titleSize === 'm' && 'statement__title--m']}>
        {titleParts
          ? <>{titleParts.before}<em class="statement__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {bullets && bullets.length > 0 && (
        <ul class="statement__bullets">
          {bullets.map((b) => (
            <li class="statement__bullet">
              <span class="statement__bullet-icon"><Icon name={b.icon} aria-hidden="true" /></span>
              <span class="statement__bullet-text">{b.text}</span>
            </li>
          ))}
        </ul>
      )}
      {body && <p class="statement__body">{body}</p>}
    </div>

    {stat && (
      <div class="statement__stat-block">
        <span class="statement__stat">{stat}</span>
        {statCaption && <span class="statement__stat-caption">{statCaption}</span>}
      </div>
    )}

    {network && (
      <div class="statement__network" aria-hidden="true">
        <canvas class="statement__network-canvas"></canvas>
      </div>
    )}

    {diagram && (
      <div class="statement__diagram" aria-hidden="true">
        <svg class="statement__diagram-svg" viewBox="0 0 220 260" preserveAspectRatio="xMidYMid meet">
          <defs>
            <marker id="st-erd-arrow" markerWidth="9" markerHeight="9" refX="6.5" refY="4.5" orient="auto-start-reverse" markerUnits="userSpaceOnUse">
              <path d="M1.5,1.5 L7.5,4.5 L1.5,7.5 Z" class="st-erd-arrow-head" />
            </marker>
          </defs>
          {dlinks.map((l) => (
            <line class:list={['st-erd-link', { 'st-erd-link--dashed': l.dashed }]} x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2} marker-end="url(#st-erd-arrow)" />
          ))}
          {diagram.nodes.map((n) => (
            <g>
              <rect class:list={['st-erd-box', { 'st-erd-box--accent': n.accent }]} x={n.x} y={n.y} width={DNW} height={DNH} rx="4" />
              <text class="st-erd-text" x={n.x + DNW / 2} y={n.y + DNH / 2}>{n.label}</text>
            </g>
          ))}
        </svg>
      </div>
    )}

    {entityCard && (
      <div class="statement__entitycard" data-abstract={ecAbstract ? 'true' : 'false'} aria-hidden="true">
        <div class="ec-stage" style={`width:${EC_STAGE_W}px;height:${EC_STAGE_H}px`}>
          {ecAbstract ? (
            <svg class="ec-cloud" viewBox={`0 0 ${EC_STAGE_W} ${EC_STAGE_H}`} preserveAspectRatio="none">
              {ecDotCloud.map((d) => (
                <circle class:list={['ec-cloud-dot', { 'ec-cloud-dot--accent': d.accent }]} cx={d.x} cy={d.y} r={d.r} style={`opacity:${d.o}`} />
              ))}
            </svg>
          ) : (
            <svg class="ec-edges" viewBox={`0 0 ${EC_STAGE_W} ${EC_STAGE_H}`} preserveAspectRatio="none">
              {ecSatPts.map((p) => <line class="ec-link" x1={EC_DOT_X} y1={p.y} x2={EC_CARD_X} y2={p.y} />)}
              {ecSatPts.map((p) => <circle class="ec-dot" cx={EC_DOT_X} cy={p.y} r="7" />)}
              {ecSatPts.map((p) => <circle class="ec-handle" cx={EC_CARD_X} cy={p.y} r="4" />)}
            </svg>
          )}
          {!ecAbstract && ecSatPts.map((p) => (
            <span class="ec-sat" style={`top:${p.y}px;width:${EC_DOT_X - 16}px`}>{p.label}</span>
          ))}
          <article class:list={['ec-card', { 'ec-card--abstract': ecAbstract }]} style={`left:${EC_CARD_X}px;top:${ecCardY}px;width:${EC_CARD_W}px`}>
            <div class="ec-card__head" style={`height:${EC_HEAD_H}px`}>
              {ecAbstract
                ? <span class="ec-ph ec-ph--title"></span>
                : <span class="ec-card__title">{entityCard.name}</span>}
            </div>
            <div class="ec-card__body">
              {entityCard.fields.map((f, i) => (
                <div class="ec-card__row" style={`height:${EC_ROW_H}px`}>
                  {ecAbstract ? (
                    <>
                      <span class="ec-ph-chip"></span>
                      <span class="ec-fill" data-vals={JSON.stringify(ecFillData[i % ecFillData.length])}>{ecFillData[i % ecFillData.length][0]}</span>
                    </>
                  ) : (
                    <>
                      <span class="ec-card__field">{f.name}</span>
                      {f.key === 'pk' && <span class="ec-badge ec-badge--pk">PK</span>}
                      {f.key === 'fk' && <span class="ec-badge ec-badge--fk">FK</span>}
                    </>
                  )}
                </div>
              ))}
            </div>
          </article>
        </div>
      </div>
    )}
  </div>

  {source && (sourceUrl
    ? <a class="slide-source" href={sourceUrl} target="_blank" rel="noopener">Source : {source}</a>
    : <p class="slide-source">Source : {source}</p>)}
</section>

<style>
  .statement {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .statement__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .statement__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .statement__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .statement__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .statement__content {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    gap: 80px;
  }
  .statement__text {
    flex: 1 1 0;
    min-width: 0;
  }
  .statement__eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    margin: 0 0 24px;
  }
  .statement__eyebrow-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    display: inline-block;
    flex: 0 0 auto;
  }
  .statement__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-xl);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    white-space: pre-line;
    text-align: left;
  }
  .statement__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  /* Titre réduit (opt-in via titleSize="l") pour les Statement denses (bullets + carte). */
  .statement__title--l {
    font-size: var(--fs-hero-l);
  }
  /* Titre encore plus réduit (titleSize="m") : permet de tenir un titre long sur
     une seule ligne en pleine largeur (token --fs-hero-m). */
  .statement__title--m {
    font-size: var(--fs-hero-m);
  }
  .statement__body {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    color: var(--c-muted);
    margin: 28px 0 0;
  }
  /* Colonne gauche aérée pour le slide à grande carte abstraite (Les 4 entités) :
     plus d'air sous le titre (avant les bullets) et avant le body. Ciblé via
     data-dense, posé uniquement sur ce slide (carte abstraite). */
  .statement__content[data-dense='true'] .statement__bullets {
    margin-top: 48px;
  }
  .statement__content[data-dense='true'] .statement__body {
    margin-top: 44px;
  }

  /* Liste à puces avec icône Phosphor devant chaque item. */
  .statement__bullets {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .statement__bullet {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .statement__bullet-icon {
    flex: 0 0 auto;
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: color-mix(in srgb, var(--c-accent) 14%, transparent);
  }
  .statement__bullet-icon :global(svg) {
    width: 26px;
    height: 26px;
    color: var(--c-accent);
  }
  .statement__bullet-text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    color: var(--c-ink);
  }

  /* Chiffre-clé à droite, centré horizontalement dans sa colonne. */
  .statement__stat-block {
    flex: 0 0 auto;
    width: 38%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .statement__stat {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(120px, 13vw, 220px);
    line-height: 0.95;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--c-ink);
  }
  .statement__stat-caption {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin-top: 12px;
    max-width: 420px;
    text-align: center;
  }

  /* Colonne droite : champ de noeuds reliés (canvas), bleed sans cadre. */
  .statement__network {
    flex: 0 0 38%;
    align-self: stretch;
    position: relative;
    overflow: hidden;
  }
  .statement__network-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Mini-ERD (colonne droite) : boîtes nommées reliées, 100% tokenisé. */
  .statement__diagram {
    flex: 0 0 38%;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }
  .statement__diagram-svg {
    width: 100%;
    height: 100%;
    max-height: 560px;
  }
  .st-erd-box {
    fill: var(--c-surface);
    stroke: color-mix(in srgb, var(--c-ink) 22%, transparent);
    stroke-width: 1.4;
  }
  .st-erd-box--accent {
    stroke: var(--c-accent);
    stroke-width: 2.4;
  }
  .st-erd-text {
    fill: var(--c-ink);
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-anchor: middle;
    dominant-baseline: central;
  }
  .st-erd-link {
    stroke: color-mix(in srgb, var(--c-ink) 38%, transparent);
    stroke-width: 1.4;
    fill: none;
  }
  .st-erd-link--dashed {
    stroke: color-mix(in srgb, var(--c-accent) 70%, transparent);
    stroke-dasharray: 4 3;
  }
  .st-erd-arrow-head {
    fill: color-mix(in srgb, var(--c-ink) 38%, transparent);
  }

  /* ====== Carte Entité (entityCard) : TableNode mis en avant + dots reliés ======
     Mêmes codes visuels que Erd.astro (radius 12, barre d'accent en tête, badges
     PK/FK), 100% tokenisé. Scène fixe en px (alignée 1:1 avec le viewBox SVG). */
  .statement__entitycard {
    flex: 0 0 40%;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }
  .ec-stage {
    position: relative;
    flex: 0 0 auto;
  }
  .ec-edges {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .ec-link {
    stroke: color-mix(in srgb, var(--c-ink) 40%, transparent);
    stroke-width: 1.6;
    fill: none;
  }
  .ec-dot { fill: var(--c-accent); }
  .ec-handle { fill: color-mix(in srgb, var(--c-ink) 40%, transparent); }
  .ec-sat {
    position: absolute;
    left: 0;
    transform: translateY(-50%);
    text-align: right;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--c-ink);
    white-space: nowrap;
  }
  .ec-card {
    position: absolute;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--c-ink) 6%, transparent), 0 1px 3px color-mix(in srgb, var(--c-ink) 4%, transparent);
  }
  .ec-card__head {
    display: flex;
    align-items: center;
    padding: 0 18px;
    border-top: 4px solid var(--c-accent);
    background: linear-gradient(180deg, color-mix(in srgb, var(--c-ink) 3%, transparent) 0%, transparent 100%);
  }
  .ec-card__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.2px;
    color: var(--c-ink);
  }
  .ec-card__body {
    display: flex;
    flex-direction: column;
  }
  .ec-card__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 0 18px;
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 6%, transparent);
  }
  .ec-card__field {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--c-ink);
  }
  .ec-badge {
    flex: 0 0 auto;
    font-family: 'Space Grotesk', monospace;
    font-size: 13px;
    font-weight: 700;
    padding: 3px 7px;
    border-radius: 4px;
  }
  .ec-badge--pk { background: var(--c-accent); color: var(--c-on-accent); }
  .ec-badge--fk { background: color-mix(in srgb, var(--c-ink) 9%, transparent); color: var(--c-muted); }

  /* ---- Mode abstrait : carte placeholder + nuage de points autour ---- */
  .ec-card { z-index: 1; }
  .ec-cloud {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    z-index: 0;
