  .ec-cloud-dot--accent { fill: var(--c-accent); }
  /* Colonne d'illustration élargie en mode abstrait (carte agrandie). */
  .statement__entitycard[data-abstract='true'] { flex-basis: 50%; }
  .ec-card--abstract .ec-card__row { justify-content: flex-start; gap: 16px; }
  .ec-ph {
