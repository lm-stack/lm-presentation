---
// src/components/slides/ImageGrid.astro
// Slide grille de cards (image + titre + texte) adaptative selon le nombre :
// 2 → 2 colonnes / 3 → 3 colonnes / 4 → 2x2 / 5 → hero + 2x2.
import SlideTitle from '@/components/SlideTitle.astro';

interface ImageItem {
  src: string;
  alt?: string;
  title?: string;
  text?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  highlight?: string;
  images: ImageItem[];
}

const { title, subtitle, highlight, images } = Astro.props;
const count = Math.min(Math.max(images.length, 2), 5);
const variantClass = `image-grid__grid--${count}`;
const hasHeader = Boolean(title || subtitle);
---
<section
  class="image-grid"
  data-layout="image-grid"
>
  {hasHeader && <SlideTitle title={title ?? ''} subtitle={subtitle} highlight={highlight} />}
  <div class={`image-grid__grid ${variantClass}`}>
    {images.map((img, i) => (
      <article class="image-grid__item" style={`--i: ${i}`}>
        <div class="image-grid__media">
          <img src={img.src} alt={img.alt ?? ''} loading="lazy" decoding="async" />
        </div>
        {(img.title || img.text) && (
          <div class="image-grid__body">
            {img.title && <h3 class="image-grid__title">{img.title}</h3>}
            {img.text && <p class="image-grid__text">{img.text}</p>}
          </div>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .image-grid {
    justify-content: center !important;
  }

  .image-grid__grid {
    display: grid;
    gap: 24px;
    max-width: 1700px;
    margin: 0 auto;
    width: 100%;
    height: 720px;
  }

  .image-grid__grid--2 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr;
  }
  .image-grid__grid--3 {
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 1fr;
  }
  .image-grid__grid--4 {
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: 1fr 1fr;
  }
  .image-grid__grid--5 {
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .image-grid__grid--5 .image-grid__item:first-child {
    grid-row: 1 / 3;
  }

  /* Card : image en haut, body en dessous, fond blanc, ombre douce */
  .image-grid__item {
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 24px -8px rgba(25, 25, 25, 0.14);
    border: 1px solid rgba(25, 25, 25, 0.06);
    min-height: 0;
    animation: image-grid-reveal 0.55s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i, 0) * 0.08s) both;
  }

  /* Image prend l'espace restant apres le body : si on agrandit la typo, le */
  /* body grandit, l'image retrecit en consequence. min-height empeche que */
  /* l'image disparaisse completement sur les layouts denses. */
  .image-grid__media {
    flex: 1 1 auto;
    min-height: 120px;
    overflow: hidden;
    background: #191919;
  }
  .image-grid__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-grid__body {
    flex: 0 0 auto;
    padding: 22px 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  /* Tailles uniformes partout : meme titre et texte sur les 4 variantes */
  .image-grid__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 30px;
    font-weight: 700;
    color: #191919;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .image-grid__text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 400;
    color: #6B6F84;
    margin: 0;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Sur les layouts les plus serres (4 cards 2x2 et smalls du 5) on clamp a 2 lignes */
  /* pour preserver une zone image visible. */
  .image-grid__grid--4 .image-grid__text,
  .image-grid__grid--5 .image-grid__item:not(:first-child) .image-grid__text {
    -webkit-line-clamp: 2;
  }

  @keyframes image-grid-reveal {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
