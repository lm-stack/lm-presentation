---
// src/components/slides/AboutHero.astro
// Présentation d'un intervenant "ExecEd-style" : photo grande à gauche,
// nom serif avec last name italique souligné jaune à droite, sections
// bio numérotées (Bungee Outline, comme TableDesMatieres de lm-offres).
// Fond pearl-stone, lien optionnel par section qui sera rendu en
// underline classique via la règle globale de slides.css.
//
// Inspiration : slide "Thomas Rouaud" du PPTX HEC ExecEd. Différent
// du composant AboutMe LM existant qui utilise un fond crème uni
// avec watermark monumental.
import '@fontsource/bungee-outline/latin.css';
interface BioSection {
  title: string;
  body: string;
  /** Si fourni, le titre devient un lien cliquable avec underline classique
     (règle globale dans slides.css). Cible _blank automatique. */
  link?: string;
}
interface Props {
  firstName: string;
  /** Affiché en italique serif. */
  lastName: string;
  /** Photo portrait (idéalement carrée ou format paysage léger). */
  photo: string;
  sections: BioSection[];
  brand?: string;
  brandSub?: string;
  /** Texte top-right (partenaire, événement, contexte). */
  partner?: string;
}
const {
  firstName,
  lastName,
  photo,
  sections,
  brand = 'Titre de la présentation',
  brandSub,
  partner,
} = Astro.props;
---
<section class="about-hero" data-layout="about-hero">
  <header class="about-hero__header">
    <div class="about-hero__brand-text">
      <p class="about-hero__brand-main">{brand}</p>
      {brandSub && <p class="about-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="about-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="about-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="about-hero__body">
    <div class="about-hero__photo">
      <img src={photo} alt={`${firstName} ${lastName}`} loading="eager" decoding="async" />
    </div>

    <div class="about-hero__content">
      <h2 class="about-hero__name">
        <span class="about-hero__first">{firstName}</span>{' '}
        <em class="about-hero__last"><span class="underline">{lastName}</span></em>
      </h2>

      <div class="about-hero__sections">
        {sections.map((s, i) => (
          <div class="about-hero__section">
            <span class="about-hero__section-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="about-hero__section-text">
              <h3 class="about-hero__section-title">
                {s.link
                  ? <a href={s.link} target="_blank" rel="noopener">{s.title}</a>
                  : s.title}
              </h3>
              <p class="about-hero__section-body">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 64px 96px !important;
    background: linear-gradient(180deg, #FFFFFF 0%, #EFEFF2 100%);
    color: #191919;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .about-hero__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(25, 25, 25, 0.12);
  }
  .about-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }
  .about-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: #191919;
    text-align: left;
  }
  .about-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: #6B6F84;
    text-align: left;
  }
  .about-hero__partner {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    margin: 0;
    color: #6B6F84;
  }

  .about-hero__body {
    flex: 1 1 auto !important;
    display: flex;
    align-items: center;
    gap: 120px;
    min-height: 0;
    padding-top: 24px;
  }

  .about-hero__photo {
    flex: 0 0 auto;
    width: 540px;
    aspect-ratio: 4 / 5;
    background: #FFFFFF;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 6px 16px -6px rgba(25, 25, 25, 0.10);
  }
  .about-hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-hero__content {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .about-hero__name {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(72px, 7vw, 116px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: #191919;
    text-align: left;
  }
  .about-hero__first {
    font-weight: 600;
  }
  .about-hero__last {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .about-hero__sections {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  .about-hero__section {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  /* Numéro Bungee Outline, comme TableDesMatieres du repo lm-offres.
     Taille calibrée pour couvrir visuellement la hauteur du bloc
     titre + body (~110-130px). */
  .about-hero__section-num {
    font-family: 'Bungee Outline', sans-serif;
    font-weight: 400;
    font-size: 80px;
    line-height: 1;
    color: #191919;
    letter-spacing: 0;
    flex: 0 0 auto;
    min-width: 110px;
  }
  .about-hero__section-text {
    flex: 1 1 auto;
    min-width: 0;
  }
  .about-hero__section-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 6px;
    color: #191919;
    text-align: left;
  }
  .about-hero__section-body {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    line-height: 1.45;
    margin: 0;
    color: #6B6F84;
  }
</style>
