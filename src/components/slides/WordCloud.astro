---
// src/components/slides/WordCloud.astro
// Variante ExecEd-style du composant WordCloud : header full-width brand + logo
// LM, titre question en serif italique partiel optionnel, fond pearl-stone,
// charte border-radius 4px et drop-shadows légères. Conserve à l'identique
// tous les hooks JS data-poll-* utilisés par src/scripts/deck/polls.ts (états
// initial / live / frozen / archived). Mots injectés en JS dans data-poll-chart
// via renderPollWordCloud (cf. src/scripts/deck/wordcloud-packing.ts).
import { splitHighlight } from '@/utils/highlight';
interface Props {
  id: string;
  question: string;
  /** Sous-titre optionnel (consigne de vote, ex "Plusieurs réponses bienvenues"). */
  subtitle?: string;
  /** Mot ou segment de la question rendu en italique serif. Optionnel. */
  italicPart?: string;
  brand?: string;
  brandSub?: string;
}

const {
  id,
  question,
  subtitle,
  italicPart,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(question, italicPart);
---
<section
  class="wordcloud"
  data-layout="wordcloud"
  data-section-title={question.slice(0, 60)}
  data-poll-id={id}
  data-poll-type="word"
  data-poll-question={question}
>
  <header class="wordcloud__header">
    <div class="wordcloud__brand">
      <p class="wordcloud__brand-main">{brand}</p>
      {brandSub && <p class="wordcloud__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="wordcloud__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="wordcloud__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="wordcloud__body">
    <div class="wordcloud__heading">
      <h2 class="wordcloud__title">
        {titleParts
          ? <>{titleParts.before}<em class="wordcloud__title-italic">{titleParts.match}</em>{titleParts.after}</>
          : question}
      </h2>
      {subtitle && <p class="wordcloud__subtitle">{subtitle}</p>}
    </div>

    <div class="wordcloud__grid">
      <div class="wordcloud__chart" data-poll-chart>
        {/* Mots injectés en JS par renderPollWordCloud */}
      </div>

      <div class="wordcloud__side" data-poll-side>
        <div class="wordcloud__initial" data-poll-state="initial" hidden>
          <button type="button" class="wordcloud__start-btn presenter-only" data-poll-start>
            Démarrer le sondage
          </button>
          <div class="poll-waiting viewer-only">En attente de l'animateur</div>
        </div>

        <div class="wordcloud__live" data-poll-state="live" hidden>
          <div class="wordcloud__qr" data-poll-qr></div>
          <div class="wordcloud__code" data-poll-code>------</div>
          <div class="wordcloud__url" data-poll-url>slides.lausanne.marketing/v/------</div>
          <div class="wordcloud__counter" data-poll-counter>0 mots</div>
          <div class="wordcloud__actions presenter-only">
            <button type="button" class="wordcloud__action-btn" data-poll-freeze title="Figer">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
                <path d="M208 80h-32V56a48 48 0 0 0-96 0v24H48a16 16 0 0 0-16 16v112a16 16 0 0 0 16 16h160a16 16 0 0 0 16-16V96a16 16 0 0 0-16-16M96 56a32 32 0 0 1 64 0v24H96Z"/>
              </svg>
            </button>
            <button type="button" class="wordcloud__action-btn" data-poll-reset title="Reset">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
                <path d="M197.67 186.37a8 8 0 0 1 0 11.29C196.58 198.73 170.82 224 128 224c-37.39 0-64.53-22.4-80-39.85V208a8 8 0 0 1-16 0v-48a8 8 0 0 1 8-8h48a8 8 0 0 1 0 16H55.44C67.76 183.35 93 208 128 208c36 0 58.14-21.46 58.36-21.68a8 8 0 0 1 11.31.05M216 40a8 8 0 0 0-8 8v23.85C192.53 54.4 165.39 32 128 32c-42.82 0-68.58 25.27-69.66 26.34a8 8 0 0 0 11.3 11.34C69.86 69.46 92 48 128 48c35 0 60.24 24.65 72.56 40H168a8 8 0 0 0 0 16h48a8 8 0 0 0 8-8V48a8 8 0 0 0-8-8"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="wordcloud__frozen" data-poll-state="frozen" hidden>
          <div class="wordcloud__frozen-badge">Vote terminé</div>
          <div class="wordcloud__counter" data-poll-frozen-counter>0 mots</div>
          <div class="wordcloud__actions presenter-only">
            <button type="button" class="wordcloud__action-btn" data-poll-reset title="Nouvelle session">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
                <path d="M197.67 186.37a8 8 0 0 1 0 11.29C196.58 198.73 170.82 224 128 224c-37.39 0-64.53-22.4-80-39.85V208a8 8 0 0 1-16 0v-48a8 8 0 0 1 8-8h48a8 8 0 0 1 0 16H55.44C67.76 183.35 93 208 128 208c36 0 58.14-21.46 58.36-21.68a8 8 0 0 1 11.31.05M216 40a8 8 0 0 0-8 8v23.85C192.53 54.4 165.39 32 128 32c-42.82 0-68.58 25.27-69.66 26.34a8 8 0 0 0 11.3 11.34C69.86 69.46 92 48 128 48c35 0 60.24 24.65 72.56 40H168a8 8 0 0 0 0 16h48a8 8 0 0 0 8-8V48a8 8 0 0 0-8-8"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="wordcloud__archived" data-poll-state="archived" hidden>
          <div class="wordcloud__frozen-badge">Session archivée</div>
          <div class="wordcloud__counter" data-poll-archived-counter>0 mots</div>
          <button type="button" class="wordcloud__start-btn presenter-only" data-poll-start>
            Nouvelle session
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .wordcloud {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .wordcloud__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .wordcloud__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .wordcloud__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .wordcloud__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .wordcloud__body {
    flex: 1 1 auto !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    padding-top: 32px;
    gap: 56px;
  }

  .wordcloud__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .wordcloud__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .wordcloud__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 16px 0 0;
  }

  .wordcloud__grid {
    display: grid;
    grid-template-columns: 60% 40%;
    gap: 64px;
    align-items: center;
  }

  .wordcloud__chart {
    position: relative;
    width: 100%;
    min-height: 560px;
    overflow: hidden;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  /* Note : le padding visuel du wordcloud est géré en JS (renderPollWordCloud)
     car les spans en position:absolute ignorent le CSS padding du container. */

  /* :global() requis car les spans sont créés en JS (document.createElement)
     et n'héritent pas du data-astro-cid de scoping. La className injectée par
     renderPollWordCloud (src/scripts/deck/polls.ts) est `wordcloud-slide__word`
     (hardcodée) : on stylé donc cette classe ici aussi pour que WordCloud
     fonctionne quand WordCloud n'est pas importé dans le même deck. */
  :global(.wordcloud-slide__word) {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
    animation: wordcloud-pop-h 400ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  :global(.wordcloud-slide__word--v) {
    animation: wordcloud-pop-v 400ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
    transform-origin: left top;
  }

  @keyframes wordcloud-pop-h {
    from { transform: scale(0); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  @keyframes wordcloud-pop-v {
    from { transform: rotate(-90deg) scale(0); opacity: 0; }
    to { transform: rotate(-90deg) scale(1); opacity: 1; }
  }

  .wordcloud__side {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .wordcloud__initial,
  .wordcloud__live,
  .wordcloud__frozen,
  .wordcloud__archived {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .wordcloud__start-btn {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 700;
    font-size: 24px;
    color: var(--c-on-accent);
    background: var(--c-accent);
    border: none;
    border-radius: 4px;
    padding: 14px 28px;
    cursor: pointer;
    transition: background-color 0.2s ease;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
  }

  .wordcloud__qr {
    width: 380px;
    height: 380px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
  }
  .wordcloud__qr svg { width: 100%; height: 100%; }

  .wordcloud__code {
    font-family: 'Space Grotesk', monospace;
    font-weight: 700;
    font-size: 64px;
    letter-spacing: 0.15em;
    color: var(--c-ink);
    font-variant-numeric: tabular-nums;
  }

  .wordcloud__url {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 500;
    font-size: 18px;
    color: var(--c-muted);
  }

  .wordcloud__counter {
    font-family: 'Space Grotesk', monospace;
    font-weight: 700;
    font-size: 16px;
    color: var(--c-muted);
    margin-top: 4px;
  }

  .wordcloud__actions {
    display: flex;
    gap: 8px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 6px;
    margin-top: 12px;
  }

  .wordcloud__action-btn {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--c-ink);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  @media (hover: hover) {
    .wordcloud__action-btn:hover { background: var(--c-accent); color: var(--c-on-accent); }
  }

  .wordcloud__frozen-badge {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 700;
    font-size: 28px;
    color: var(--c-on-accent);
    background: var(--c-accent);
    padding: 18px 36px;
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    text-align: center;
  }
</style>
