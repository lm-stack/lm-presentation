---
// src/components/slides/Section.astro
// Slide de transition de section. Inspire du Cover, plus light : fond blanc
// dominant, accent gold via watermark numerique et pill eyebrow, mot signature
// toujours en bande noire rotative.
interface Props {
  number?: string; // affichage : "01", "Jour 1", "I", etc.
  title: string;
  subtitle?: string;
  highlight?: string;
  eyebrow?: string;
}

const { number, title, subtitle, highlight, eyebrow } = Astro.props;

function splitHighlight(text: string, mot?: string) {
  if (!mot) return null;
  const idx = text.toLowerCase().indexOf(mot.toLowerCase());
  if (idx === -1) return null;
  return {
    before: text.slice(0, idx),
    match: text.slice(idx, idx + mot.length),
    after: text.slice(idx + mot.length),
  };
}

const titleParts = splitHighlight(title, highlight);
---
<section class="slide-section" data-layout="section" data-section-title={title}>
  <span class="slide-section__wash" aria-hidden="true"></span>
  {number && <span class="slide-section__watermark" aria-hidden="true">{number}</span>}

  <div class="slide-section__inner">
    {eyebrow && <p class="slide-section__eyebrow">{eyebrow}</p>}
    <h2 class="slide-section__title">
      {titleParts
        ? <>{titleParts.before}<span class="slide-section__mark">{titleParts.match}</span>{titleParts.after}</>
        : title}
    </h2>
    {subtitle && <p class="slide-section__subtitle">{subtitle}</p>}
  </div>

  <span class="slide-section__rule" aria-hidden="true"></span>
</section>

<style>
  .slide-section {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 96px 96px !important;
    background: #FFFFFF;
    color: #191919;
    display: flex !important;
    flex-direction: column;
    justify-content: center !important;
  }

  /* Wash gold radial bottom-left, ancre visuelle subtile */
  .slide-section__wash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 0% 100%, rgba(255, 216, 56, 0.32) 0%, rgba(255, 216, 56, 0) 55%);
    z-index: 0;
  }

  /* Watermark numerique gold a droite, fadant vers le bord */
  .slide-section__watermark {
    position: absolute;
    top: 50%;
    right: -64px;
    transform: translateY(-50%);
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 900;
    font-size: clamp(420px, 60vw, 880px);
    line-height: 0.78;
    letter-spacing: -0.06em;
    color: #FFD838;
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
    z-index: 0;
    -webkit-mask-image: linear-gradient(to right, #000 30%, rgba(0, 0, 0, 0.25) 100%);
    mask-image: linear-gradient(to right, #000 30%, rgba(0, 0, 0, 0.25) 100%);
    animation: section-watermark 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .slide-section__inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    animation: section-stagger 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .slide-section__eyebrow {
    display: inline-block;
    font-family: 'Space Grotesk', monospace;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: #191919;
    margin: 0 0 32px;
    padding: 8px 16px;
    background: #FFD838;
    border: 2px solid #191919;
    border-radius: 4px;
  }

  .slide-section__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 900;
    font-size: clamp(80px, 9vw, 160px);
    line-height: 0.92;
    letter-spacing: -0.035em;
    color: #191919;
    margin: 0 0 28px;
    text-align: left;
    text-wrap: balance;
  }

  /* Marqueur signature : bande noire rotative (calque sur Cover) */
  .slide-section__mark {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .slide-section__mark::after {
    content: '';
    position: absolute;
    left: -6px;
    right: -6px;
    bottom: 4px;
    height: 11px;
    background: #191919;
    z-index: -1;
    transform: rotate(-1.5deg);
  }

  .slide-section__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 28px;
    font-weight: 500;
    line-height: 1.4;
    color: #6B6F84;
    margin: 0;
    max-width: 1100px;
  }

  /* Trait gold inline-bottom, ancre la composition */
  .slide-section__rule {
    position: absolute;
    left: 96px;
    bottom: 80px;
    width: 96px;
    height: 6px;
    background: #FFD838;
    z-index: 1;
  }

  @keyframes section-stagger {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes section-watermark {
    from {
      opacity: 0;
      transform: translateY(-50%) translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
  }
</style>
