---
// src/components/slides/Demo.astro
// Slide d'annonce d'une démo live ExecEd-style, structure asymétrique calquée
// sur Workshop. Fond DISTINCTIF (dégradé + halo accent, façon Cover) et un
// schéma ERD esquissé en filigrane (entités + relations) pour l'ambiance
// "atelier où l'on construit le schéma en direct".
// À gauche (60%) : badge "Démo en direct", titre FIGÉ "Démonstration" (italique
// serif + soulignement accent, inviolable comme Workshop), objectifs en gros
// numéros accent. À droite (40%) : logo de l'outil démontré + son nom.
// ERD décoratif générique (cards abstraites sans texte) : marche pour n'importe
// quelle démo et dans les deux schémas (tokens uniquement).
interface Props {
  /** Logo de l'outil de la démo (chemin SVG/PNG dans /public). */
  toolLogo: string;
  /** Nom de l'outil affiché sous le logo, ex. "Zoho CRM". */
  toolName?: string;
  /** Objectifs concrets de la démo (3 à 5 items, ce qu'on fait en direct). */
  objectives: string[];
  /** Libellé du badge live, défaut "Démo en direct". */
  liveLabel?: string;
  brand?: string;
  brandSub?: string;
}
const {
  toolLogo,
  toolName,
  objectives,
  liveLabel = 'Démo en direct',
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="demo" data-layout="demo">
  <div class="demo__bg" aria-hidden="true">
    <svg class="demo__erd" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice">
      <path class="erd-rel" d="M 450 794 C 820 794 1010 815 1380 815" />
      <path class="erd-rel" d="M 1480 438 C 1480 585 1530 585 1530 720" />
      <circle class="erd-key" cx="450" cy="794" r="7" />
      <circle class="erd-key" cx="1380" cy="815" r="7" />
      <circle class="erd-key" cx="1480" cy="438" r="7" />
      <circle class="erd-key" cx="1530" cy="720" r="7" />
      <g transform="translate(150 700)">
        <rect class="erd-card" width="300" height="188" rx="14" />
        <line class="erd-head" x1="0" y1="50" x2="300" y2="50" />
        <line class="erd-field" x1="30" y1="92" x2="214" y2="92" />
        <line class="erd-field" x1="30" y1="126" x2="246" y2="126" />
        <line class="erd-field" x1="30" y1="160" x2="184" y2="160" />
      </g>
      <g transform="translate(1330 250)">
        <rect class="erd-card" width="300" height="188" rx="14" />
        <line class="erd-head" x1="0" y1="50" x2="300" y2="50" />
        <line class="erd-field" x1="30" y1="92" x2="232" y2="92" />
        <line class="erd-field" x1="30" y1="126" x2="198" y2="126" />
        <line class="erd-field" x1="30" y1="160" x2="244" y2="160" />
      </g>
      <g transform="translate(1380 720)">
        <rect class="erd-card" width="300" height="188" rx="14" />
        <line class="erd-head" x1="0" y1="50" x2="300" y2="50" />
        <line class="erd-field" x1="30" y1="92" x2="206" y2="92" />
        <line class="erd-field" x1="30" y1="126" x2="244" y2="126" />
        <line class="erd-field" x1="30" y1="160" x2="172" y2="160" />
      </g>
    </svg>
  </div>

  <header class="demo__header">
    <div class="demo__brand-text">
      <p class="demo__brand-main">{brand}</p>
      {brandSub && <p class="demo__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="demo__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="demo__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="demo__content">
    <div class="demo__tool-zone">
      <div class="demo__tool-inner">
        <img class="demo__tool-logo" src={toolLogo} alt={toolName ?? ''} />
        {toolName && <p class="demo__tool-name">{toolName}</p>}
      </div>
    </div>

    <div class="demo__main">
      <p class="demo__live">
        <span class="demo__live-dot" aria-hidden="true"></span>
        {liveLabel}
      </p>
      <h2 class="demo__title">
        <em class="demo__title-italic"><span class="underline">Démonstration</span></em>
      </h2>

      <ol class="demo__objectives">
        {objectives.map((objective, i) => (
          <li class="demo__objective">
            <span class="demo__objective-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="demo__objective-text">{objective}</span>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .demo {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    /* Fond distinctif (façon Cover halo-gold) : halo accent doux autour de
       l'outil + dégradé diagonal crème -> bg-end. Tokens => marche LM et ExecEd. */
    background:
      radial-gradient(78% 68% at 82% 40%, color-mix(in srgb, var(--c-accent-soft) 46%, transparent) 0%, transparent 60%),
      linear-gradient(158deg, var(--c-cream) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Schéma ERD esquissé en filigrane (cards abstraites + relations accent),
     atténué vers les bords par un masque radial. Décoratif, derrière le contenu. */
  .demo__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .demo__erd {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    -webkit-mask-image: radial-gradient(ellipse 96% 92% at 50% 46%, #000 48%, transparent 90%);
    mask-image: radial-gradient(ellipse 96% 92% at 50% 46%, #000 48%, transparent 90%);
  }
  .erd-card {
    fill: none;
    stroke: color-mix(in srgb, var(--c-ink) 20%, transparent);
    stroke-width: 2;
  }
  .erd-head {
    stroke: color-mix(in srgb, var(--c-ink) 20%, transparent);
    stroke-width: 2;
  }
  .erd-field {
    stroke: color-mix(in srgb, var(--c-ink) 13%, transparent);
    stroke-width: 6;
    stroke-linecap: round;
  }
  .erd-rel {
    fill: none;
    stroke: color-mix(in srgb, var(--c-accent) 34%, transparent);
    stroke-width: 2.5;
  }
  .erd-key {
    fill: color-mix(in srgb, var(--c-accent) 44%, transparent);
  }

  /* Header full-width standard : brand gauche + logo LM droite + border-bottom. */
  .demo__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .demo__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
  }
  .demo__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
  }
  .demo__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .demo__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
  }

  /* Zone outil (droite, 40%) : logo en grand + nom, posé sur le halo du fond. */
  .demo__tool-zone {
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 56px 96px 56px 32px;
  }
  .demo__tool-inner {
    position: relative;
    width: 100%;
    max-width: 460px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }
  .demo__tool-logo {
    width: 100%;
    height: auto;
    display: block;
  }
  .demo__tool-name {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--c-ink);
    margin: 0;
    text-align: center;
  }

  /* Colonne principale (gauche, 60%) : badge live + titre + objectifs. */
  .demo__main {
    position: relative;
    z-index: 1;
    width: 60%;
    height: 100%;
    padding: 28px 64px 56px 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }

  .demo__live {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    align-self: flex-start;
    margin: 0 0 24px;
    padding: 8px 18px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-accent) 10%, transparent);
    color: var(--c-accent);
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .demo__live-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--c-accent) 60%, transparent);
    animation: demo-pulse 1.8s ease-out infinite;
  }
  @keyframes demo-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--c-accent) 55%, transparent); }
    70% { box-shadow: 0 0 0 12px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .demo__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .demo__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .demo__objectives {
    list-style: none;
    margin: 56px 0 0;
    padding: 0;
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .demo__objective {
    display: flex;
    align-items: center;
    gap: 36px;
    padding: 22px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .demo__objective-num {
    flex: 0 0 auto;
    min-width: 86px;
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
    font-size: var(--fs-hero-m);
    line-height: 0.9;
    color: var(--c-accent);
  }
  .demo__objective-text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-ink);
  }
</style>
