---
// src/components/slides/TitleSplitImage.astro
// Layout titre + 2 colonnes + image droite : fond noir LM, titre serif
// italique partiel, sous-titre avec carré jaune, 2 colonnes "label /
// body" courtes, image illustrative à droite.
// Inspiration slide 25 du PPTX ExecEd.
interface Column {
  label: string;
  text: string;
}
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  columns: Column[];
  image?: string;
  brand?: string;
  brandSub?: string;
}
import { splitHighlight } from '@/utils/highlight';
const {
  title,
  italicPart,
  subtitle,
  columns,
  image,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="title-split-image" data-layout="title-split-image">
  <header class="title-split-image__header">
    <div class="title-split-image__brand">
      <p class="title-split-image__brand-main">{brand}</p>
      {brandSub && <p class="title-split-image__brand-sub">{brandSub}</p>}
    </div>
  </header>

  <div class="title-split-image__body">
    <div class="title-split-image__text">
      <h2 class="title-split-image__title">
        {titleParts
          ? <>{titleParts.before}<em class="title-split-image__title-italic">{titleParts.match}</em>{titleParts.after}</>
          : title}
      </h2>

      {subtitle && (
        <p class="title-split-image__subtitle">
          <span class="title-split-image__subtitle-square" aria-hidden="true"></span>
          {subtitle}
        </p>
      )}

      <div class="title-split-image__columns">
        {columns.map((col) => (
          <div class="title-split-image__column">
            <p class="title-split-image__column-label">{col.label}</p>
            <p class="title-split-image__column-text">{col.text}</p>
          </div>
        ))}
      </div>
    </div>

    {image && (
      <div class="title-split-image__image" aria-hidden="true">
        <img src={image} alt="" loading="lazy" decoding="async" />
      </div>
    )}
  </div>
</section>

<style>
  .title-split-image {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .title-split-image__header {
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .title-split-image__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
  }
  .title-split-image__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
  }

  .title-split-image__body {
    flex: 1 1 auto !important;
    display: flex;
    align-items: center;
    gap: 64px;
    min-height: 0;
    padding-top: 32px;
  }
  .title-split-image__text {
    flex: 1 1 auto;
    min-width: 0;
  }

  .title-split-image__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(56px, 5.4vw, 84px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .title-split-image__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .title-split-image__subtitle {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--c-muted);
    margin: 20px 0 36px;
  }
  .title-split-image__subtitle-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    display: inline-block;
    flex: 0 0 auto;
  }

  .title-split-image__columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 36px;
  }
  .title-split-image__column-label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--c-ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .title-split-image__column-text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    line-height: 1.55;
    color: var(--c-muted);
    margin: 0;
  }

  .title-split-image__image {
    flex: 0 0 auto;
    width: 400px;
    aspect-ratio: 4 / 5;
    background: var(--c-surface);
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--c-ink) 10%, transparent);
  }
  .title-split-image__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
