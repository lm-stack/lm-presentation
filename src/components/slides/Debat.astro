---
// src/components/slides/Debat.astro
// Slide "Débat" ExecEd-style : header standard (brand + logo LM + border), fond
// pearl. En haut : pastille "Débat" + la question (Hanken, portion serif italique
// soulignée or) + une intro de contexte. En dessous : les prompts rendus en BULLES
// de discussion (cards radius 4px + petite queue + avatar rond), en quinconce
// gauche/droite, voix alternées (or / encre).
//
// Mode `live` ("le débat en direct") : badge pulsant, les bulles débarquent des
// deux côtés opposés puis flottent, l'avatar émet un halo de voix, et un FLUX
// continu de réactions monte en fond (la salle qui s'enflamme). `intensity`
// dose la densité du flux. Tout est coupé en prefers-reduced-motion et à
// l'impression (PDF handout) : les réactions sont purement décoratives.
//
// Hors `live`, c'est le "fil de discussion" calme (apparition en cascade).
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';

interface Props {
  /** La question du débat. */
  title: string;
  /** Portion du titre en serif italique soulignée or. */
  italicPart?: string;
  /** Texte de mise en contexte sous la question. */
  intro?: string;
  /** Les points de débat, rendus en bulles de discussion (idéal 2 à 4). */
  prompts?: string[];
  /** Libellé de la pastille en haut. Défaut "Débat". */
  eyebrow?: string;
  /** Mode "en direct" : badge pulsant, bulles animées + halo, flux de réactions. */
  live?: boolean;
  /** Mots du flux de réactions (live). Défaut : jeu générique de débat. */
  reactions?: string[];
  /** Densité/vitesse du flux live. */
  intensity?: 'normal' | 'intense';
  brand?: string;
  brandSub?: string;
  /** Libellé ToC (sinon le titre). */
  tocLabel?: string;
}
const {
  title,
  italicPart,
  intro,
  prompts = [],
  eyebrow = 'Débat',
  live = false,
  reactions,
  intensity = 'normal',
  brand = 'Titre de la présentation',
  brandSub,
  tocLabel,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);

// Avatars/bulles d'ambiance : positions fixes vers les bords (sous le contenu,
// faible opacité). Décoratif. En mode live, ils dérivent lentement.
const ambient = [
  { top: '10%', left: '46%', s: 54 },
  { top: '15%', left: '91%', s: 70, accent: true },
  { top: '41%', left: '96%', s: 46, bubble: true },
  { top: '67%', left: '4%', s: 64 },
  { top: '87%', left: '31%', s: 50, accent: true },
  { top: '63%', left: '92%', s: 76 },
  { top: '90%', left: '63%', s: 52, bubble: true },
  { top: '31%', left: '3%', s: 44, bubble: true },
];

// Flux de réactions (live) : mots courts qui montent et s'effacent en boucle.
// Pistes biaisées vers les gouttières gauche/droite pour laisser le centre lisible.
const DEFAULT_REACTIONS = [
  // Murmure multilingue : phrases de débat entrelacées (FR, EN, DE, ES, IT, PT, NL)
  // pour qu'un échantillon de chaque langue apparaisse même à densité normale.
  "Je ne suis pas d'accord du tout",
  "I see your point, but...",
  "Das ist wirklich kompliziert",
  "Todo depende del contexto",
  "Non è così semplice, dai",
  "Depende muito do caso",
  "Daar ben ik het mee eens",
  "Ça dépend vraiment du contexte",
  "That's a real ethical dilemma",
  "Da bin ich anderer Meinung",
  "No lo veo tan claro",
  "Sono completamente d'accordo",
  "Concordo plenamente com isto",
  "Ik ben het er niet mee eens",
  "C'est bien plus nuancé que ça",
  "It's honestly not that simple",
  "Genau das denke ich auch",
  "Estoy totalmente de acuerdo",
  "Dipende molto dai casi",
  "Não é tão simples assim",
  "Precies wat ik denk",
  "On ne peut pas tout automatiser",
  "But who actually decides?",
  "Da ist was dran",
];
const reactionWords = reactions && reactions.length ? reactions : DEFAULT_REACTIONS;
const STREAM = [
  { l: '12%', delay: '0s', dur: '12s' },
  { l: '84%', delay: '1.4s', dur: '13.5s' },
  { l: '30%', delay: '3.1s', dur: '11s' },
  { l: '66%', delay: '2.2s', dur: '14s' },
  { l: '8%', delay: '5.3s', dur: '15s' },
  { l: '92%', delay: '4.1s', dur: '10.5s' },
  { l: '48%', delay: '6.4s', dur: '13s' },
  { l: '20%', delay: '7.7s', dur: '12.5s' },
  { l: '76%', delay: '0.7s', dur: '15.5s' },
  { l: '38%', delay: '2.9s', dur: '11.5s' },
  { l: '88%', delay: '8.2s', dur: '12s' },
  { l: '4%', delay: '3.6s', dur: '14.5s' },
  { l: '58%', delay: '5.9s', dur: '10s' },
  { l: '26%', delay: '9.1s', dur: '13s' },
  { l: '70%', delay: '4.7s', dur: '16s' },
  { l: '15%', delay: '6.8s', dur: '11s' },
  { l: '82%', delay: '2.5s', dur: '13.8s' },
  { l: '44%', delay: '8.6s', dur: '12.2s' },
  { l: '94%', delay: '1.1s', dur: '15.2s' },
  { l: '34%', delay: '7.2s', dur: '10.8s' },
  { l: '62%', delay: '3.3s', dur: '14.2s' },
  { l: '10%', delay: '9.4s', dur: '12.8s' },
  { l: '78%', delay: '5.1s', dur: '11.8s' },
  { l: '52%', delay: '6.1s', dur: '13.3s' },
];
const streamCount = live ? (intensity === 'intense' ? 24 : 16) : 0;
const stream = STREAM.slice(0, streamCount).map((s, i) => ({
  ...s,
  text: reactionWords[i % reactionWords.length],
}));
---
<section class:list={['debat', { 'debat--live': live }]} data-layout="debat" data-section-title={tocLabel ?? title}>
  <div class="debat__ambient" aria-hidden="true">
    {ambient.map((a) => (
      a.bubble
        ? <span class="debat__ghost-bubble" style={`top:${a.top};left:${a.left};width:${Math.round(a.s * 1.7)}px;height:${Math.round(a.s * 0.74)}px`}></span>
        : <span class:list={['debat__ghost-avatar', { 'debat__ghost-avatar--accent': a.accent }]} style={`top:${a.top};left:${a.left};width:${a.s}px;height:${a.s}px`}><Icon name="ph:user-fill" /></span>
    ))}
  </div>

  {stream.length > 0 && (
    <div class="debat__stream" aria-hidden="true">
      {stream.map((s) => (
        <span class="debat__reaction" style={`left:${s.l};animation-delay:${s.delay};animation-duration:${s.dur}`}>{s.text}</span>
      ))}
    </div>
  )}

  <header class="debat__header">
    <div class="debat__brand-text">
      <p class="debat__brand-main">{brand}</p>
      {brandSub && <p class="debat__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="debat__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="debat__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="debat__content">
    <p class="debat__eyebrow">
      {live
        ? <span class="debat__live-dot" aria-hidden="true"></span>
        : <span class="debat__eyebrow-square" aria-hidden="true"></span>}
      {eyebrow}
    </p>
    <h2 class="debat__title">
      {titleParts
        ? <>{titleParts.before}<em class="debat__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
        : title}
    </h2>
    {intro && <p class="debat__intro">{intro}</p>}

    {prompts.length > 0 && (
      <ul class="debat__thread">
        {prompts.map((p, i) => (
          <li class:list={['debat__row', { 'debat__row--right': i % 2 === 1 }]} style={`--i:${i}`}>
            <span class="debat__avatar" aria-hidden="true">
              <Icon name="ph:user-fill" />
            </span>
            <div class="debat__bubble"><span>{p}</span></div>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .debat {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Nuée d'ambiance : voix estompées vers les bords, derrière le contenu. */
  .debat__ambient {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.16;
    pointer-events: none;
  }
  .debat__ghost-avatar,
  .debat__ghost-bubble {
    position: absolute;
    transform: translate(-50%, -50%);
  }
  .debat__ghost-avatar {
    border-radius: 50%;
    background: color-mix(in srgb, var(--c-ink) 16%, transparent);
    color: color-mix(in srgb, var(--c-ink) 55%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .debat__ghost-avatar--accent {
    background: color-mix(in srgb, var(--c-accent) 42%, transparent);
    color: color-mix(in srgb, var(--c-ink) 60%, transparent);
  }
  .debat__ghost-avatar :global(svg) {
    width: 58%;
    height: 58%;
  }
  .debat__ghost-bubble {
    border-radius: 4px;
    border: 2px solid color-mix(in srgb, var(--c-ink) 24%, transparent);
  }

  /* Flux de réactions (live) : mini-bulles qui montent et s'effacent en boucle. */
  .debat__stream {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .debat__reaction {
    position: absolute;
    bottom: 4%;
    transform: translate(-50%, 20px) scale(0.94);
    background: color-mix(in srgb, var(--c-surface) 60%, transparent);
    border: 1px solid color-mix(in srgb, var(--c-ink) 5%, transparent);
    border-radius: 4px;
    padding: 6px 14px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.1;
    color: color-mix(in srgb, var(--c-ink) 44%, transparent);
    white-space: nowrap;
    opacity: 0;
    animation-name: dbt-rise;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  /* Header standard intangible : brand gauche + logo LM droite + border-bottom. */
  .debat__header {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .debat__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .debat__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .debat__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Corps centré verticalement dans l'espace sous le header. */
  .debat__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .debat__eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    margin: 0 0 24px;
    opacity: 0;
    animation: dbt-fade-left 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .debat__eyebrow-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    display: inline-block;
    flex: 0 0 auto;
  }
  /* Point "en direct" qui pulse (live). */
  .debat__live-dot {
    position: relative;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--c-accent);
    flex: 0 0 auto;
  }
  .debat__live-dot::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--c-accent);
    animation: dbt-ping 1.6s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .debat__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 1320px;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
    opacity: 0;
    animation: dbt-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.24s both;
  }
  .debat__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .debat__intro {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    color: var(--c-muted);
    margin: 24px 0 0;
    max-width: var(--measure-l);
    opacity: 0;
    animation: dbt-fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.36s both;
  }

  /* Le fil de discussion : une ligne par prompt, bulle + avatar, en quinconce. */
  .debat__thread {
    list-style: none;
    margin: 44px 0 0;
    padding: 0;
    max-width: none;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .debat__row {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    opacity: 0;
    animation: dbt-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(0.5s + var(--i, 0) * 0.18s);
  }
  .debat__row--right {
    flex-direction: row-reverse;
  }

  /* Avatar rond (exception border-radius 50% admise pour les profils). Voix
     alternées : or pour les lignes de gauche, encre pour les lignes de droite. */
  .debat__avatar {
    position: relative;
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--c-accent);
    color: var(--c-on-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 14%, transparent);
  }
  .debat__avatar :global(svg) {
    width: 34px;
    height: 34px;
  }
  .debat__row--right .debat__avatar {
    background: color-mix(in srgb, var(--c-ink) 86%, var(--c-surface));
    color: var(--c-surface);
  }

  /* Bulle = card radius 4px (RÈGLE) + petite queue triangulaire vers l'avatar. */
  .debat__bubble {
    position: relative;
    max-width: 62%;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
    border-radius: 4px;
    padding: 22px 28px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 400;
    color: var(--c-ink);
  }
  .debat__bubble::before {
    content: '';
    position: absolute;
    bottom: 20px;
    left: -10px;
    border-style: solid;
    border-width: 9px 12px 9px 0;
    border-color: transparent var(--c-surface) transparent transparent;
  }
  .debat__row--right .debat__bubble::before {
    left: auto;
    right: -10px;
    border-width: 9px 0 9px 12px;
    border-color: transparent transparent transparent var(--c-surface);
  }

  /* ============ MODE LIVE ============ */
  /* Bulles : entrée depuis les côtés opposés (rebond), puis flottement continu
     porté par la bulle elle-même (la ligne gère l'entrée, la bulle le flottement,
     pour ne pas faire entrer deux transforms en conflit). */
  .debat--live .debat__row {
    opacity: 0;
    animation: dbt-in-left 0.85s cubic-bezier(0.22, 1.2, 0.36, 1) both;
    animation-delay: calc(0.4s + var(--i, 0) * 0.18s);
  }
  .debat--live .debat__row--right {
    animation-name: dbt-in-right;
  }
  .debat--live .debat__bubble {
    animation: dbt-float 5.5s ease-in-out infinite;
    animation-delay: calc(1.4s + var(--i, 0) * 0.4s);
  }
  /* Halo de voix qui pulse autour de l'avatar. */
  .debat--live .debat__avatar::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid var(--c-accent);
    animation: dbt-halo 2.4s ease-out infinite;
    animation-delay: calc(var(--i, 0) * 0.35s);
  }
  .debat--live .debat__row--right .debat__avatar::after {
    border-color: color-mix(in srgb, var(--c-ink) 70%, transparent);
  }
  /* Ambiance qui dérive doucement en live. */
  .debat--live .debat__ghost-avatar {
    animation: dbt-drift 9s ease-in-out infinite;
  }
  .debat--live .debat__ghost-bubble {
    animation: dbt-drift 11s ease-in-out infinite reverse;
  }

  @keyframes dbt-fade-up {
    from { opacity: 0; transform: translateY(26px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes dbt-fade-left {
    from { opacity: 0; transform: translateX(-22px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes dbt-in-left {
    from { opacity: 0; transform: translateX(-70px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes dbt-in-right {
    from { opacity: 0; transform: translateX(70px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes dbt-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  @keyframes dbt-halo {
    0% { transform: scale(1); opacity: 0.7; }
    70%, 100% { transform: scale(1.7); opacity: 0; }
  }
  @keyframes dbt-ping {
    0% { transform: scale(1); opacity: 0.6; }
    70%, 100% { transform: scale(2.6); opacity: 0; }
  }
  @keyframes dbt-drift {
    0%, 100% { transform: translate(-50%, -50%); }
    50% { transform: translate(-50%, calc(-50% - 14px)); }
  }
  @keyframes dbt-rise {
    0% { opacity: 0; transform: translate(-50%, 20px) scale(0.94); }
    12% { opacity: 0.5; }
    85% { opacity: 0.5; }
    100% { opacity: 0; transform: translate(-50%, -440px) scale(1); }
  }

  /* Accessibilité + impression : on fige tout (pas de mouvement, état final
     lisible, flux décoratif masqué). */
  @media (prefers-reduced-motion: reduce) {
    .debat__eyebrow,
    .debat__title,
    .debat__intro,
    .debat__row,
    .debat--live .debat__row,
    .debat--live .debat__bubble {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .debat__stream { display: none !important; }
    .debat__live-dot::after,
    .debat--live .debat__avatar::after,
    .debat--live .debat__ghost-avatar,
    .debat--live .debat__ghost-bubble { animation: none !important; }
  }
  @media print {
    .debat__eyebrow,
    .debat__title,
    .debat__intro,
    .debat__row,
    .debat--live .debat__row,
    .debat--live .debat__bubble {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .debat__stream { display: none !important; }
    .debat__live-dot::after,
    .debat--live .debat__avatar::after,
    .debat--live .debat__ghost-avatar,
    .debat--live .debat__ghost-bubble { animation: none !important; }
  }
</style>
