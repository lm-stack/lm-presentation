---
// src/components/slides/TableHero.astro
// Tableau multi-colonnes ExecEd-style : header marque + logo LM (44/40), titre
// (Hanken Grotesk, portion en serif italique soulignée jaune) + sous-titre + intro
// optionnels en haut (fixes), puis un tableau centré dans l'espace restant :
// en-tête ink, première colonne en gras ink, lignes zébrées discrètes, cadre
// radius 4px et ombre légère. Légende / source optionnelles (.slide-source).
//
// Pendant ExecEd de l'ancien TableSlide (format SlideTitle). Conçu pour des
// tableaux de 3 à 4 colonnes et jusqu'à ~8 lignes sur une slide 1920x1080.
import { splitHighlight } from '@/utils/highlight';
interface Props {
  title: string;
  /** Portion du titre en serif italique soulignée jaune. */
  italicPart?: string;
  subtitle?: string;
  /** Phrase d'introduction optionnelle, sous le sous-titre. */
  intro?: string;
  headers: string[];
  rows: string[][];
  /** Met la première colonne en avant (gras ink). Défaut true. */
  emphasizeFirstCol?: boolean;
  /** Légende sous le tableau. */
  caption?: string;
  /** Étude citée, en bas à gauche. */
  source?: string;
  /** Lien rendant la source cliquable. */
  sourceUrl?: string;
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  intro,
  headers,
  rows,
  emphasizeFirstCol = true,
  caption,
  source,
  sourceUrl,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="table-hero" data-layout="table-hero">
  <header class="table-hero__header">
    <div class="table-hero__brand-text">
      <p class="table-hero__brand-main">{brand}</p>
      {brandSub && <p class="table-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="table-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="table-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="table-hero__body">
    <div class="table-hero__heading">
      <h2 class="table-hero__title">
        {titleParts
          ? <>{titleParts.before}<em class="table-hero__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="table-hero__subtitle">{subtitle}</p>}
      {intro && <p class="table-hero__intro">{intro}</p>}
    </div>

    <div class="table-hero__table-area">
      <div class="table-hero__wrapper">
        <table class:list={['table-hero__table', emphasizeFirstCol && 'table-hero__table--emph-first']}>
          <thead>
            <tr>{headers.map((h) => <th>{h}</th>)}</tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
            ))}
          </tbody>
        </table>
      </div>
      {caption && <p class="table-hero__caption">{caption}</p>}
    </div>
  </div>

  {source && (sourceUrl
    ? <a class="slide-source" href={sourceUrl} target="_blank" rel="noopener">Source : {source}</a>
    : <p class="slide-source">Source : {source}</p>)}
</section>

<style>
  .table-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom. */
  .table-hero__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .table-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .table-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .table-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Corps : heading fixe en haut, tableau centré dans l'espace restant. */
  .table-hero__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
    padding-top: 28px;
  }
  .table-hero__heading {
    flex: 0 0 auto;
  }
  .table-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(40px, 4vw, 64px);
    line-height: 1.06;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .table-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .table-hero__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 24px;
    line-height: 1.4;
    font-weight: 500;
    color: var(--c-muted);
    margin: 12px 0 0;
    max-width: 1500px;
  }
  .table-hero__intro {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 20px;
    line-height: 1.5;
    font-weight: 400;
    color: var(--c-muted);
    margin: 10px 0 0;
    max-width: 1400px;
  }

  /* Zone tableau : prend l'espace restant, centre le tableau verticalement. */
  .table-hero__table-area {
    flex: 0 0 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .table-hero__wrapper {
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    background: var(--c-surface);
  }
  .table-hero__table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Hanken Grotesk', sans-serif;
  }
  .table-hero__table thead th {
    background: var(--c-accent);
    color: var(--c-on-accent);
    text-align: left;
    padding: 18px 28px;
    font-size: 21px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .table-hero__table tbody td {
    padding: 16px 28px;
    font-size: 23px;
    line-height: 1.35;
    font-weight: 400;
    color: var(--c-muted);
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .table-hero__table tbody tr:nth-child(even) td {
    background: color-mix(in srgb, var(--c-ink) 2.5%, transparent);
  }
  .table-hero__table tbody tr:last-child td {
    border-bottom: none;
  }
  /* Première colonne en avant : libellé fort ink. */
  .table-hero__table--emph-first tbody td:first-child {
    color: var(--c-ink);
    font-weight: 700;
  }

  .table-hero__caption {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--c-muted);
    margin: 0;
    text-align: left;
  }
</style>
