---
// src/components/slides/Recap.astro
// Slide « récap » ExecEd-style : header standard (brand + logo LM + border) puis
// deux colonnes dérivées AU BUILD du parcours, comme AgendaDays :
//   - Workshops : tout deck dont le corps MDX contient un <Workshop> (moins la
//     liste `noWorkshop`, même override que l'agenda), libellé = titre du deck.
//   - Démonstrations : chaque <Demo toolName="..."> rencontré dans les decks.
// Aucun chiffre écrit à la main : ajouter un atelier ou une démo dans un deck
// met le récap à jour tout seul. Charte LM light, fond pearl, cards radius 4px.
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';

interface Props {
  /** Slug du parcours (id de collection, ex. "crm-data-automation"). */
  parcours: string;
  title?: string;
  italicPart?: string;
  subtitle?: string;
  /** Slugs de decks à NE jamais compter comme workshop (même override que l'agenda). */
  noWorkshop?: string[];
  brand?: string;
  brandSub?: string;
}

const {
  parcours: slug,
  title = 'Le chemin parcouru',
  italicPart = 'parcouru',
  subtitle,
  noWorkshop = [],
  brand,
  brandSub,
} = Astro.props;

const entry = (await getCollection('parcours')).find((p) => p.id === slug);
if (!entry) {
  throw new Error(`<Recap> : parcours "${slug}" introuvable dans src/content/parcours/.`);
}

const order: string[] = entry.data.decks ?? [];
const bodyBySlug = new Map(
  (await getCollection('presentations')).map((p) => [p.id, { title: p.data.title, body: p.body ?? '' }])
);

const workshops: string[] = [];
const demos: string[] = [];
for (const deckSlug of order) {
  const meta = bodyBySlug.get(deckSlug);
  if (!meta) continue;
  if (/<Workshop[\s/>]/.test(meta.body) && !noWorkshop.includes(deckSlug)) {
    workshops.push(meta.title);
  }
  for (const m of meta.body.matchAll(/toolName="([^"]+)"/g)) {
    demos.push(m[1]);
  }
}

// brand / brandSub dérivés comme la route p/[slug].astro, AgendaDays, Agenda.
const INSTITUTION: Record<string, string> = {
  execed: 'Executive Education',
  lm: 'Lausanne Marketing',
};
const resolvedBrand = brand ?? entry.data.title;
const resolvedBrandSub = brandSub ?? INSTITUTION[entry.data.scheme];
const titleParts = splitHighlight(title, italicPart);

const cols = [
  { icon: 'ph:chalkboard-teacher-fill', label: 'Workshops', count: workshops.length, items: workshops },
  { icon: 'ph:monitor-play-fill', label: 'Démonstrations', count: demos.length, items: demos },
];
---
<section class="recap" data-layout="recap">
  <header class="recap__header">
    <div class="recap__brand-text">
      <p class="recap__brand-main">{resolvedBrand}</p>
      {resolvedBrandSub && <p class="recap__brand-sub">{resolvedBrandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="recap__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="recap__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="recap__body">
    <h2 class="recap__title">
      {titleParts
        ? <>{titleParts.before}<em class="recap__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
        : title}
    </h2>
    {subtitle && <p class="recap__subtitle">{subtitle}</p>}

    <div class="recap__grid">
      {cols.map((col) => (
        <article class="recap__card">
          <div class="recap__card-head">
            <span class="recap__icon" aria-hidden="true"><Icon name={col.icon} /></span>
            <span class="recap__count">{col.count}</span>
            <span class="recap__card-label">{col.label}</span>
          </div>
          <ul class="recap__list">
            {col.items.map((item) => (
              <li class="recap__item">
                <span class="recap__mark" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .recap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width (RÈGLE) : brand gauche + logo LM droite + border-bottom. */
  .recap__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .recap__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .recap__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .recap__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Corps : titre fixe en haut puis grille centrée dans l'espace restant. */
  .recap__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 32px;
  }
  .recap__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .recap__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .recap__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    margin: 0 0 48px;
    color: var(--c-muted);
    max-width: none;
    text-align: left;
  }

  .recap__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    align-items: start;
  }

  .recap__card {
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 36px 44px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .recap__card-head {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-bottom: 24px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .recap__icon {
    width: 56px;
    height: 56px;
    color: var(--c-accent);
    flex: 0 0 auto;
  }
  .recap__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  /* Grand chiffre décoratif (exception assumée, cf. type.css : « chiffres stat
     géants sans token »), pendant du gros numéro de Steps. */
  .recap__count {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 88px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--c-ink);
    flex: 0 0 auto;
  }
  .recap__card-label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-muted);
  }

  .recap__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .recap__item {
    display: flex;
    align-items: baseline;
    gap: 16px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 600;
    color: var(--c-ink);
  }
  .recap__mark {
    flex: 0 0 auto;
    width: 12px;
    height: 12px;
    margin-top: 2px;
    align-self: center;
    background: var(--c-accent);
    display: inline-block;
  }
</style>
