---
// src/components/slides/AboutMe.astro
// Slide "a propos" intro : eyebrow, nom monumental, role, photo polaroid.
// Pas de bullets : la liste vit sur la slide suivante (AboutMeBullets).
// Charte LM (#FFD838 gold, Hanken Grotesk + Space Grotesk), watermark gold derriere.

interface Props {
  eyebrow?: string;
  firstName: string;
  lastName: string;
  highlight?: string;   // Mot du nom a souligner (bande noire rotative)
  role?: string;
  photo: string;
  photoAlt?: string;
  watermark?: string;   // Watermark monumental (ex: initiales)
}

const {
  eyebrow = 'À propos',
  firstName,
  lastName,
  highlight,
  role,
  photo,
  photoAlt = '',
  watermark,
} = Astro.props;

function splitHighlight(text: string, mot?: string) {
  if (!mot) return null;
  const idx = text.toLowerCase().indexOf(mot.toLowerCase());
  if (idx === -1) return null;
  return {
    before: text.slice(0, idx),
    match: text.slice(idx, idx + mot.length),
    after: text.slice(idx + mot.length),
  };
}

const lastNameParts = splitHighlight(lastName, highlight);
---
<section
  class="about-me"
  data-layout="about-me"
  data-section-title="À propos"
>
  <span class="about-me__wash" aria-hidden="true"></span>
  {watermark && <span class="about-me__watermark" aria-hidden="true">{watermark}</span>}

  <div class="about-me__layout">
    <div class="about-me__text">
      <p class="about-me__eyebrow">{eyebrow}</p>
      <h2 class="about-me__name">
        <span class="about-me__first">{firstName}</span>
        <span class="about-me__last">
          {lastNameParts
            ? <>{lastNameParts.before}<span class="about-me__mark">{lastNameParts.match}</span>{lastNameParts.after}</>
            : lastName}
        </span>
      </h2>
      {role && <p class="about-me__role">{role}</p>}
      <span class="about-me__rule" aria-hidden="true"></span>
    </div>

    <div class="about-me__portrait" aria-hidden={!photoAlt}>
      <div class="about-me__polaroid">
        <img src={photo} alt={photoAlt} loading="eager" decoding="async" />
      </div>
    </div>
  </div>
</section>

<style>
  .about-me {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 96px 96px !important;
    background: var(--slide-bg, #FAF8F3);
    color: #191919;
    display: flex !important;
    flex-direction: column;
    justify-content: center !important;
  }

  .about-me__wash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 0% 100%, rgba(255, 216, 56, 0.32) 0%, rgba(255, 216, 56, 0) 55%);
    z-index: 0;
  }

  .about-me__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 900;
    font-size: 880px;
    line-height: 0.78;
    letter-spacing: -0.07em;
    color: #FFD838;
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
    z-index: 0;
    -webkit-mask-image: linear-gradient(to right, #000 30%, rgba(0, 0, 0, 0.18) 100%);
    mask-image: linear-gradient(to right, #000 30%, rgba(0, 0, 0, 0.18) 100%);
    animation: about-watermark 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .about-me__layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 96px;
    align-items: center;
    max-width: 1700px;
    width: 100%;
    margin: 0 auto;
  }

  .about-me__text {
    animation: about-stagger 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .about-me__eyebrow {
    display: inline-block;
    font-family: 'Space Grotesk', monospace;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: #191919;
    margin: 0 0 36px;
    padding: 10px 20px;
    background: #FFD838;
    border: 2px solid #191919;
    border-radius: 4px;
  }

  .about-me__name {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 900;
    font-size: clamp(160px, 16vw, 280px);
    line-height: 0.85;
    letter-spacing: -0.045em;
    color: #191919;
    margin: 0 0 32px;
    text-align: left;
    text-wrap: balance;
    display: flex;
    flex-direction: column;
  }
  .about-me__first {
    opacity: 0.45;
    font-weight: 400;
  }
  .about-me__last {
    color: #191919;
  }

  .about-me__mark {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .about-me__mark::after {
    content: '';
    position: absolute;
    left: -8px;
    right: -8px;
    bottom: 6px;
    height: 16px;
    background: #191919;
    z-index: -1;
    transform: rotate(-1.5deg);
  }

  .about-me__role {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 40px;
    font-weight: 500;
    line-height: 1.3;
    color: #6B6F84;
    margin: 0 0 36px;
    max-width: 900px;
  }

  .about-me__rule {
    display: block;
    width: 96px;
    height: 6px;
    background: #FFD838;
  }

  .about-me__portrait {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .about-me__polaroid {
    width: 620px;
    aspect-ratio: 4 / 5;
    background: #191919;
    padding: 20px 20px 96px;
    transform: rotate(3deg);
    box-shadow: 0 32px 60px -16px rgba(25, 25, 25, 0.45);
    position: relative;
    animation: about-pop 1s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
  }
  .about-me__polaroid::after {
    content: '';
    position: absolute;
    left: 28px;
    bottom: 40px;
    width: 80px;
    height: 4px;
    background: #FFD838;
  }
  .about-me__polaroid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @keyframes about-stagger {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes about-pop {
    from { opacity: 0; transform: rotate(3deg) translateY(28px) scale(0.94); }
    to { opacity: 1; transform: rotate(3deg) translateY(0) scale(1); }
  }
  @keyframes about-watermark {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>
