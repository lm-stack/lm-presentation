---
// src/components/slides/Calendar.astro
// Calendrier d'une journee : header marque + logo LM (RÈGLE), fond pearl, titre
// body + sous-titre, puis un libelle de jour vertical + un tableau horaire
// (en-tete accent, lignes zebrees discretes), facon Table. Tokenise.
import { splitHighlight } from '@/utils/highlight';

interface Slot {
  time: string;
  subject: string;
  speaker?: string;
}

interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  day: string;
  slots: Slot[];
  speakerHeader?: string;
  showSpeakerColumn?: boolean;
  brand?: string;
  brandSub?: string;
}

const {
  title = 'Calendrier',
  italicPart,
  subtitle,
  day,
  slots,
  speakerHeader = 'Intervenant',
  showSpeakerColumn = true,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="calendar" data-layout="calendar">
  <header class="calendar__header">
    <div class="calendar__brand-text">
      <p class="calendar__brand-main">{brand}</p>
      {brandSub && <p class="calendar__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="calendar__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="calendar__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="calendar__body">
    <div class="calendar__heading">
      <h2 class="calendar__title">
        {titleParts
          ? <>{titleParts.before}<em class="calendar__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="calendar__subtitle">{subtitle}</p>}
    </div>

    <div class="calendar__wrapper">
      <span class="calendar__day-label">{day}</span>
      <div class="calendar__table-wrap">
        <table class="calendar__table">
          <thead>
            <tr>
              <th>Horaire</th>
              <th>Sujet</th>
              {showSpeakerColumn && <th>{speakerHeader}</th>}
            </tr>
          </thead>
          <tbody>
            {slots.map((slot) => (
              <tr>
                <td class="calendar__time">{slot.time}</td>
                <td class="calendar__subject">{slot.subject}</td>
                {showSpeakerColumn && <td class="calendar__speaker">{slot.speaker ?? ''}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<style>
  .calendar {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom (RÈGLE). */
  .calendar__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .calendar__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .calendar__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .calendar__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .calendar__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
    padding-top: 28px;
  }
  .calendar__heading { flex: 0 0 auto; }
  .calendar__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .calendar__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .calendar__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 12px 0 0;
    max-width: none;
    text-align: left;
  }

  .calendar__wrapper {
    display: flex;
    align-items: stretch;
    gap: 24px;
    width: 100%;
  }
  .calendar__day-label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-source);
    color: var(--c-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    align-self: stretch;
    display: flex;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    padding: 16px 0;
  }
  .calendar__table-wrap {
    flex: 1;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    background: var(--c-surface);
  }
  .calendar__table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
  }
  .calendar__table thead th {
    background: var(--c-accent);
    color: var(--c-on-accent);
    text-align: left;
    padding: 16px 24px;
    font-weight: 700;
  }
  .calendar__table tbody td {
    padding: 14px 24px;
    color: var(--c-muted);
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .calendar__table tbody tr:nth-child(even) td {
    background: color-mix(in srgb, var(--c-ink) 2.5%, transparent);
  }
  .calendar__table tbody tr:last-child td {
    border-bottom: none;
  }
  .calendar__time {
    color: var(--c-ink) !important;
    font-weight: 700;
    white-space: nowrap;
    font-feature-settings: 'tnum';
  }
  .calendar__subject {
    color: var(--c-ink) !important;
  }
</style>
