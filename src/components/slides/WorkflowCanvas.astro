---
// src/components/slides/WorkflowCanvas.astro
// Slide "démo interactive" : on construit un WORKFLOW d'exécution en direct,
// étape par étape, via les fragments Reveal (chaque noeud + son connecteur
// apparait sur avance clavier). Pendant workflow du BpmnCanvas (modélisation) :
// même langage visuel (barre chrome avec dots, fond pointillé, connecteurs à
// pulse animé), mais un flux LINÉAIRE de noeuds (déclencheur, actions, action
// spéciale) au lieu d'un diagramme BPMN à swimlanes. Thémé via les tokens
// (--c-accent), aucune couleur en dur.
//
// Coordonnées : canvas fixe 1728x760 (slide figé 1920x1080, Reveal scale le
// tout) -> viewBox SVG 0 0 1728 760 mappe 1:1 sur les px des noeuds absolus.
//
// Workflow : « Du formulaire reçu à l'email de bienvenue » (le plan du workflow
// construit en direct à la démo Zapier qui suit). Déclencheur « Nouveau
// formulaire » (Google Forms) -> Action « Créer le contact » (Zoho CRM) ->
// Action spéciale « Consentement donné ? » (Filtre) -> Action « Envoyer l'email »
// (Gmail). Le noeud déclencheur est visible d'emblée (l'ancre de départ) ; les
// trois étapes suivantes apparaissent une à une avec leur connecteur.
import { Icon } from 'astro-icon/components';
interface Props {
  brand?: string;
  brandSub?: string;
  tocLabel?: string;
}
const {
  brand = 'Titre de la présentation',
  brandSub,
  tocLabel = 'Construction en direct',
} = Astro.props;

// Géométrie : 4 noeuds (carte 230 de large) répartis sur le canvas, alignés sur
// une même ligne. top 274 -> le centre de carte (où arrivent les connecteurs)
// tombe à y 402 (274 + 44 de libellé de type + 84 = mi-hauteur de carte 168).
const NODE_TOP = 274;
const LINK_Y = 402;

// Déclencheur : visible d'emblée (l'ancre, le processus naît ici).
const trigger = {
  kind: 'Déclencheur',
  label: 'Nouveau formulaire reçu',
  tool: 'Google Forms',
  icon: 'ph:lightning',
  x: 164,
};

// Étapes suivantes (fragments 1..3) : action, action spéciale (filtre), action.
const steps = [
  { id: 1, kind: 'Action', label: 'Créer le contact', tool: 'Zoho CRM', icon: 'ph:user-plus', x: 554, type: 'action' },
  { id: 2, kind: 'Action spéciale', label: 'Consentement donné ?', tool: 'Filtre', icon: 'ph:funnel', x: 944, type: 'special' },
  { id: 3, kind: 'Action', label: "Envoyer l'email", tool: 'Gmail', icon: 'ph:paper-plane-tilt', x: 1334, type: 'action' },
];

// Connecteurs : bord droit du noeud source -> bord gauche du noeud cible (carte
// large de 230), à la hauteur LINK_Y. idx aligné sur le fragment du noeud cible.
const links = [
  { idx: 1, x1: trigger.x + 230, x2: steps[0].x },
  { idx: 2, x1: steps[0].x + 230, x2: steps[1].x },
  { idx: 3, x1: steps[1].x + 230, x2: steps[2].x },
];
---
<section class="wf" data-layout="workflow-canvas" data-section-title={tocLabel}>
  <header class="wf__header">
    <div class="wf__brand-text">
      <p class="wf__brand-main">{brand}</p>
      {brandSub && <p class="wf__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="wf__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="wf__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="wf__body">
    {/* Fenêtre : barre chrome (titre) flush sur le canvas + légende de notation */}
    <div class="wf__window">
      <div class="wf__chrome">
        <div class="wf__dots" aria-hidden="true"><span></span><span></span><span></span></div>
        <div class="wf__chrome-title">
          <Icon name="ph:flow-arrow" class="wf__chrome-icon" aria-hidden="true" />
          Du formulaire reçu à l'email de bienvenue
        </div>
        <div class="wf__legend" aria-hidden="true">
          <span class="wf__legend-item"><span class="wf__legend-mark wf__legend-mark--trigger"></span>Déclencheur</span>
          <span class="wf__legend-item"><span class="wf__legend-mark wf__legend-mark--action"></span>Action</span>
          <span class="wf__legend-item"><span class="wf__legend-mark wf__legend-mark--special"></span>Action spéciale</span>
        </div>
      </div>

      {/* Canvas pointillé : connecteurs (svg) + noeuds (absolu) */}
      <div class="wf__canvas">
        {/* Connecteurs (flux d'exécution gauche -> droite) */}
        <svg class="wf__links" viewBox="0 0 1728 760" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <marker id="wf-arrow" markerWidth="10" markerHeight="10" refX="7.5" refY="4" orient="auto" markerUnits="userSpaceOnUse">
              <path d="M1 1 L8 4 L1 7" class="wf-arrowhead" />
            </marker>
            <filter id="wf-glow" filterUnits="userSpaceOnUse" x="0" y="0" width="1728" height="760">
              <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="b" />
              <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
            </filter>
          </defs>

          {links.map((l) => (
            <g class="wf-link fragment" data-fragment-index={l.idx}>
              <path class="wf-link__base" d={`M${l.x1} ${LINK_Y} L${l.x2} ${LINK_Y}`} marker-end="url(#wf-arrow)" />
              <path class="wf-link__pulse" d={`M${l.x1} ${LINK_Y} L${l.x2} ${LINK_Y}`} pathLength="100" />
            </g>
          ))}
        </svg>

        {/* Noeud déclencheur (visible d'emblée) */}
        <div class="wf-node wf-node--trigger" style={`left: ${trigger.x}px; top: ${NODE_TOP}px;`}>
          <span class="wf-node__kind">{trigger.kind}</span>
          <div class="wf-node__card">
            <span class="wf-node__icon"><Icon name={trigger.icon} class="wf-node__ic" aria-hidden="true" /></span>
            <span class="wf-node__label">{trigger.label}</span>
            <span class="wf-node__tool">{trigger.tool}</span>
          </div>
        </div>

        {/* idx1..3 : action, action spéciale (filtre), action */}
        {steps.map((s) => (
          <div class={`wf-node wf-node--${s.type} fragment`} data-fragment-index={s.id} style={`left: ${s.x}px; top: ${NODE_TOP}px;`}>
            <span class="wf-node__kind">{s.kind}</span>
            <div class="wf-node__card">
              <span class="wf-node__icon"><Icon name={s.icon} class="wf-node__ic" aria-hidden="true" /></span>
              <span class="wf-node__label">{s.label}</span>
              <span class="wf-node__tool">{s.tool}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .wf {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    /* Header aligné sur la norme de la famille (haut 44px) ; bas maintenu à 44px
       (le canvas fixe 760px a besoin de la place, le bas n'affecte pas le header). */
    padding: 44px 96px 44px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header intangible : brand gauche + logo LM droite + border-bottom. */
  .wf__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .wf__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .wf__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .wf__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Corps : la fenêtre (chrome + canvas) centrée dans l'espace sous le header. */
  .wf__body {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  /* La fenêtre : chrome et canvas collés (un seul bloc, pas d'espace entre). */
  .wf__window {
    width: 1728px;
    margin: 0 auto;
    border-radius: 6px;
    box-shadow: 0 8px 24px -10px color-mix(in srgb, var(--c-ink) 14%, transparent);
  }

  /* Barre chrome facon fenêtre d'application (flush sur le canvas). */
  .wf__chrome {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 14px 26px;
    background: color-mix(in srgb, var(--c-ink) 3%, var(--c-surface));
    border: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
    border-radius: 6px 6px 0 0;
    border-bottom: none;
  }
  .wf__dots { display: flex; gap: 8px; flex: 0 0 auto; }
  .wf__dots span {
    width: 12px; height: 12px; border-radius: 50%;
    background: color-mix(in srgb, var(--c-ink) 22%, transparent);
  }
  .wf__dots span:nth-child(1) { background: color-mix(in srgb, var(--c-accent) 70%, transparent); }
  .wf__chrome-title {
    display: flex; align-items: center; gap: 12px;
    flex: 1 1 auto;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--c-ink);
  }
  .wf__chrome-icon { width: 26px; height: 26px; color: var(--c-accent); flex: 0 0 auto; }
  .wf__legend { display: flex; align-items: center; gap: 24px; flex: 0 0 auto; }
  .wf__legend-item {
    display: flex; align-items: center; gap: 9px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-source);
    font-weight: 500;
    color: var(--c-muted);
  }
  .wf__legend-mark { width: 18px; height: 18px; flex: 0 0 auto; border: 2px solid var(--c-accent); border-radius: 3px; }
  .wf__legend-mark--trigger { background: var(--c-accent); border-radius: 50%; }
  .wf__legend-mark--action { background: color-mix(in srgb, var(--c-accent) 12%, transparent); }
  .wf__legend-mark--special { background: transparent; border-style: dashed; }

  /* Canvas : fond pointillé, boite fixe 1728x760, collée sous la barre chrome. */
  .wf__canvas {
    position: relative;
    width: 1728px;
    height: 760px;
    border: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
    border-radius: 0 0 6px 6px;
    background:
      radial-gradient(circle, color-mix(in srgb, var(--c-ink) 12%, transparent) 1.4px, transparent 1.4px) 0 0 / 26px 26px,
      var(--c-surface);
    overflow: hidden;
  }

  /* Couche connecteurs. */
  .wf__links {
    position: absolute;
    inset: 0;
    width: 1728px;
    height: 760px;
    z-index: 1;
    pointer-events: none;
  }
  .wf-link__base {
    stroke: color-mix(in srgb, var(--c-ink) 26%, transparent);
    stroke-width: 2.5;
    fill: none;
  }
  .wf-arrowhead {
    fill: none;
    stroke: color-mix(in srgb, var(--c-ink) 38%, transparent);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .wf-link__pulse {
    stroke: var(--c-accent);
    stroke-width: 3.5;
    fill: none;
    stroke-linecap: round;
    stroke-dasharray: 18 82;
    filter: url(#wf-glow);
    animation: wf-flow 2.4s linear infinite;
  }
  @keyframes wf-flow {
    from { stroke-dashoffset: 100; }
    to { stroke-dashoffset: 0; }
  }

  /* Noeuds (couche supérieure) : libellé de type + carte. */
  .wf-node {
    position: absolute;
    z-index: 2;
    width: 230px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  /* Libellé de type au-dessus de la carte (hauteur figée -> le centre de carte
     tombe pile sur LINK_Y, peu importe le texte). */
  .wf-node__kind {
    height: 30px;
    line-height: 30px;
    margin-bottom: 14px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-source);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-muted);
  }

  /* Carte : icône en badge, libellé de l'action, tag outil en pied. */
  .wf-node__card {
    position: relative;
    width: 100%;
    height: 168px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 18px 16px 0;
    background: var(--c-surface);
    border: 2px solid color-mix(in srgb, var(--c-ink) 16%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 12%, transparent);
    overflow: hidden;
  }
  .wf-node__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: color-mix(in srgb, var(--c-accent) 12%, transparent);
  }
  .wf-node__ic { width: 30px; height: 30px; color: var(--c-accent); flex: 0 0 auto; }
  .wf-node__label {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    font-weight: 600;
    line-height: 1.18;
    color: var(--c-ink);
    text-align: center;
  }
  /* Tag outil : pied de carte, fond accent doux, nom de l'outil en capitales. */
  .wf-node__tool {
    flex: 0 0 auto;
    width: calc(100% + 32px);
    margin: 0 -16px;
    padding: 8px 0;
    background: color-mix(in srgb, var(--c-accent) 12%, transparent);
    border-top: 1px solid color-mix(in srgb, var(--c-accent) 22%, transparent);
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-source);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c-accent);
    text-align: center;
  }

  /* Déclencheur : carte d'entrée mise en avant (fond accent doux + bord accent). */
  .wf-node--trigger .wf-node__card {
    background: color-mix(in srgb, var(--c-accent) 7%, var(--c-surface));
    border-color: var(--c-accent);
  }
  .wf-node--trigger .wf-node__icon {
    background: color-mix(in srgb, var(--c-accent) 18%, transparent);
  }

  /* Action : accent porté par la barre latérale gauche (comme une tâche BPMN). */
  .wf-node--action .wf-node__card {
    border-left: 4px solid var(--c-accent);
  }

  /* Action spéciale (filtre) : bord en pointillés pour la distinguer. */
  .wf-node--special .wf-node__card {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--c-accent) 55%, var(--c-ink));
  }

  /* Pop des noeuds quand le fragment devient visible (.visible runtime Reveal). */
  .wf-node:global(.fragment.visible) {
    animation: wf-pop 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes wf-pop {
    from { opacity: 0; transform: translateY(12px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Respect de prefers-reduced-motion : pas de pulse ni de pop animés. */
  @media (prefers-reduced-motion: reduce) {
    .wf-link__pulse { animation: none; opacity: 0.5; }
    .wf-node:global(.fragment.visible) { animation: none; }
  }
</style>
