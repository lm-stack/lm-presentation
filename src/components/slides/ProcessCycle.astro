---
// src/components/slides/ProcessCycle.astro
// Slide "deux pôles + cycle" : deux cartes (gauche / droite) reliées par un moyeu
// circulaire de flèches (ph:arrows-clockwise) qui signale un aller-retour permanent
// entre les deux. Header + heading calqués sur Schema/Compare, 100% tokenisé.
// Le bloc titre + diagramme est centré verticalement sous le header ; titre et
// sous-titre centrés horizontalement ; diagramme pleine largeur (cartes flex).
// Usage : "Par où commencer ? Architecture des données <-> Modélisation des processus".
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';
interface Pole {
  icon: string;
  label: string;
  sub?: string;
}
interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  left: Pole;
  right: Pole;
  /** Phrase de synthèse sous le diagramme (le sens du cycle). */
  note?: string;
  /** Icône du moyeu central (cercle de flèches). Défaut ph:arrows-clockwise. */
  hubIcon?: string;
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  left,
  right,
  note,
  hubIcon = 'ph:arrows-clockwise',
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="pcycle" data-layout="process-cycle">
  {/* Le filigrane animé du « cycle » est rendu dans le moyeu central
      (.pcycle__hub) pour être concentrique au moyeu doré : voir plus bas. */}
  <header class="pcycle__header">
    <div class="pcycle__brand-text">
      <p class="pcycle__brand-main">{brand}</p>
      {brandSub && <p class="pcycle__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="pcycle__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="pcycle__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="pcycle__body">
    {(title || subtitle) && (
      <div class="pcycle__heading">
        {title && (
          <h2 class="pcycle__title">
            {titleParts
              ? <>{titleParts.before}<em class="pcycle__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
              : title}
          </h2>
        )}
        {subtitle && <p class="pcycle__subtitle">{subtitle}</p>}
      </div>
    )}

    <div class="pcycle__stage">
      <div class="pcycle__diagram">
        <article class="pcycle__pole">
          <div class="pcycle__pole-icon"><Icon name={left.icon} aria-hidden="true" /></div>
          <h3 class="pcycle__pole-label">{left.label}</h3>
          {left.sub && <p class="pcycle__pole-sub">{left.sub}</p>}
        </article>

        <span class="pcycle__link" aria-hidden="true"></span>

        <div class="pcycle__hub" aria-hidden="true">
          {/* Filigrane animé du « cycle », concentrique au moyeu doré (même centre) :
              cadran fixe + flèche en rotation + anneau pointillé en contre-rotation +
              point doré en orbite. Rendu derrière le contenu (z-index -1), décoratif. */}
          <div class="pcycle__watermark">
            <svg class="pcycle__cycle" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <marker id="pcycle-head" markerWidth="6" markerHeight="6" refX="4.2" refY="3" orient="auto" markerUnits="userSpaceOnUse">
                  <path class="pcycle__cycle-head" d="M1 1 L4.5 3 L1 5" />
                </marker>
              </defs>
              {/* Cadran fixe : cercle fin + 12 graduations (écho de l'horloge AgendaDays). */}
              <g class="pcycle__cycle-dial">
                <circle class="pcycle__cycle-rim" cx="100" cy="100" r="93" />
                {Array.from({ length: 12 }).map((_, i) => (
                  <line class="pcycle__cycle-tick" x1="100" y1="9" x2="100" y2="20" transform={`rotate(${i * 30} 100 100)`} />
                ))}
              </g>
              {/* Anneau pointillé interne, contre-rotation lente (profondeur). */}
              <circle class="pcycle__cycle-dots" cx="100" cy="100" r="64" />
              {/* La flèche circulaire (le cycle), fine, en rotation. */}
              <path class="pcycle__cycle-arrow" d="M143 25.5 A86 86 0 1 1 57 25.5" marker-end="url(#pcycle-head)" />
              {/* Point d'accent doré en orbite (écho de la trotteuse dorée de l'horloge). */}
              <g class="pcycle__cycle-orbit">
                <circle class="pcycle__cycle-dot" cx="100" cy="14" r="4.2" />
              </g>
            </svg>
          </div>
          <span class="pcycle__hub-ring"><Icon name={hubIcon} class="pcycle__hub-ic" /></span>
        </div>

        <span class="pcycle__link" aria-hidden="true"></span>

        <article class="pcycle__pole">
          <div class="pcycle__pole-icon"><Icon name={right.icon} aria-hidden="true" /></div>
          <h3 class="pcycle__pole-label">{right.label}</h3>
          {right.sub && <p class="pcycle__pole-sub">{right.sub}</p>}
        </article>
      </div>

      {note && <p class="pcycle__note">{note}</p>}
    </div>
  </div>
</section>

<style>
  .pcycle {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Filigrane animé : un « cycle » fin et tournant, calqué sur l'horloge du slide
     agenda (AgendaDays). Cadran fixe (cercle + graduations) survolé par une flèche
     circulaire en rotation, un anneau pointillé en contre-rotation, et un point
     doré en orbite (écho de la trotteuse). Concentrique au moyeu doré (enfant du
     moyeu, centré dessus), derrière le contenu (z-index -1), décoratif. */
  .pcycle__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 1240px;
    height: 1240px;
    z-index: -1;
    pointer-events: none;
  }
  .pcycle__cycle {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  /* Cadran fixe : cercle fin + graduations, teinte encre neutre (comme l'horloge). */
  .pcycle__cycle-rim {
    fill: none;
    stroke: color-mix(in srgb, var(--c-ink) 10%, transparent);
    stroke-width: 0.5;
  }
  .pcycle__cycle-tick {
    stroke: color-mix(in srgb, var(--c-ink) 13%, transparent);
    stroke-width: 0.7;
    stroke-linecap: round;
  }

  /* Anneau pointillé interne, contre-rotation lente. */
  .pcycle__cycle-dots {
    fill: none;
    stroke: color-mix(in srgb, var(--c-ink) 12%, transparent);
    stroke-width: 0.9;
    stroke-linecap: round;
    stroke-dasharray: 0.6 5;
    transform-box: view-box;
    transform-origin: 100px 100px;
    animation: pcycle-spin-rev 72s linear infinite;
  }

  /* La flèche circulaire (fine) + sa pointe, en rotation lente. */
  .pcycle__cycle-arrow {
    fill: none;
    stroke: color-mix(in srgb, var(--c-ink) 17%, transparent);
    stroke-width: 0.8;
    stroke-linecap: round;
    transform-box: view-box;
    transform-origin: 100px 100px;
    animation: pcycle-spin 48s linear infinite;
  }
  .pcycle__cycle-head {
    fill: none;
    stroke: color-mix(in srgb, var(--c-ink) 17%, transparent);
    stroke-width: 0.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Point d'accent doré en orbite (écho de la trotteuse dorée de l'horloge). */
  .pcycle__cycle-orbit {
    transform-box: view-box;
    transform-origin: 100px 100px;
    animation: pcycle-spin 18s linear infinite;
  }
  .pcycle__cycle-dot {
    fill: color-mix(in srgb, var(--c-accent) 55%, transparent);
  }

  @keyframes pcycle-spin {
    to { transform: rotate(360deg); }
  }
  @keyframes pcycle-spin-rev {
    to { transform: rotate(-360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pcycle__cycle-dots,
    .pcycle__cycle-arrow,
    .pcycle__cycle-orbit { animation: none; }
  }

  /* Header intangible : brand gauche + logo LM droite + border-bottom. */
  .pcycle__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .pcycle__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .pcycle__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .pcycle__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Body : titre + diagramme centrés comme un bloc (au-dessus du filigrane). */
  .pcycle__body {
    position: relative;
    z-index: 1;
    flex: 1 1 auto !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    gap: 56px;
  }
  .pcycle__heading {
    flex: 0 0 auto;
    text-align: center;
  }
  .pcycle__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: center;
  }
  .pcycle__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .pcycle__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    margin: 12px auto 0;
    color: var(--c-muted);
    text-align: center;
    max-width: var(--measure-l);
  }

  /* Scène : le diagramme, centré horizontalement sous le titre. */
  .pcycle__stage {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .pcycle__diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 36px;
    width: 100%;
  }

  /* Pôle : carte centrée (icône ronde + label + sous-label). */
  .pcycle__pole {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 44px 36px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    text-align: center;
  }
  .pcycle__pole-icon {
    width: 104px;
    height: 104px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--c-accent) 12%, var(--c-surface));
    border: 2px solid color-mix(in srgb, var(--c-accent) 42%, transparent);
  }
  .pcycle__pole-icon :global(svg) {
    width: 52px;
    height: 52px;
    color: var(--c-accent);
  }
  .pcycle__pole-label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--c-ink);
    margin: 0;
  }
  .pcycle__pole-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    font-weight: 400;
    line-height: var(--lh-body);
    color: var(--c-muted);
    margin: 0;
  }

  /* Connecteur : fin trait accent reliant le pôle au moyeu. */
  .pcycle__link {
    flex: 0 0 auto;
    width: 64px;
    height: 3px;
    border-radius: 2px;
    background: color-mix(in srgb, var(--c-accent) 45%, transparent);
  }

  /* Moyeu : cercle de flèches (le cycle). */
  .pcycle__hub {
    position: relative;
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pcycle__hub-ring {
    width: 196px;
    height: 196px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--c-accent) 10%, var(--c-surface));
    border: 3px solid color-mix(in srgb, var(--c-accent) 45%, transparent);
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .pcycle__hub-ic {
    width: 104px;
    height: 104px;
    color: var(--c-accent);
  }

  /* Note de synthèse, centrée sous le diagramme. */
  .pcycle__note {
    flex: 0 0 auto;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 0;
    max-width: var(--measure-l);
    text-align: center;
    text-wrap: balance;
  }
</style>
