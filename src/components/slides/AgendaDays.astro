---
// src/components/slides/AgendaDays.astro
// Agenda « complet » : couche données au-dessus d'une grille 3 colonnes (une
// par jour du parcours). Lit la structure `days` d'un parcours (label + theme)
// et, pour chaque jour, résout les slugs de `decks` en titres réels via la
// collection `presentations`. Aucun texte d'agenda n'est écrit dans le deck :
// tout est dérivé du parcours au build.
import { getCollection } from 'astro:content';
import { splitHighlight } from '@/utils/highlight';

interface Props {
  // Slug du parcours (id de collection, ex. "crm-data-automation").
  parcours: string;
  title?: string;
  italicPart?: string;
  // Slugs de decks à NE jamais marquer "workshop" (override de la détection auto),
  // ex. un deck legacy hors-brochure qui garde un atelier mais ne compte pas.
  noWorkshop?: string[];
  // Slugs de decks à mettre en avant : si non vide, tous les AUTRES decks sont
  // grisés (vue « recap examen » qui isole les workshops évalués).
  examDecks?: string[];
}

const { parcours: slug, title = 'Agenda', italicPart = 'Agenda', noWorkshop = [], examDecks = [] } = Astro.props;

const entry = (await getCollection('parcours')).find((p) => p.id === slug);
if (!entry) {
  throw new Error(
    `<AgendaDays> : parcours "${slug}" introuvable dans src/content/parcours/.`
  );
}

const days = entry.data.days;
if (!days?.length) {
  throw new Error(`<AgendaDays> : le parcours "${slug}" n'a pas de "days" défini.`);
}

// Table slug -> { titre, présence d'un workshop }, pour résoudre chaque jour.
// Un deck est marqué "workshop" si son corps MDX contient un <Workshop ...> :
// l'agenda se met donc à jour tout seul quand on ajoute/retire un atelier.
const metaBySlug = new Map(
  (await getCollection('presentations')).map((p) => [
    p.id,
    { title: p.data.title, hasWorkshop: /<Workshop[\s/>]/.test(p.body ?? '') },
  ])
);

const columns = days.map((d) => {
  if (!d.theme) {
    throw new Error(
      `<AgendaDays> : le jour "${d.label}" du parcours "${slug}" doit définir "theme".`
    );
  }
  const decks = d.decks.map((deckSlug) => {
    const meta = metaBySlug.get(deckSlug);
    if (!meta) {
      throw new Error(
        `<AgendaDays> : deck "${deckSlug}" (jour "${d.label}", parcours "${slug}") introuvable dans src/content/presentations/.`
      );
    }
    return {
      title: meta.title,
      hasWorkshop: meta.hasWorkshop && !noWorkshop.includes(deckSlug),
      dimmed: examDecks.length > 0 && !examDecks.includes(deckSlug),
    };
  });
  return { label: d.label, theme: d.theme, decks };
});

// brand / brandSub dérivés comme la route p/[slug].astro.
const INSTITUTION: Record<string, string> = {
  execed: 'Executive Education',
  lm: 'Lausanne Marketing',
};
const brand = entry.data.title;
const brandSub = INSTITUTION[entry.data.scheme];
const titleParts = splitHighlight(title, italicPart);
---
<section class="agenda-days" data-layout="agenda-days">
  <div class="agenda-days__clock" aria-hidden="true">
    <div class="agenda-days__clock-face">
      {Array.from({ length: 12 }).map((_, i) => (
        <span class="agenda-days__clock-tick" style={`transform: rotate(${i * 30}deg) translateY(-620px)`}></span>
      ))}
      <span class="agenda-days__clock-hand agenda-days__clock-hand--hour"></span>
      <span class="agenda-days__clock-hand agenda-days__clock-hand--minute"></span>
      <span class="agenda-days__clock-hand agenda-days__clock-hand--second"></span>
      <span class="agenda-days__clock-cap"></span>
    </div>
  </div>
  <header class="agenda-days__header">
    <div class="agenda-days__brand-text">
      <p class="agenda-days__brand-main">{brand}</p>
      {brandSub && <p class="agenda-days__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="agenda-days__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo-white-letter.svg" class="agenda-days__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="agenda-days__main">
    <h2 class="agenda-days__title">
      {titleParts
        ? <>{titleParts.before}<em class="agenda-days__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
        : title}
    </h2>

    <div class="agenda-days__grid">
      {columns.map((col) => (
        <div class="agenda-days__col">
          <div class="agenda-days__col-head">
            <span class="agenda-days__day-label">{col.label}</span>
            <h3 class="agenda-days__day-theme">{col.theme}</h3>
            <span class="agenda-days__day-rule" aria-hidden="true"></span>
          </div>
          <ol class="agenda-days__decks">
            {col.decks.map((deck, i) => (
              <li class:list={['agenda-days__deck', { 'agenda-days__deck--workshop': deck.hasWorkshop, 'agenda-days__deck--dimmed': deck.dimmed }]}>
                <span class="agenda-days__deck-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span class="agenda-days__deck-title">{deck.title}</span>
                {deck.hasWorkshop && <span class="agenda-days__deck-tag">Workshop</span>}
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .agenda-days {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Horloge « temps qui passe » : grande, alignée à droite, coupée à la moitié
     par le bord droit (overflow hidden de la section), trotteuse des secondes
     animée. Décorative, derrière les cartes (z-index 0). */
  .agenda-days__clock {
    position: absolute;
    top: 50%;
    left: 0;
    width: 1300px;
    height: 1300px;
    transform: translate(-25%, -50%);
    z-index: 0;
    pointer-events: none;
  }
  .agenda-days__clock-face {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid color-mix(in srgb, var(--c-ink) 13%, transparent);
  }
  .agenda-days__clock-tick {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 4px;
    height: 32px;
    margin: -16px 0 0 -2px;
    background: color-mix(in srgb, var(--c-ink) 15%, transparent);
    transform-origin: 50% 50%;
  }
  .agenda-days__clock-hand {
    position: absolute;
    left: 50%;
    bottom: 50%;
    transform-origin: bottom center;
    border-radius: 4px;
  }
  .agenda-days__clock-hand--hour {
    width: 10px;
    height: 330px;
    margin-left: -5px;
    background: color-mix(in srgb, var(--c-ink) 18%, transparent);
    transform: rotate(-58deg);
  }
  .agenda-days__clock-hand--minute {
    width: 8px;
    height: 488px;
    margin-left: -4px;
    background: color-mix(in srgb, var(--c-ink) 16%, transparent);
    transform: rotate(42deg);
  }
  .agenda-days__clock-hand--second {
    width: 4px;
    height: 568px;
    margin-left: -2px;
    background: color-mix(in srgb, var(--c-accent) 55%, transparent);
    animation: ad-clock-tick 60s linear infinite;
  }
  .agenda-days__clock-cap {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 26px;
    height: 26px;
    margin: -13px 0 0 -13px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--c-ink) 22%, transparent);
  }
  @keyframes ad-clock-tick {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .agenda-days__clock-hand--second { animation: none; }
  }

  /* Header full-width (RÈGLE) : brand gauche + logo LM droite + border-bottom. */
  .agenda-days__header {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .agenda-days__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .agenda-days__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .agenda-days__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Corps : titre + grille 3 colonnes, centré dans l'espace sous le header
     (titre + grille comme un bloc, pattern Programme). */
  .agenda-days__main {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 32px 96px 64px;
    gap: 48px;
  }

  .agenda-days__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .agenda-days__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .agenda-days__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 32px;
    align-items: stretch;
  }

  /* Chaque jour dans une carte blanche : convention carte du repo
     (surface, bordure legere, radius 4px, drop-shadow legere). */
  .agenda-days__col {
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 32px;
  }

  .agenda-days__col-head {
    margin-bottom: 28px;
  }
  .agenda-days__day-label {
    display: block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-muted);
  }
  .agenda-days__day-theme {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 6px 0 0;
    color: var(--c-ink);
    text-align: left;
  }
  .agenda-days__day-rule {
    display: block;
    width: 48px;
    height: 3px;
    margin-top: 16px;
    background: var(--c-accent);
    border-radius: 2px;
  }

  .agenda-days__decks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .agenda-days__deck {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  /* Vue recap examen (prop examDecks) : les decks hors examen sont grisés pour
     isoler visuellement les workshops évalués. */
  .agenda-days__deck--dimmed {
    opacity: 0.3;
  }
  .agenda-days__deck-num {
    flex: 0 0 auto;
    min-width: 30px;
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-label);
    font-weight: 700;
    color: var(--c-accent);
    font-feature-settings: 'tnum';
    letter-spacing: 0.02em;
  }
  .agenda-days__deck-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 600;
    color: var(--c-ink);
  }

  /* Marqueur "Workshop" : pastille gold poussée à droite de la ligne, sur les
     sessions dont le deck contient un atelier (détection auto via le corps MDX). */
  .agenda-days__deck-tag {
    flex: 0 0 auto;
    align-self: center;
    margin-left: auto;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-on-accent);
    background: var(--c-accent);
    border-radius: 4px;
    padding: 3px 9px;
  }
</style>
