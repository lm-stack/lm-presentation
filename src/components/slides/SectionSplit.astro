---
// src/components/slides/SectionSplit.astro
// Layout split half-half : moitié gauche fond noir LM avec titre serif
// italique partiel + carré jaune sous-titre + body texte ; moitié droite
// light texturée (motif damier subtil). Pour les ouvertures de section
// avec un body explicatif riche, là où NumberedSplit attendait une liste.
// Inspiration slide 20 du PPTX ExecEd.
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  body: string;
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  body,
  brand = 'Lausanne Marketing',
  brandSub,
} = Astro.props;
---
<section class="section-split" data-layout="section-split">
  <div class="section-split__bg-right" aria-hidden="true"></div>

  <div class="section-split__left">
    <header class="section-split__header">
      <p class="section-split__brand-main">{brand}</p>
      {brandSub && <p class="section-split__brand-sub">{brandSub}</p>}
    </header>

    <div class="section-split__body">
      <h2 class="section-split__title">
        {italicPart
          ? <>{title.split(italicPart)[0]}<em class="section-split__title-italic">{italicPart}</em>{title.split(italicPart)[1]}</>
          : title}
      </h2>

      {subtitle && (
        <p class="section-split__subtitle">
          <span class="section-split__subtitle-square" aria-hidden="true"></span>
          {subtitle}
        </p>
      )}

      <p class="section-split__text">{body}</p>
    </div>
  </div>
</section>

<style>
  .section-split {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: #191919;
    color: #FAF8F3;
    display: block !important;
  }

  .section-split__bg-right {
    position: absolute;
    top: 0;
    right: 0;
    width: 38%;
    height: 100%;
    background-color: #FAF8F3;
    background-image:
      linear-gradient(45deg, rgba(25, 25, 25, 0.04) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(25, 25, 25, 0.04) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(25, 25, 25, 0.04) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(25, 25, 25, 0.04) 75%);
    background-size: 24px 24px;
    background-position: 0 0, 0 12px, 12px -12px, -12px 0;
  }

  .section-split__left {
    position: relative;
    z-index: 1;
    width: 62%;
    height: 100%;
    padding: 64px 96px;
    display: flex;
    flex-direction: column;
  }

  .section-split__header {
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(250, 248, 243, 0.18);
  }
  .section-split__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: #FAF8F3;
  }
  .section-split__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: rgba(250, 248, 243, 0.65);
  }

  .section-split__body {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    padding-top: 32px;
    max-width: 880px;
  }

  .section-split__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(72px, 7vw, 116px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: #FAF8F3;
    text-wrap: balance;
  }
  .section-split__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .section-split__subtitle {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 500;
    color: rgba(250, 248, 243, 0.78);
    margin: 24px 0 32px;
  }
  .section-split__subtitle-square {
    width: 14px;
    height: 14px;
    background: #FFD838;
    display: inline-block;
    flex: 0 0 auto;
  }

  .section-split__text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    line-height: 1.55;
    color: rgba(250, 248, 243, 0.88);
    margin: 0;
    max-width: 720px;
  }
</style>
