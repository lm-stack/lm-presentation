---
// src/components/slides/DataPipeline.astro
// Slide "pipeline de la donnée" : un flux horizontal d'étapes (Récolter ->
// Nettoyer -> Enrichir -> Injecter) où la MÊME donnée se transforme d'une carte
// à l'autre (brut -> propre -> enrichi -> fiche CRM). La dernière carte est la
// fiche CRM (destination, accentuée). Tags "Qualité" en rappel sur les étapes
// traitées au module précédent. Header + tokens calqués sur la famille Hero.
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';
interface Stage {
  num: string;
  verb: string;
  icon: string;
  desc: string;
  /** Lignes de données affichées dans la carte (l'état de l'enregistrement). */
  data: string[];
  /** Étape de récolte : données brutes (rendu monospace "en vrac"). */
  raw?: boolean;
  /** Étape d'enrichissement : les lignes sont des ajouts (accent + "+"). */
  added?: boolean;
  /** Pastille teaser (ex. "Qualité"). */
  tag?: string;
}
interface FicheField {
  label: string;
  value: string;
}
interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  /** Étapes de transformation (Récolter, Nettoyer, Enrichir). */
  stages: Stage[];
  /** Carte finale : la fiche CRM (étape Injecter). */
  result: {
    num: string;
    verb: string;
    icon: string;
    desc: string;
    title: string;
    fields: FicheField[];
  };
  /** Note de bas de slide (teaser, optionnelle). */
  note?: string;
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  stages,
  result,
  note,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="pipeline" data-layout="data-pipeline">
  <header class="pipeline__header">
    <div class="pipeline__brand-text">
      <p class="pipeline__brand-main">{brand}</p>
      {brandSub && <p class="pipeline__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="pipeline__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="pipeline__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="pipeline__body">
    {(title || subtitle) && (
      <div class="pipeline__heading">
        {title && (
          <h2 class="pipeline__title">
            {titleParts
              ? <>{titleParts.before}<em class="pipeline__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
              : title}
          </h2>
        )}
        {subtitle && <p class="pipeline__subtitle">{subtitle}</p>}
      </div>
    )}

    <div class="pipeline__flow">
      {stages.map((s) => (
        <>
          <article class="pipeline__stage">
            <div class="pipeline__stage-head">
              <span class="pipeline__stage-num">{s.num}</span>
              <Icon name={s.icon} class="pipeline__stage-icon" aria-hidden="true" />
              <span class="pipeline__stage-verb">{s.verb}</span>
              {s.tag && <span class="pipeline__stage-tag">{s.tag}</span>}
            </div>
            <div class:list={["pipeline__data", { "pipeline__data--raw": s.raw, "pipeline__data--added": s.added }]}>
              {s.data.map((line) => <span class="pipeline__data-line">{line}</span>)}
            </div>
            <p class="pipeline__stage-desc">{s.desc}</p>
          </article>
          <span class="pipeline__arrow" aria-hidden="true"><Icon name="ph:arrow-right" /></span>
        </>
      ))}

      <article class="pipeline__stage pipeline__stage--fiche">
        <div class="pipeline__stage-head">
          <span class="pipeline__stage-num">{result.num}</span>
          <Icon name={result.icon} class="pipeline__stage-icon" aria-hidden="true" />
          <span class="pipeline__stage-verb">{result.verb}</span>
        </div>
        <div class="pipeline__fiche">
          <span class="pipeline__fiche-title">{result.title}</span>
          <dl class="pipeline__fiche-fields">
            {result.fields.map((f) => (
              <div class="pipeline__fiche-row">
                <dt>{f.label}</dt>
                <dd>{f.value}</dd>
              </div>
            ))}
          </dl>
        </div>
        <p class="pipeline__stage-desc">{result.desc}</p>
      </article>
    </div>

    {note && <p class="pipeline__note">{note}</p>}
  </div>
</section>

<style>
  .pipeline {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .pipeline__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .pipeline__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .pipeline__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .pipeline__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Body : titre + flux + note, centrés comme un bloc. */
  .pipeline__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 36px;
  }
  .pipeline__heading {
    text-align: left;
  }
  .pipeline__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .pipeline__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .pipeline__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    margin: 12px 0 0;
    color: var(--c-muted);
    text-align: left;
    max-width: none;
  }

  /* Flux horizontal : cartes d'étape + flèches, la dernière est la fiche CRM. */
  .pipeline__flow {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 14px;
  }
  .pipeline__stage {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px 22px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  /* Fiche CRM : la destination, carte accentuée. */
  .pipeline__stage--fiche {
    background: color-mix(in srgb, var(--c-accent) 6%, var(--c-surface));
    border-color: color-mix(in srgb, var(--c-accent) 45%, transparent);
  }

  .pipeline__stage-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .pipeline__stage-num {
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-label);
    font-weight: 700;
    color: var(--c-accent);
    font-variant-numeric: tabular-nums;
  }
  .pipeline__stage-icon {
    width: 24px;
    height: 24px;
    color: var(--c-accent);
    flex: 0 0 auto;
  }
  .pipeline__stage-verb {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--c-ink);
  }
  .pipeline__stage-tag {
    margin-left: auto;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-accent);
    background: color-mix(in srgb, var(--c-accent) 12%, transparent);
    padding: 4px 10px;
    border-radius: 999px;
  }

  /* Boîte de données : l'état de l'enregistrement à cette étape. */
  .pipeline__data {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 16px 16px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--c-ink) 4%, var(--c-surface));
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .pipeline__data-line {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: 1.3;
    font-weight: 600;
    color: var(--c-ink);
    word-break: break-word;
  }
  /* Brut : monospace "en vrac", grisé, sur fond plus contrasté. */
  .pipeline__data--raw {
    background: color-mix(in srgb, var(--c-ink) 7%, var(--c-surface));
    border-style: dashed;
  }
  .pipeline__data--raw .pipeline__data-line {
    font-family: 'Space Grotesk', ui-monospace, Menlo, monospace;
    font-size: 19px;
    font-weight: 500;
    color: var(--c-muted);
  }
  /* Enrichi : les lignes sont des ajouts (accent, préfixe +). */
  .pipeline__data--added .pipeline__data-line {
    color: var(--c-accent);
    display: flex;
    gap: 7px;
  }
  .pipeline__data--added .pipeline__data-line::before {
    content: '+';
    font-weight: 800;
  }

  .pipeline__stage-desc {
    margin: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--c-muted);
  }

  /* Fiche CRM : mini-carte contact (titre + champs label/valeur). */
  .pipeline__fiche {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px 18px;
    border-radius: 4px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-accent) 32%, transparent);
  }
  .pipeline__fiche-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c-accent);
    padding-bottom: 10px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .pipeline__fiche-fields {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .pipeline__fiche-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .pipeline__fiche-row dt {
    flex: 0 0 auto;
    width: 92px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-source);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-muted);
  }
  .pipeline__fiche-row dd {
    flex: 1 1 auto;
    min-width: 0;
    margin: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    font-weight: 600;
    line-height: 1.25;
    color: var(--c-ink);
  }

  /* Flèche de flux entre deux cartes. */
  .pipeline__arrow {
    flex: 0 0 auto;
    align-self: center;
    display: flex;
  }
  .pipeline__arrow :global(svg) {
    width: 34px;
    height: 34px;
    color: var(--c-accent);
  }

  /* Note teaser, sous le flux. */
  .pipeline__note {
    margin: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-weight: 500;
    color: var(--c-muted);
    text-align: center;
  }
</style>
