---
// src/components/slides/DefinitionHero.astro
// Slide "definition" d'un concept, design dedie : terme en grand serif italique
// (accent souligne), definition en GROS texte avec une barre accent a gauche
// (signature visuelle), leger halo accent en haut a droite. Header marque
// standard. Texte volontairement plus grand qu'un corps de slide classique.
interface Props {
  /** Petit label au-dessus du terme. Defaut "Definition". */
  eyebrow?: string;
  /** Le terme defini, ex "Outil d'automation". */
  term: string;
  /** Portion du terme soulignee en accent. */
  termItalicPart?: string;
  /** La definition (gros texte, sous le terme). */
  definition: string;
  /** Image de fond optionnelle : floutee + voile clair (facon QuoteImage). */
  image?: string;
  brand?: string;
  brandSub?: string;
  tocLabel?: string;
}
import { splitHighlight } from '@/utils/highlight';
const {
  eyebrow = 'Définition',
  term,
  termItalicPart,
  definition,
  image,
  brand = 'Titre de la présentation',
  brandSub,
  tocLabel,
} = Astro.props;
const termParts = splitHighlight(term, termItalicPart);
---
<section class="definition-hero" data-layout="definition-hero" data-section-title={tocLabel ?? term}>
  {image && (
    <div class="definition-hero__bg" aria-hidden="true">
      <img src={image} alt="" loading="lazy" decoding="async" />
      <div class="definition-hero__overlay"></div>
    </div>
  )}
  <header class="definition-hero__header">
    <div class="definition-hero__brand-text">
      <p class="definition-hero__brand-main">{brand}</p>
      {brandSub && <p class="definition-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="definition-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="definition-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="definition-hero__body">
    <p class="definition-hero__eyebrow">
      <span class="definition-hero__eyebrow-square" aria-hidden="true"></span>{eyebrow}
    </p>
    <h2 class="definition-hero__term">
      {termParts
        ? <>{termParts.before}<span class="underline">{termParts.match}</span>{termParts.after}</>
        : term}
    </h2>
    <p class="definition-hero__definition">{definition}</p>
  </div>
</section>

<style>
  .definition-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background:
      radial-gradient(110% 70% at 100% 2%, color-mix(in srgb, var(--c-accent) 13%, transparent) 0%, transparent 52%),
      linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Fond image optionnel : floute + voile clair (facon QuoteImage). */
  .definition-hero__bg { position: absolute; inset: 0; z-index: 0; }
  .definition-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(14px) saturate(0.6);
    transform: scale(1.1);
  }
  .definition-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, color-mix(in srgb, var(--c-bg-start) 72%, transparent) 0%, color-mix(in srgb, var(--c-bg-end) 80%, transparent) 100%);
  }
  /* Contenu toujours au-dessus du fond image. */
  .definition-hero__header,
  .definition-hero__body { position: relative; z-index: 1; }

  /* Header standard (brand gauche + logo LM droite + border-bottom). */
  .definition-hero__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .definition-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .definition-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .definition-hero__brand-logo { height: 48px; width: auto; display: block; flex: 0 0 auto; }

  /* Corps centre verticalement dans l'espace sous le header. */
  .definition-hero__body {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
    max-width: 1500px;
  }
  .definition-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--c-muted);
    margin: 0;
  }
  .definition-hero__eyebrow-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    flex: 0 0 auto;
  }
  /* Terme defini : grand serif italique, accent souligne via .underline global. */
  .definition-hero__term {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
    font-size: var(--fs-term);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
    text-wrap: balance;
  }
  /* Definition : GROS texte, cale a gauche comme l'eyebrow et le terme. */
  .definition-hero__definition {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    color: var(--c-ink);
    margin: 0;
    max-width: 1240px;
  }

  .definition-hero__body > * {
    animation: definition-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .definition-hero__term { animation-delay: 0.1s; }
  .definition-hero__definition { animation-delay: 0.22s; }

  @keyframes definition-fade-up {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
