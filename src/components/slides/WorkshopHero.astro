---
// src/components/slides/WorkshopHero.astro
// Slide "Workshop" ExecEd-style : header full-width standard, à gauche le titre +
// un tableau label / valeur des infos clés, à droite une colonne (38%) avec un
// matrix rain "papier-pluie" (canvas, repris de CoverHero) surmonté du minuteur
// (TimerControl, centré, sans barre de progression). Charte LM light.
import TimerControl from '@/components/slides/TimerControl.astro';

interface WorkshopRow {
  label: string;
  value: string;
}
interface Props {
  subtitle?: string;
  rows: WorkshopRow[];
  /** Durée par défaut du minuteur, en minutes (temps de l'atelier). */
  defaultMinutes?: number;
  /** Durées proposées au minuteur, en minutes. */
  presets?: number[];
  brand?: string;
  brandSub?: string;
}
const {
  subtitle,
  rows,
  defaultMinutes = 20,
  presets = [5, 10, 15],
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="workshop-hero" data-layout="workshop-hero">
  <header class="workshop-hero__header">
    <div class="workshop-hero__brand-text">
      <p class="workshop-hero__brand-main">{brand}</p>
      {brandSub && <p class="workshop-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="workshop-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="workshop-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="workshop-hero__content">
    <div class="workshop-hero__rain-area">
      <canvas class="workshop-hero__rain" aria-hidden="true"></canvas>
      <svg class="workshop-hero__timer-circle" viewBox="0 0 100 100" aria-hidden="true">
        <circle class="workshop-hero__ring-track" cx="50" cy="50" r="46" pathLength="100"></circle>
        <circle class="workshop-hero__ring-fill" cx="50" cy="50" r="46" pathLength="100" data-ws-ring></circle>
      </svg>
      <div class="workshop-hero__timer">
        <TimerControl size="compact" center hideProgress presets={presets} allowCustom={true} defaultMinutes={defaultMinutes} />
      </div>
    </div>

    <div class="workshop-hero__main">
      <h2 class="workshop-hero__title">
        <em class="workshop-hero__title-italic"><span class="underline">Workshop</span></em>
      </h2>
      {subtitle && <p class="workshop-hero__subtitle">{subtitle}</p>}

      <dl class="workshop-hero__table">
        {rows.map((row) => (
          <div class="workshop-hero__row">
            <dt class="workshop-hero__label">{row.label}</dt>
            <dd class="workshop-hero__value">{row.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>

<script>
  // Matrix rain "papier-pluie" repris de CoverHero (initCoverHeroRain), renommé
  // pour rester un module isolé (pas de collision avec le script de CoverHero).
  function initWorkshopRain(canvas: HTMLCanvasElement) {
    const parent = canvas.parentElement;
    if (!parent) return;

    function sizeCanvas() {
      canvas.width = parent!.offsetWidth;
      canvas.height = parent!.offsetHeight;
    }
    sizeCanvas();
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const fontSize = 11;
    let W = canvas.width;
    let H = canvas.height;
    let cols = Math.floor(W / fontSize);
    let rows = Math.floor(H / fontSize);
    let centerX = W / 2;
    let centerY = H / 2;
    let maxRadius = Math.max(W, H) * 0.5;

    interface Cell { char: string; alpha: number; state: string; life: number; }
    let grid: Cell[][] = [];
    let drops: { row: number; speed: number }[] = [];
    let radialMask: number[][] = [];

    function rebuild() {
      W = canvas.width;
      H = canvas.height;
      cols = Math.floor(W / fontSize);
      rows = Math.floor(H / fontSize);
      centerX = W / 2;
      centerY = H / 2;
      maxRadius = Math.max(W, H) * 0.5;

      grid = [];
      drops = [];
      radialMask = [];
      for (let c = 0; c < cols; c++) {
        grid[c] = [];
        for (let r = 0; r < rows; r++) {
          grid[c][r] = { char: Math.random() > 0.5 ? '1' : '0', alpha: 0, state: 'off', life: 0 };
        }
        drops[c] = { row: Math.floor(Math.random() * -rows), speed: 1.0 + Math.random() * 0.8 };
      }
      for (let c = 0; c < cols; c++) {
        radialMask[c] = [];
        for (let r = 0; r < rows; r++) {
          const x = c * fontSize + fontSize / 2;
          const y = r * fontSize + fontSize / 2;
          const dx = x - centerX;
          const dy = y - centerY;
          const dist = Math.sqrt(dx * dx + dy * dy) / maxRadius;
          radialMask[c][r] = Math.max(0, 1 - dist * dist);
        }
      }
    }
    rebuild();

    function update() {
      for (let c = 0; c < cols; c++) {
        const drop = drops[c];
        const headRow = Math.floor(drop.row);
        if (headRow >= 0 && headRow < rows) {
          const cell = grid[c][headRow];
          if (cell.state === 'off') {
            cell.state = 'in';
            cell.alpha = 0;
            cell.char = Math.random() > 0.5 ? '1' : '0';
          }
        }
        drop.row += drop.speed;
        if (drop.row > rows + 10) {
          drop.row = Math.random() * -30 - 5;
          drop.speed = 1.0 + Math.random() * 0.8;
        }
      }
      for (let c = 0; c < cols; c++) {
        for (let r = 0; r < rows; r++) {
          const cell = grid[c][r];
          const peak = radialMask[c][r] * 0.45;
          if (cell.state === 'in') {
            cell.alpha += 0.04;
            if (cell.alpha >= peak) { cell.alpha = peak; cell.state = 'visible'; cell.life = 30 + Math.floor(Math.random() * 50); }
          } else if (cell.state === 'visible') {
            cell.life--;
            if (cell.life <= 0) cell.state = 'out';
          } else if (cell.state === 'out') {
            cell.alpha -= 0.02;
            if (cell.alpha <= 0) { cell.alpha = 0; cell.state = 'off'; }
          }
        }
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, W, H);
      ctx!.font = fontSize + 'px ui-monospace, "SF Mono", Menlo, monospace';
      ctx!.textBaseline = 'top';
      for (let c = 0; c < cols; c++) {
        for (let r = 0; r < rows; r++) {
          const cell = grid[c][r];
          if (cell.alpha <= 0) continue;
          ctx!.fillStyle = 'rgba(100, 104, 135, ' + cell.alpha.toFixed(3) + ')';
          ctx!.fillText(cell.char, c * fontSize, r * fontSize);
        }
      }
    }

    let running = true;
    const obs = new IntersectionObserver(([entry]) => {
      running = entry.isIntersecting;
    }, { threshold: 0 });
    obs.observe(canvas);

    const ro = new ResizeObserver(() => {
      sizeCanvas();
      rebuild();
    });
    ro.observe(parent);

    function loop() {
      if (running) { update(); draw(); }
      requestAnimationFrame(loop);
    }
    loop();
  }

  function initWorkshopRains() {
    document.querySelectorAll<HTMLCanvasElement>('.workshop-hero__rain').forEach((c) => {
      if (c.dataset.rainInit) return;
      c.dataset.rainInit = '1';
      initWorkshopRain(c);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkshopRains);
  } else {
    initWorkshopRains();
  }

  // Relie l'anneau de progression au minuteur : à chaque tick (event tc:tick
  // émis par TimerControl), on met à jour l'offset de l'arc (100 = vide, 0 = plein).
  function initWorkshopRings() {
    document.querySelectorAll<HTMLElement>('[data-layout="workshop-hero"]').forEach((slide) => {
      const ringFill = slide.querySelector<SVGCircleElement>('[data-ws-ring]');
      const timer = slide.querySelector<HTMLElement>('[data-timer-control]');
      if (!ringFill || !timer || timer.dataset.wsRingInit === 'true') return;
      timer.dataset.wsRingInit = 'true';
      timer.addEventListener('tc:tick', (e) => {
        const pct = (e as CustomEvent).detail?.pct ?? 0;
        ringFill.style.strokeDashoffset = String(Math.max(0, 100 - pct));
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkshopRings);
  } else {
    initWorkshopRings();
  }
</script>

<style>
  .workshop-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .workshop-hero__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .workshop-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .workshop-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .workshop-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .workshop-hero__content {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
  }

  /* Colonne droite : matrix rain en fond, minuteur centré dessus. */
  .workshop-hero__rain-area {
    position: absolute;
    top: 0;
    right: 0;
    width: 38%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px;
  }
  .workshop-hero__rain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .workshop-hero__timer {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 400px;
    /* Minuteur légèrement plus bas que le centre de l'anneau. */
    transform: translateY(34px);
  }
  /* Anneau jaune progressif autour du minuteur (piste + arc qui se remplit
     comme la barre de la Pause), posé sur le matrix rain. */
  .workshop-hero__timer-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(540px, 92%);
    aspect-ratio: 1;
    z-index: 0;
    overflow: visible;
  }
  .workshop-hero__ring-track {
    fill: none;
    stroke: color-mix(in srgb, var(--c-accent) 25%, transparent);
    stroke-width: 1.6;
  }
  .workshop-hero__ring-fill {
    fill: none;
    stroke: var(--c-accent);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transform: rotate(-90deg);
    transform-origin: 50% 50%;
    transition: stroke-dashoffset 0.9s linear;
  }

  .workshop-hero__main {
    position: relative;
    z-index: 1;
    width: 62%;
    height: 100%;
    padding: 28px 64px 56px 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }

  .workshop-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .workshop-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .workshop-hero__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: var(--space-title-lead) 0 0;
  }

  /* Tableau label / valeur. */
  .workshop-hero__table {
    margin: 80px 0 0;
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .workshop-hero__row {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 28px;
    align-items: baseline;
    padding: 16px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .workshop-hero__label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink);
  }
  .workshop-hero__value {
    margin: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    font-weight: 400;
    line-height: var(--lh-lead);
    color: var(--c-muted);
  }
</style>
