---
// src/components/slides/Custom.astro
// Slide d'escape hatch : prend du contenu MDX libre. Le prop `background` est conserve
// pour la retrocompat des MDX existants mais ignore visuellement (fond creme uniforme).
interface Props {
  background?: 'white' | 'dark' | 'gold';
  align?: 'top' | 'center' | 'bottom';
  class?: string;
}

const { align = 'top', class: extraClass } = Astro.props;

const classes = [
  'custom-slide',
  `custom-slide--align-${align}`,
  extraClass,
].filter(Boolean).join(' ');
---
<section class={classes} data-layout="custom">
  <slot />
</section>

<style>
  .custom-slide {
    width: 100%;
    height: 100%;
    background: var(--slide-bg, #FAF8F3);
    color: #6B6F84;
  }
  .custom-slide--align-top {
    justify-content: flex-start !important;
  }
  .custom-slide--align-center {
    justify-content: center !important;
    align-items: center !important;
  }
  .custom-slide--align-bottom {
    justify-content: flex-end !important;
  }
  .custom-slide :global(h1),
  .custom-slide :global(h2),
  .custom-slide :global(h3) {
    color: inherit;
  }
</style>
