---
// src/components/slides/ProgrammeHero.astro
// Slide « Agenda / Programme » : header ExecEd standard full-width
// (brand gauche + logo droite + border-bottom), puis split 70/30 sous
// le header (contenu liste numérotée Bungee Outline à gauche, image
// illustrative floutée à droite). Numéros 80px style AboutHero.
// Inspiration : slide « Index » du PPTX HEC ExecEd, transposée light.
import '@fontsource/bungee-outline/latin.css';

interface AgendaItem {
  title: string;
  description: string;
}
interface Props {
  title?: string;
  italicPart?: string;
  items: AgendaItem[];
  image?: string;
  brand?: string;
  brandSub?: string;
}
const {
  title = 'Agenda',
  italicPart,
  items,
  image,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="programme-hero" data-layout="programme-hero">
  {image && (
    <div class="programme-hero__image-area" aria-hidden="true">
      <img src={image} alt="" loading="lazy" decoding="async" />
      <div class="programme-hero__image-overlay"></div>
    </div>
  )}

  <header class="programme-hero__header">
    <div class="programme-hero__brand-text">
      <p class="programme-hero__brand-main">{brand}</p>
      {brandSub && <p class="programme-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="programme-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo-white-letter.svg" class="programme-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="programme-hero__main">
    <h2 class="programme-hero__title">
      {italicPart
        ? <>{title.split(italicPart)[0]}<em class="programme-hero__title-italic"><span class="underline">{italicPart}</span></em>{title.split(italicPart)[1]}</>
        : title}
    </h2>

    <ol class="programme-hero__list">
      {items.map((item, i) => (
        <li class="programme-hero__item">
          <span class="programme-hero__item-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="programme-hero__item-text">
            <h3 class="programme-hero__item-title">{item.title}</h3>
            <p class="programme-hero__item-desc">{item.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .programme-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, #FFFFFF 0%, #EFEFF2 100%);
    color: #191919;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Image latérale floutée subtilement, en absolu sur la droite,
     full hauteur — passe DERRIÈRE le header et la zone main left. */
  .programme-hero__image-area {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 38%;
    z-index: 0;
    overflow: hidden;
  }
  .programme-hero__image-area img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px) saturate(0.7);
    transform: scale(1.08);
  }
  .programme-hero__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.2) 100%);
  }

  /* Header full-width, intangible — règle absolue dans CLAUDE.md.
     z-index 1 pour rester au-dessus de l'image qui passe en dessous. */
  .programme-hero__header {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 64px 96px 24px;
    border-bottom: 1px solid rgba(25, 25, 25, 0.12);
  }
  .programme-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: #191919;
    text-align: left;
  }
  .programme-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: #6B6F84;
    text-align: left;
  }
  .programme-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Main content : 68% à gauche (l'image absolue couvre le 32% droit).
     z-index 1 pour rester au-dessus de l'image qui passe en dessous. */
  .programme-hero__main {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    width: 62%;
    padding: 32px 96px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    gap: 72px;
  }

  .programme-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(64px, 6vw, 96px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: #191919;
    text-align: left;
  }
  .programme-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .programme-hero__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .programme-hero__item {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  /* Numéros Bungee Outline 80px, pattern identique à AboutHero */
  .programme-hero__item-num {
    font-family: 'Bungee Outline', sans-serif;
    font-weight: 400;
    font-size: 80px;
    line-height: 1;
    color: #191919;
    letter-spacing: 0;
    flex: 0 0 auto;
    min-width: 110px;
  }
  .programme-hero__item-text {
    flex: 1 1 auto;
    min-width: 0;
  }
  .programme-hero__item-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 6px;
    color: #191919;
    text-align: left;
  }
  .programme-hero__item-desc {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    line-height: 1.45;
    margin: 0;
    color: #6B6F84;
  }

</style>
