---
// src/components/slides/Workshop.astro
// Transition pleine "Workshop" : annonce visuellement qu'un atelier
// arrive. Calque sur Section avec substitution du numero par l'icone
// Phosphor pencil-simple-line et la couleur d'accent vert.
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';

interface Props {
  title: string;
  subtitle?: string;
  highlight?: string;
  eyebrow?: string;
}

const { title, subtitle, highlight, eyebrow = 'Workshop' } = Astro.props;

const titleParts = splitHighlight(title, highlight);
---
<section
  class="convention-transition convention-transition--workshop"
  data-layout="workshop"
  data-section-title={title}
>
  <span class="convention-transition__wash" aria-hidden="true"></span>
  <span class="convention-transition__watermark" aria-hidden="true">
    <Icon name="ph:pencil-simple-line-bold" />
  </span>

  <div class="convention-transition__inner">
    <p class="convention-transition__eyebrow">{eyebrow}</p>
    <h2 class="convention-transition__title">
      {titleParts
        ? <>{titleParts.before}<span class="convention-transition__mark">{titleParts.match}</span>{titleParts.after}</>
        : title}
    </h2>
    {subtitle && <p class="convention-transition__subtitle">{subtitle}</p>}
  </div>

  <span class="convention-transition__rule" aria-hidden="true"></span>
</section>

<style>
  .convention-transition--workshop {
    --accent: #2EC27E;
    --accent-soft: rgba(46, 194, 126, 0.32);
    --accent-ink: #0E5C3B;
  }

  .convention-transition {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 96px 96px !important;
    background: var(--slide-bg, #FAF8F3);
    color: #191919;
    display: flex !important;
    flex-direction: column;
    justify-content: center !important;
  }

  /* Wash radial colore bottom-left, plus dense qu'un Section habituel */
  .convention-transition__wash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 0% 100%, var(--accent-soft) 0%, transparent 55%);
    z-index: 0;
  }

  /* Icone monumentale a droite, fadant vers le bord. Substitue le numero */
  /* du Section : meme placement, meme echelle, mais glyph vectoriel. */
  .convention-transition__watermark {
    position: absolute;
    top: 50%;
    right: -48px;
    transform: translateY(-50%);
    width: 880px;
    height: 880px;
    color: var(--accent);
    opacity: 0.18;
    user-select: none;
    pointer-events: none;
    z-index: 0;
    -webkit-mask-image: linear-gradient(to right, #000 30%, rgba(0, 0, 0, 0.4) 100%);
    mask-image: linear-gradient(to right, #000 30%, rgba(0, 0, 0, 0.4) 100%);
    animation: ct-watermark 1.1s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
  }
  .convention-transition__watermark :global(svg) {
    width: 100%;
    height: 100%;
  }

  .convention-transition__inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    animation: ct-stagger 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Eyebrow pill : fond accent colore, bord noir, texte noir. Different */
  /* du Section (qui pose le pill en gold) : signale visuellement qu'on  */
  /* sort du rythme normal du deck. */
  .convention-transition__eyebrow {
    display: inline-block;
    font-family: 'Space Grotesk', monospace;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: #191919;
    margin: 0 0 32px;
    padding: 8px 16px;
    background: var(--accent);
    border: 2px solid #191919;
    border-radius: 4px;
    box-shadow: 4px 4px 0 0 #191919;
  }

  .convention-transition__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 800;
    font-size: clamp(80px, 9vw, 160px);
    line-height: 0.92;
    letter-spacing: -0.035em;
    color: #191919;
    margin: 0 0 28px;
    text-align: left;
    text-wrap: balance;
  }

  /* Marqueur signature : on garde la bande noire rotative comme Section. */
  /* L'identite LM reste lisible meme dans la rupture chromatique.       */
  .convention-transition__mark {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .convention-transition__mark::after {
    content: '';
    position: absolute;
    left: -6px;
    right: -6px;
    bottom: 4px;
    height: 11px;
    background: #191919;
    z-index: -1;
    transform: rotate(-1.5deg);
  }

  .convention-transition__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 28px;
    font-weight: 500;
    line-height: 1.4;
    color: #6B6F84;
    margin: 0;
    max-width: 1100px;
  }

  /* Rule basse gold : signature LM, ancre l'ensemble. */
  .convention-transition__rule {
    position: absolute;
    left: 96px;
    bottom: 80px;
    width: 96px;
    height: 6px;
    background: #FFD838;
    z-index: 1;
  }

  @keyframes ct-stagger {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes ct-watermark {
    from { opacity: 0; transform: translateY(-50%) translateX(40px) scale(0.92); }
    to { opacity: 0.18; transform: translateY(-50%) translateX(0) scale(1); }
  }
</style>
