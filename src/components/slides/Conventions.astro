---
// src/components/slides/Conventions.astro
// Slide a contenu qui expose les 3 conventions visuelles du deck :
// Echange, Demo, Workshop. Header marque + logo LM (RÈGLE), fond pearl, titre
// body (portion serif italique soulignee) + sous-titre, puis 3 cartes a grand
// disc colore. Les couleurs des conventions (--accent par carte) sont des
// couleurs semantiques de signalisation, passees en data (item.color).
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';

interface Convention {
  icon: string;
  label: string;
  description: string;
  /** Couleur de signalisation de la convention (semantique, passee en data). */
  color: string;
}

interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  items?: Convention[];
  brand?: string;
  brandSub?: string;
}

const DEFAULT_ITEMS: Convention[] = [
  {
    icon: 'ph:chats-circle-fill',
    label: 'Échange',
    description: 'Prenez la parole quand ce pictogramme apparaît : partage d\'expérience, retour critique, anecdote terrain.',
    color: '#E53E5E',
  },
  {
    icon: 'ph:cursor-click-fill',
    label: 'Démo',
    description: 'Une démonstration en direct va suivre : outil en ligne, requête API, écran à observer ensemble.',
    color: '#5BA8D6',
  },
  {
    icon: 'ph:pencil-simple-line-bold',
    label: 'Workshop',
    description: 'Un atelier hands-on commence : exercice individuel ou en sous-groupe, livrable concret en sortie.',
    color: '#2EC27E',
  },
];

const {
  title = 'Conventions du support',
  italicPart = 'pictogrammes',
  subtitle = 'Trois pictogrammes balisent les moments clés du cours.',
  items = DEFAULT_ITEMS,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="conventions" data-layout="conventions">
  <header class="conventions__header">
    <div class="conventions__brand-text">
      <p class="conventions__brand-main">{brand}</p>
      {brandSub && <p class="conventions__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="conventions__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="conventions__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="conventions__body">
    <div class="conventions__heading">
      <h2 class="conventions__title">
        {titleParts
          ? <>{titleParts.before}<em class="conventions__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="conventions__subtitle">{subtitle}</p>}
    </div>

    <div class="conventions__grid">
      {items.map((item, i) => (
        <article class="conventions__card" style={`--accent: ${item.color}; --i: ${i}`}>
          <span class="conventions__halo" aria-hidden="true"></span>
          <span class="conventions__disc" aria-hidden="true">
            <Icon name={item.icon} />
          </span>
          <h3 class="conventions__label">{item.label}</h3>
          <p class="conventions__description">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .conventions {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom (RÈGLE). */
  .conventions__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .conventions__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .conventions__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .conventions__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .conventions__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 48px;
    padding-top: 28px;
  }
  .conventions__heading { flex: 0 0 auto; }
  .conventions__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .conventions__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .conventions__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 12px 0 0;
    max-width: none;
    text-align: left;
  }

  .conventions__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    width: 100%;
  }

  /* Carte verticale : grand cercle colore avec icone, label, description.
     --accent = couleur de signalisation de la convention (data). */
  .conventions__card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 44px 32px 32px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 6%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    overflow: hidden;
    animation: conv-card 0.7s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i, 0) * 0.12s + 0.1s) both;
  }

  .conventions__halo {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, var(--accent) 0%, transparent 65%);
    opacity: 0.18;
    z-index: 0;
    pointer-events: none;
  }

  /* Disc central : meme glyph que les transitions. Bord + ombre dure ink = */
  /* element graphique plat signature (pas une elevation soft).            */
  .conventions__disc {
    position: relative;
    z-index: 1;
    width: 144px;
    height: 144px;
    border-radius: 50%;
    background: var(--accent);
    border: 4px solid var(--c-ink);
    box-shadow: 8px 8px 0 0 var(--c-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    margin-bottom: 36px;
    animation: conv-pop 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) calc(var(--i, 0) * 0.12s + 0.3s) both;
  }
  .conventions__disc :global(svg) {
    width: 72px;
    height: 72px;
  }

  .conventions__label {
    position: relative;
    z-index: 1;
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-card-title);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-ink);
    margin: 0 0 18px;
  }

  .conventions__description {
    position: relative;
    z-index: 1;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    font-weight: 400;
    line-height: var(--lh-lead);
    color: var(--c-muted);
    margin: 0;
    max-width: 420px;
  }

  @keyframes conv-card {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes conv-pop {
    from { opacity: 0; transform: scale(0.6) rotate(-8deg); }
    to { opacity: 1; transform: scale(1) rotate(0deg); }
  }
</style>
