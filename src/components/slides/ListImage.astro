---
// src/components/slides/ListImage.astro
// "Liste sur image" ExecEd-style, transposition LIGHT du slide listing HEC :
// header full-width (brand + logo + border pleine largeur), à gauche titre serif
// italique partiel + sous-titre (carré jaune) + paragraphe, à droite une pile de
// cards (label + titre) posées sur une image floutée. Charte LM light (pas de
// fond dark : fond pearl + voile clair sur l'image).
import { splitHighlight } from '@/utils/highlight';
interface ListItem {
  /** Petit sur-titre de la card, ex "Module 1". */
  label?: string;
  title: string;
  /** Portion du titre rendue en italique serif. */
  italicPart?: string;
  /** Ligne d'objectif affichée sous le titre de la card. */
  objective?: string;
  /** Met la card en avant (cadre jaune) + puce "Vous êtes ici". */
  current?: boolean;
}
interface Props {
  title: string;
  italicPart?: string;
  /** Force la partie italique du titre sur sa propre ligne (saut de ligne). */
  titleBreak?: boolean;
  subtitle?: string;
  /** Trois compteurs affichés en gros KPI (remplace le sous-titre textuel). */
  kpis?: { value: string; label: string }[];
  body?: string;
  /** Image de fond (floutée) de la colonne droite. */
  image: string;
  items: ListItem[];
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  titleBreak = false,
  subtitle,
  kpis,
  body,
  image,
  items,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="list-image" data-layout="list-image">
  <div class="list-image__image" aria-hidden="true">
    <img src={image} alt="" loading="lazy" decoding="async" />
    <div class="list-image__image-overlay"></div>
  </div>

  <header class="list-image__header">
    <div class="list-image__brand-text">
      <p class="list-image__brand-main">{brand}</p>
      {brandSub && <p class="list-image__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="list-image__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo-white-letter.svg" class="list-image__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="list-image__content">
    <div class="list-image__left">
      <h2 class:list={['list-image__title', { 'list-image__title--break': titleBreak }]}>
        {titleParts
          ? <>{titleParts.before}<em class="list-image__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && (
        <p class="list-image__subtitle">{subtitle}</p>
      )}
      {body && <p class="list-image__body">{body}</p>}
      {kpis && kpis.length > 0 && (
        <ul class="list-image__kpis">
          {kpis.map((k) => (
            <li class="list-image__kpi">
              <span class="list-image__kpi-value">{k.value}</span>
              <span class="list-image__kpi-rule" aria-hidden="true"></span>
              <span class="list-image__kpi-label">{k.label}</span>
            </li>
          ))}
        </ul>
      )}
    </div>

    <div class="list-image__right">
      <ol class="list-image__cards">
        {items.map((item) => (
          <li class={`list-image__card${item.current ? ' is-current' : ''}`}>
            {(item.label || item.current) && (
              <span class="list-image__card-label">
                {item.label}
                {item.current && <span class="list-image__card-here">Vous êtes ici</span>}
              </span>
            )}
            <span class="list-image__card-title">
              {(() => {
                const ip = splitHighlight(item.title, item.italicPart);
                return ip ? <>{ip.before}<em>{ip.match}</em>{ip.after}</> : item.title;
              })()}
            </span>
            {item.objective && <span class="list-image__card-obj">{item.objective}</span>}
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .list-image {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width intangible (border-bottom pleine largeur). */
  .list-image__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .list-image__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .list-image__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .list-image__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Sous le header : texte à gauche (58%), pile de cards sur image à droite (42%). */
  .list-image__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
  }

  .list-image__left {
    position: relative;
    z-index: 1;
    width: 58%;
    padding: 40px 56px 64px 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }
  .list-image__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .list-image__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  /* titleBreak : la partie italique passe sur sa propre ligne. */
  .list-image__title--break .list-image__title-italic {
    display: block;
  }
  .list-image__subtitle {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 28px 0 0;
  }
  .list-image__subtitle-square {
    width: 14px;
    height: 14px;
    background: var(--c-accent);
    display: inline-block;
    flex: 0 0 auto;
  }
  .list-image__body {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    font-weight: 400;
    line-height: var(--lh-body);
    color: var(--c-muted);
    margin: 28px 0 0;
    max-width: var(--measure-m);
  }

  /* Rangée de gros KPI (remplace le sous-titre textuel sur la slide du CAS). */
  .list-image__kpis {
    list-style: none;
    margin: 160px 0 0;
    padding: 0;
    display: flex;
    gap: 48px;
  }
  /* Colonnes KPI de largeur égale, contenu aligné à gauche : espacement visuel
     identique entre chaque KPI, quelle que soit la largeur du label. */
  .list-image__kpi {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    width: 140px;
    text-align: left;
  }
  /* Grand chiffre KPI : exception de taille assumée (chiffre géant, sans token). */
  .list-image__kpi-value {
    font-family: 'Space Grotesk', 'Hanken Grotesk', sans-serif;
    font-size: clamp(56px, 5vw, 84px);
    font-weight: 700;
    line-height: 0.95;
    color: var(--c-ink);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
  }
  .list-image__kpi-rule {
    width: 40px;
    height: 4px;
    background: var(--c-accent);
    border-radius: 2px;
  }
  .list-image__kpi-label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-muted);
  }

  /* Colonne droite : image floutée en fond + voile clair, cards posées dessus. */
  .list-image__right {
    position: relative;
    width: 42%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
    padding: 40px 56px;
    min-height: 0;
  }
  .list-image__image {
    position: absolute;
    top: 0;
    right: 0;
    width: 42%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }
  .list-image__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px) saturate(0.7);
    transform: scale(1.08);
  }
  .list-image__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.2) 100%);
  }

  .list-image__cards {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .list-image__card {
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 16px 24px;
    text-align: center;
  }
  .list-image__card-label {
    display: block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-muted);
    margin-bottom: 4px;
  }
  .list-image__card-title {
    display: block;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-card-title);
    font-weight: 700;
    line-height: 1.2;
    color: var(--c-ink);
  }
  .list-image__card-title em {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  /* Objectif sous le titre de la card (un objectif par module). */
  .list-image__card-obj {
    display: block;
    margin-top: 8px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-body);
    font-weight: 400;
    line-height: var(--lh-body);
    color: var(--c-muted);
  }

  /* Card mise en avant : le module courant du parcours. */
  .list-image__card.is-current {
    border-color: var(--c-accent);
    background: color-mix(in srgb, var(--c-accent) 8%, var(--c-surface));
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .list-image__card-here {
    display: inline-block;
    margin-left: 10px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-on-accent);
    background: var(--c-accent);
    border-radius: 4px;
    padding: 2px 8px;
    vertical-align: middle;
  }
</style>
