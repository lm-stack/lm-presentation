---
// src/components/slides/FormHero.astro
// Slide "formulaire" ExecEd-style : header standard (brand + logo + border,
// 44/40), à gauche titre + contexte, à droite une maquette de formulaire
// (champs + bouton). Maquette statique (pas d'inputs interactifs, pour ne pas
// capter le clavier de Reveal). Charte LM light.
interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  /** Libellés des champs affichés. */
  fields?: string[];
  /** Libellé du bouton. */
  button?: string;
  brand?: string;
  brandSub?: string;
}
const {
  title = 'Un formulaire',
  italicPart,
  subtitle,
  fields = ['Nom', 'Prénom', 'Email'],
  button = 'Envoyer',
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="form-hero" data-layout="form-hero">
  <header class="form-hero__header">
    <div class="form-hero__brand-text">
      <p class="form-hero__brand-main">{brand}</p>
      {brandSub && <p class="form-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="form-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="form-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="form-hero__content">
    <div class="form-hero__text">
      <h2 class="form-hero__title">
        {italicPart
          ? <>{title.split(italicPart)[0]}<em class="form-hero__title-italic"><span class="underline">{italicPart}</span></em>{title.split(italicPart)[1]}</>
          : title}
      </h2>
      {subtitle && <p class="form-hero__subtitle">{subtitle}</p>}
    </div>

    <div class="form-hero__card" aria-hidden="true">
      {fields.map((f) => (
        <div class="form-hero__field">
          <span class="form-hero__label">{f}</span>
          <span class="form-hero__input"></span>
        </div>
      ))}
      <span class="form-hero__button">{button}</span>
    </div>
  </div>
</section>

<style>
  .form-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .form-hero__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .form-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .form-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .form-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .form-hero__content {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    gap: 96px;
  }
  .form-hero__text {
    flex: 1 1 0;
    min-width: 0;
  }
  .form-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(56px, 5.6vw, 96px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .form-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .form-hero__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    line-height: 1.45;
    font-weight: 400;
    color: var(--c-muted);
    margin: 28px 0 0;
    max-width: 640px;
  }

  /* Maquette de formulaire. */
  .form-hero__card {
    flex: 0 0 auto;
    width: 620px;
    max-width: 46%;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--c-ink) 12%, transparent);
    padding: 48px 48px 44px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-hero__field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .form-hero__label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--c-ink);
  }
  .form-hero__input {
    height: 56px;
    border: 1px solid color-mix(in srgb, var(--c-ink) 18%, transparent);
    border-radius: 4px;
    background: var(--c-cream);
    display: block;
  }
  .form-hero__button {
    margin-top: 8px;
    align-self: stretch;
    text-align: center;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--c-on-accent);
    background: var(--c-accent);
    border-radius: 4px;
    padding: 16px 28px;
  }
</style>
