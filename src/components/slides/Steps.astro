---
// src/components/slides/Steps.astro
// Liste numérotée "ExecEd-style" : header full-width standard (brand gauche +
// logo LM droite + border-bottom pleine largeur), puis sous le header un split
// 62/38 : cards numérotées (gros chiffre Bungee Outline) à gauche qui débordent
// volontairement sur l'image (ou le motif damier) à droite.
// Inspiration slide 30 du PPTX ExecEd (Public cible).
import '@fontsource/bungee-outline/latin.css';
import { splitHighlight } from '@/utils/highlight';

interface NumberedItem {
  /** Texte ou titre de l'item. */
  text: string;
}
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  items: NumberedItem[];
  /** Numéro de départ du décompte (défaut 1). Permet de continuer la numérotation
   *  d'un slide à l'autre (ex. 04, 05, 06 sur un second slide qui prolonge le premier). */
  start?: number;
  /** Image décorative affichée à droite (sinon motif damier). */
  image?: string;
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  items,
  start = 1,
  image,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="steps" data-layout="steps">
  {image
    ? <div class="steps__image" aria-hidden="true"><img src={image} alt="" loading="lazy" decoding="async" /><div class="steps__image-overlay"></div></div>
    : <div class="steps__bg-right" aria-hidden="true"></div>}

  <header class="steps__header">
    <div class="steps__brand-text">
      <p class="steps__brand-main">{brand}</p>
      {brandSub && <p class="steps__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="steps__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo-white-letter.svg" class="steps__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="steps__content">
    <div class="steps__main">
      <h2 class="steps__title">
        {titleParts
          ? <>{titleParts.before}<em class="steps__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>

      {subtitle && (
        <p class="steps__subtitle">{subtitle}</p>
      )}

      <ol class="steps__list">
        {items.map((item, i) => (
          <li class="steps__item">
            <span class="steps__number">{String(i + start).padStart(2, '0')}</span>
            <p class="steps__item-text">{item.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .steps {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width intangible : brand gauche + logo LM droite + border-bottom
     pleine largeur. z-index 2 pour rester au-dessus de l'image et des cards.
     Les colonnes (texte + image) commencent EN DESSOUS. */
  .steps__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .steps__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .steps__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .steps__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Zone de contenu sous le header : texte à gauche (62%), image/damier
     à droite (38%, en absolu, derrière). */
  .steps__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
  }

  .steps__image,
  .steps__bg-right {
    position: absolute;
    top: 0;
    right: 0;
    width: 38%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }
  .steps__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px) saturate(0.7);
    transform: scale(1.08);
  }
  .steps__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.2) 100%);
  }
  .steps__bg-right {
    background-image:
      linear-gradient(45deg, color-mix(in srgb, var(--c-ink) 5%, transparent) 25%, transparent 25%),
      linear-gradient(-45deg, color-mix(in srgb, var(--c-ink) 5%, transparent) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, color-mix(in srgb, var(--c-ink) 5%, transparent) 75%),
      linear-gradient(-45deg, transparent 75%, color-mix(in srgb, var(--c-ink) 5%, transparent) 75%);
    background-size: 24px 24px;
    background-position: 0 0, 0 12px, 12px -12px, -12px 0;
  }

  /* Bloc texte à gauche (62%), centré verticalement, au-dessus de l'image. */
  .steps__main {
    position: relative;
    z-index: 1;
    width: 62%;
    height: 100%;
    padding: 32px 96px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }

  .steps__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-l);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .steps__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .steps__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 24px 0 64px;
  }

  /* Les cards débordent volontairement vers la droite, par-dessus l'image
     (ou le motif damier en l'absence d'image). z-index 1 du bloc gauche les
     fait passer au-dessus du fond ; l'overflow hidden coupe au bord de slide. */
  .steps__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 132%;
  }
  .steps__item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 18px 28px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  /* Numéros en Bungee Outline, identiques au slide Agenda (Programme)
     et à About : gros chiffre contour, sans pastille. */
  .steps__number {
    flex: 0 0 auto;
    min-width: 100px;
    font-family: 'Bungee Outline', sans-serif;
    font-weight: 400;
    font-size: 80px;
    line-height: 1;
    letter-spacing: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .steps__item-text {
    flex: 1 1 auto;
    margin: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    color: var(--c-ink);
  }
</style>
