---
// src/components/slides/AgendaLight.astro
// Agenda compact, 4 a 6 points + image editoriale a droite. Header marque +
// logo LM (RÈGLE), fond pearl, titre body + sous-titre, puis timeline accent
// verticale a gauche et figure portrait a droite. Tokenise.
import { splitHighlight } from '@/utils/highlight';

interface Item {
  time?: string;
  title: string;
  description?: string;
}

interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  eyebrow?: string;
  items: Item[];
  image?: string;
  imageAlt?: string;
  imageCaption?: string;
  brand?: string;
  brandSub?: string;
}

const {
  title = 'Agenda',
  italicPart,
  subtitle,
  eyebrow = 'Programme',
  items,
  image,
  imageAlt = '',
  imageCaption,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;

// Clamp a 6 points max pour preserver la respiration.
const safeItems = items.slice(0, 6);
const titleParts = splitHighlight(title, italicPart);
---
<section class="agenda-light" data-layout="agenda-light">
  <header class="agenda-light__header">
    <div class="agenda-light__brand-text">
      <p class="agenda-light__brand-main">{brand}</p>
      {brandSub && <p class="agenda-light__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="agenda-light__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="agenda-light__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="agenda-light__body">
    <div class="agenda-light__heading">
      <h2 class="agenda-light__title">
        {titleParts
          ? <>{titleParts.before}<em class="agenda-light__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="agenda-light__subtitle">{subtitle}</p>}
    </div>

    <div class="agenda-light__grid">
      <div class="agenda-light__list-wrap">
        {eyebrow && <span class="agenda-light__eyebrow">{eyebrow}</span>}
        <ol class="agenda-light__list" style={`--count: ${safeItems.length};`}>
          {safeItems.map((item, i) => (
            <li class="agenda-light__item">
              <span class="agenda-light__node" aria-hidden="true"></span>
              <div class="agenda-light__head">
                <span class="agenda-light__num">{String(i + 1).padStart(2, '0')}</span>
                {item.time && <span class="agenda-light__time">{item.time}</span>}
              </div>
              <div class="agenda-light__item-body">
                <h3 class="agenda-light__item-title">{item.title}</h3>
                {item.description && (
                  <p class="agenda-light__desc">{item.description}</p>
                )}
              </div>
            </li>
          ))}
        </ol>
      </div>

      {image && (
        <figure class="agenda-light__figure">
          <span class="agenda-light__figure-tag" aria-hidden="true">AGENDA</span>
          <img src={image} alt={imageAlt} loading="lazy" decoding="async" />
          {imageCaption && (
            <figcaption class="agenda-light__caption">{imageCaption}</figcaption>
          )}
        </figure>
      )}
    </div>
  </div>
</section>

<style>
  .agenda-light {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom (RÈGLE). */
  .agenda-light__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .agenda-light__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .agenda-light__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .agenda-light__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .agenda-light__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    padding-top: 28px;
  }
  .agenda-light__heading { flex: 0 0 auto; }
  .agenda-light__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .agenda-light__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .agenda-light__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 12px 0 0;
    max-width: var(--measure-l);
    text-align: left;
  }

  .agenda-light__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: 80px;
    width: 100%;
    align-items: stretch;
  }
  .agenda-light__list-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .agenda-light__eyebrow {
    display: inline-block;
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-source);
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-on-accent);
    padding: 6px 12px;
    background: var(--c-accent);
    margin-bottom: 28px;
    align-self: flex-start;
  }

  /* Liste : rail vertical accent en pseudo-element, noeuds ink sur chaque item. */
  .agenda-light__list {
    list-style: none;
    margin: 0;
    padding: 0 0 0 56px;
    position: relative;
  }
  .agenda-light__list::before {
    content: '';
    position: absolute;
    left: 21px;
    top: 14px;
    bottom: 14px;
    width: 3px;
    background: var(--c-accent);
    border-radius: 2px;
  }
  .agenda-light__item {
    position: relative;
    padding: 14px 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4px;
  }
  .agenda-light__item + .agenda-light__item {
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
  }
  .agenda-light__node {
    position: absolute;
    left: -47px;
    top: 24px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--c-ink);
    border: 3px solid var(--c-bg-start);
    box-shadow: 0 0 0 2px var(--c-ink);
  }
  .agenda-light__head {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  .agenda-light__num {
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-source);
    font-weight: 700;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--c-ink) 35%, transparent);
    font-feature-settings: 'tnum';
  }
  .agenda-light__time {
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-source);
    font-weight: 700;
    color: var(--c-ink);
    background: color-mix(in srgb, var(--c-ink) 6%, transparent);
    padding: 3px 10px;
    border-radius: 3px;
    font-feature-settings: 'tnum';
    letter-spacing: 0.02em;
  }
  .agenda-light__item-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    font-weight: 700;
    color: var(--c-ink);
    margin: 6px 0 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .agenda-light__desc {
    font-size: var(--fs-body);
    color: var(--c-muted);
    margin: 4px 0 0;
    line-height: var(--lh-body);
    max-width: var(--measure-s);
  }

  /* Image editoriale a droite : portrait, fond ink, label vertical "AGENDA". */
  .agenda-light__figure {
    position: relative;
    margin: 0;
    align-self: center;
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--c-ink);
    padding: 14px;
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 10%, transparent);
  }
  .agenda-light__figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 2px;
    filter: grayscale(0.15) contrast(1.05);
  }
  .agenda-light__figure-tag {
    position: absolute;
    top: 50%;
    left: -28px;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center;
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-source);
    font-weight: 700;
    letter-spacing: 0.4em;
    color: var(--c-on-accent);
    background: var(--c-accent);
    padding: 6px 14px;
    white-space: nowrap;
  }
  .agenda-light__caption {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 24px;
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-source);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FFFFFF;
    text-align: center;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }
</style>
