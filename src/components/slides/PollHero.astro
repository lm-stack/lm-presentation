---
// src/components/slides/PollHero.astro
// Variante ExecEd-style du composant Poll : header full-width brand + logo LM,
// titre question en serif italique partiel optionnel, fond pearl-stone, charte
// border-radius 4px et drop-shadows légères. Conserve à l'identique tous les
// hooks JS data-poll-* utilisés par src/scripts/deck/polls.ts (états initial /
// live / frozen / archived, QR, code, URL, counter, boutons start/freeze/reset).
import { splitHighlight } from '@/utils/highlight';
interface Props {
  id: string;
  question: string;
  options: string[];
  /** Mot ou segment de la question rendu en italique serif. Optionnel. */
  italicPart?: string;
  /** Sous-titre optionnel (consigne de vote, ex "Une seule réponse"). */
  subtitle?: string;
  brand?: string;
  brandSub?: string;
}

const {
  id,
  question,
  options,
  italicPart,
  subtitle,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(question, italicPart);

if (options.length < 2 || options.length > 6) {
  throw new Error(`PollHero "${id}" : options doit contenir 2 à 6 entrées, reçu ${options.length}`);
}
---
<section
  class="poll-hero"
  data-layout="poll-hero"
  data-section-title={question.slice(0, 60)}
  data-poll-id={id}
  data-poll-type="choice"
  data-poll-question={question}
  data-poll-options={JSON.stringify(options)}
>
  <header class="poll-hero__header">
    <div class="poll-hero__brand">
      <p class="poll-hero__brand-main">{brand}</p>
      {brandSub && <p class="poll-hero__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="poll-hero__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="poll-hero__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="poll-hero__body">
    <div class="poll-hero__heading">
      <h2 class="poll-hero__title">
        {titleParts
          ? <>{titleParts.before}<em class="poll-hero__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : question}
      </h2>
      {subtitle && <p class="poll-hero__subtitle">{subtitle}</p>}
    </div>

    <div class="poll-hero__grid">
      <div class="poll-hero__chart" data-poll-chart>
        {options.map((opt, i) => (
          <div class="poll-hero__bar-row" data-bar-index={i}>
            <span class="poll-hero__bar-label">{opt}</span>
            <div class="poll-hero__bar-track">
              <div class="poll-hero__bar-fill" data-bar-fill style="width: 0%"></div>
            </div>
            <span class="poll-hero__bar-count" data-bar-count>0</span>
          </div>
        ))}
      </div>

      <div class="poll-hero__side" data-poll-side>
        <div class="poll-hero__initial" data-poll-state="initial" hidden>
          <button type="button" class="poll-hero__start-btn presenter-only" data-poll-start>
            Démarrer le sondage
          </button>
          <div class="poll-waiting viewer-only">En attente de l'animateur</div>
        </div>

        <div class="poll-hero__live" data-poll-state="live" hidden>
          <div class="poll-hero__qr" data-poll-qr></div>
          <div class="poll-hero__code" data-poll-code>------</div>
          <div class="poll-hero__url" data-poll-url>slides.lausanne.marketing/v/------</div>
          <div class="poll-hero__counter" data-poll-counter>0 votes</div>
          <div class="poll-hero__actions presenter-only">
            <button type="button" class="poll-hero__action-btn" data-poll-freeze title="Figer">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
                <path d="M208 80h-32V56a48 48 0 0 0-96 0v24H48a16 16 0 0 0-16 16v112a16 16 0 0 0 16 16h160a16 16 0 0 0 16-16V96a16 16 0 0 0-16-16M96 56a32 32 0 0 1 64 0v24H96Z"/>
              </svg>
            </button>
            <button type="button" class="poll-hero__action-btn" data-poll-reset title="Reset">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
                <path d="M197.67 186.37a8 8 0 0 1 0 11.29C196.58 198.73 170.82 224 128 224c-37.39 0-64.53-22.4-80-39.85V208a8 8 0 0 1-16 0v-48a8 8 0 0 1 8-8h48a8 8 0 0 1 0 16H55.44C67.76 183.35 93 208 128 208c36 0 58.14-21.46 58.36-21.68a8 8 0 0 1 11.31.05M216 40a8 8 0 0 0-8 8v23.85C192.53 54.4 165.39 32 128 32c-42.82 0-68.58 25.27-69.66 26.34a8 8 0 0 0 11.3 11.34C69.86 69.46 92 48 128 48c35 0 60.24 24.65 72.56 40H168a8 8 0 0 0 0 16h48a8 8 0 0 0 8-8V48a8 8 0 0 0-8-8"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="poll-hero__frozen" data-poll-state="frozen" hidden>
          <div class="poll-hero__frozen-badge">Vote terminé</div>
          <div class="poll-hero__counter" data-poll-frozen-counter>0 votes</div>
          <div class="poll-hero__actions presenter-only">
            <button type="button" class="poll-hero__action-btn" data-poll-reset title="Nouvelle session">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
                <path d="M197.67 186.37a8 8 0 0 1 0 11.29C196.58 198.73 170.82 224 128 224c-37.39 0-64.53-22.4-80-39.85V208a8 8 0 0 1-16 0v-48a8 8 0 0 1 8-8h48a8 8 0 0 1 0 16H55.44C67.76 183.35 93 208 128 208c36 0 58.14-21.46 58.36-21.68a8 8 0 0 1 11.31.05M216 40a8 8 0 0 0-8 8v23.85C192.53 54.4 165.39 32 128 32c-42.82 0-68.58 25.27-69.66 26.34a8 8 0 0 0 11.3 11.34C69.86 69.46 92 48 128 48c35 0 60.24 24.65 72.56 40H168a8 8 0 0 0 0 16h48a8 8 0 0 0 8-8V48a8 8 0 0 0-8-8"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="poll-hero__archived" data-poll-state="archived" hidden>
          <div class="poll-hero__frozen-badge">Session archivée</div>
          <div class="poll-hero__counter" data-poll-archived-counter>0 votes</div>
          <button type="button" class="poll-hero__start-btn presenter-only" data-poll-start>
            Nouvelle session
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .poll-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .poll-hero__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .poll-hero__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .poll-hero__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .poll-hero__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .poll-hero__body {
    flex: 1 1 auto !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    padding-top: 32px;
    gap: 56px;
  }

  .poll-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .poll-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .poll-hero__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 16px 0 0;
  }

  .poll-hero__grid {
    display: grid;
    grid-template-columns: 60% 40%;
    gap: 64px;
    align-items: center;
  }

  /* Toutes les réponses dans une carte blanche bordée, à la même hauteur que
     wordcloud-hero__chart (min-height 560px), barres centrées verticalement. */
  .poll-hero__chart {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    min-height: 560px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 32px 36px;
  }

  .poll-hero__bar-row {
    display: grid;
    grid-template-columns: 260px 1fr 72px;
    align-items: center;
    gap: 16px;
    height: 52px;
  }

  .poll-hero__bar-label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 700;
    font-size: var(--fs-lead);
    color: var(--c-ink);
    text-align: right;
  }

  .poll-hero__bar-track {
    height: 52px;
    background: color-mix(in srgb, var(--c-ink) 6%, transparent);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }

  .poll-hero__bar-fill {
    height: 100%;
    background: var(--c-accent);
    border-radius: 4px;
    transition: width 400ms ease-out;
    position: relative;
  }

  .poll-hero__bar-fill.is-flash::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.4);
    animation: poll-hero-flash 600ms ease-out forwards;
  }

  @keyframes poll-hero-flash {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  .poll-hero__bar-count {
    font-family: 'Space Grotesk', monospace;
    font-weight: 700;
    font-size: 22px;
    color: var(--c-ink);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  .poll-hero__side {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .poll-hero__initial,
  .poll-hero__live,
  .poll-hero__frozen,
  .poll-hero__archived {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .poll-hero__start-btn {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 700;
    font-size: 24px;
    color: var(--c-on-accent);
    background: var(--c-accent);
    border: none;
    border-radius: 4px;
    padding: 14px 28px;
    cursor: pointer;
    transition: background-color 0.2s ease;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
  }

  .poll-hero__qr {
    width: 380px;
    height: 380px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
  }
  .poll-hero__qr svg {
    width: 100%;
    height: 100%;
  }

  .poll-hero__code {
    font-family: 'Space Grotesk', monospace;
    font-weight: 700;
    font-size: 64px;
    letter-spacing: 0.15em;
    color: var(--c-ink);
    font-variant-numeric: tabular-nums;
  }

  .poll-hero__url {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 500;
    font-size: 18px;
    color: var(--c-muted);
  }

  .poll-hero__counter {
    font-family: 'Space Grotesk', monospace;
    font-weight: 700;
    font-size: 16px;
    color: var(--c-muted);
    margin-top: 4px;
  }

  .poll-hero__actions {
    display: flex;
    gap: 8px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    padding: 6px;
    margin-top: 12px;
  }

  .poll-hero__action-btn {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--c-ink);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  @media (hover: hover) {
    .poll-hero__action-btn:hover {
      background: var(--c-accent);
      color: var(--c-on-accent);
    }
  }

  .poll-hero__frozen-badge {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 700;
    font-size: 28px;
    color: var(--c-on-accent);
    background: var(--c-accent);
    padding: 18px 36px;
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    text-align: center;
  }
</style>
