---
// src/components/slides/Quote.astro
// Slide citation / insight : grande phrase centrée. En tête, soit la marque de
// citation (guillemets), soit une icône (prop `icon`, ex "ph:lightbulb" pour un
// encart idée). Attribution (auteur + rôle + avatar) optionnelle. Couleurs en
// tokens (suit le scheme LM / ExecEd), fond pearl comme les slides à contenu.
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';
interface Props {
  text: string;
  author?: string;
  role?: string;
  image?: string;
  highlight?: string;
  /** Icône Phosphor en tête (ex "ph:lightbulb") ; sinon, guillemets de citation. */
  icon?: string;
}
const { text, author, role, image, highlight, icon } = Astro.props;
const textParts = splitHighlight(text, highlight);
---
<section class="quote-slide" data-layout="quote">
  <figure>
    <blockquote class="quote-slide__text">
      {icon
        ? <Icon name={icon} class="quote-slide__icon" />
        : <span class="quote-slide__mark" aria-hidden="true">&#x201C;</span>}
      {textParts
        ? <span>{textParts.before}<span class="underline">{textParts.match}</span>{textParts.after}</span>
        : <span>{text}</span>}
    </blockquote>
    {(author || image) && (
      <figcaption class="quote-slide__attribution">
        {image && (
          <span class="quote-slide__avatar">
            <img src={image} alt={author ?? ''} loading="lazy" decoding="async" />
          </span>
        )}
        {(author || role) && (
          <span class="quote-slide__name-block">
            {author && <span class="quote-slide__author">{author}</span>}
            {role && <span class="quote-slide__role">{role}</span>}
          </span>
        )}
      </figcaption>
    )}
  </figure>
</section>

<style>
  .quote-slide {
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    justify-content: center !important;
    align-items: center !important;
    text-align: center;
  }
  .quote-slide figure {
    margin: 0;
    max-width: 1400px;
  }
  .quote-slide__text {
    position: relative;
    font-size: 44px;
    line-height: 1.3;
    font-weight: 700;
    color: var(--c-ink);
    margin: 0 0 48px;
    quotes: none;
  }
  .quote-slide__mark {
    position: absolute;
    top: -32px;
    left: -16px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 120px;
    line-height: 1;
    color: var(--c-accent);
    opacity: 0.6;
  }
  .quote-slide__icon {
    display: block;
    width: 84px;
    height: 84px;
    margin: 0 auto 32px;
    color: var(--c-accent);
  }
  .quote-slide__attribution {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    justify-content: center;
  }
  .quote-slide__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
  }
  .quote-slide__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .quote-slide__name-block {
    display: flex;
    flex-direction: column;
    text-align: left;
  }
  .quote-slide__author {
    font-size: 22px;
    font-weight: 700;
    color: var(--c-ink);
  }
  .quote-slide__role {
    font-size: 18px;
    color: var(--c-muted);
  }
</style>
