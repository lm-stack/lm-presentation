---
// src/components/slides/Quote.astro
// Citation entièrement centrée (horizontalement + verticalement) sur image de
// fond floutée + voile crème halo gold. Pastille jaune avec icône Phosphor
// "quotes" centrée au-dessus de la citation, attribution centrée dessous.
// Variante optionnelle "logos row" pour afficher les logos de marques
// sous l'attribution.
// Inspiration slides 5 et 6 du PPTX ExecEd.
import { Icon } from 'astro-icon/components';

interface LogoItem {
  src: string;
  alt: string;
}
interface Props {
  text: string;
  /** Texte de support optionnel sous la citation (un ou plusieurs paragraphes). */
  lead?: string | string[];
  author?: string;
  role?: string;
  image?: string;
  /** Icône Phosphor dans la pastille (défaut "ph:quotes-thin" ; ex "ph:lightbulb"). */
  icon?: string;
  logos?: LogoItem[];
  brand?: string;
  brandSub?: string;
}
const {
  text,
  lead,
  author,
  role,
  image,
  icon = 'ph:quotes-thin',
  logos,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const leadParts = lead ? (Array.isArray(lead) ? lead : [lead]) : [];
---
<section class:list={['quote', !image && 'quote--plain']} data-layout="quote">
  {image && (
    <div class="quote__bg" aria-hidden="true">
      <img src={image} alt="" loading="lazy" decoding="async" />
      <div class="quote__overlay"></div>
    </div>
  )}

  <header class="quote__header">
    <div class="quote__brand-text">
      <p class="quote__brand-main">{brand}</p>
      {brandSub && <p class="quote__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="quote__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="quote__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="quote__body">
    <span class="quote__mark" aria-hidden="true">
      <Icon name={icon} />
    </span>
    <blockquote class="quote__text">{text}</blockquote>
    {leadParts.length > 0 && (
      <div class="quote__lead">
        {leadParts.map((p) => <p>{p}</p>)}
      </div>
    )}
    {author && (
      <p class="quote__author">
        <span class="quote__author-name">{author}</span>
        {role && <span class="quote__author-role">, {role}</span>}
      </p>
    )}
  </div>

  {logos && logos.length > 0 && (
    <div class="quote__logos">
      {logos.map((logo) => (
        <span class="quote__logo">
          <img src={logo.src} alt={logo.alt} loading="lazy" decoding="async" />
        </span>
      ))}
    </div>
  )}
</section>

<style>
  .quote {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    color: var(--c-ink);
    display: grid !important;
    grid-template-rows: auto 1fr auto;
    background: var(--c-cream);
  }
  /* Sans image de fond : encart épuré sur le dégradé pearl du deck. */
  .quote--plain { background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%); }

  .quote__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .quote__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(14px) saturate(0.6);
    transform: scale(1.1); /* évite les bords blurés en sortant de l'écran */
  }
  /* Voile crème + halo gold en coin pour rester en light mode et la
     lisibilité du texte foncé. Opacité plus marquée pour que l'image
     reste sous-jacente mais ne dispute pas le texte. */
  .quote__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, color-mix(in srgb, var(--c-bg-start) 60%, transparent) 0%, color-mix(in srgb, var(--c-bg-end) 70%, transparent) 100%);
  }

  .quote__header,
  .quote__icon,
  .quote__body,
  .quote__logos {
    position: relative;
    z-index: 1;
  }

  .quote__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .quote__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }
  .quote__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .quote__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }

  /* Bloc entièrement centré : pastille, citation et attribution empilées
     et centrées horizontalement (align-items + text-align center) dans un
     conteneur lui-même centré (margin auto). */
  .quote__body {
    align-self: center;
    max-width: 1480px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 36px;
    text-align: center;
    position: relative;
  }
  /* Pastille jaune centrée au-dessus de la citation (remplace l'ancien rond
     ancré au bord gauche qui déséquilibrait la composition vers la gauche). */
  .quote__mark {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--c-ink) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-on-accent);
    flex: 0 0 auto;
  }
  .quote__mark :global(svg) {
    width: 60px;
    height: 60px;
  }
  .quote__text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(34px, 3.3vw, 50px);
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
    max-width: 1380px;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: center;
  }
  /* Texte de support optionnel sous la citation (un ou plusieurs paragraphes). */
  .quote__lead {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 1100px;
  }
  .quote__lead p {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 400;
    color: var(--c-muted);
    margin: 0;
    text-align: center;
  }
  .quote__author {
    position: relative;
    z-index: 1;
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: 22px;
    margin: 0;
    color: var(--c-ink);
    text-align: center;
  }
  .quote__author-name {
    font-weight: 500;
  }
  .quote__author-role {
    font-weight: 400;
    color: var(--c-muted);
  }

  .quote__logos {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    padding-top: 32px;
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .quote__logo {
    flex: 1 1 0;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0.78;
  }
  .quote__logo img {
    max-height: 36px;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(1);
  }
</style>
