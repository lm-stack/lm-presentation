---
// src/components/slides/InfoCardsGrid.astro
// Grille de cards "info" : icône Phosphor + LABEL CAPS + valeur ou
// description courte. Header marque + logo LM (RÈGLE ABSOLUE), fond pearl,
// titre serif italique partiel + sous-titre optionnel, cards larges (2 col).
// Inspiration slides 35 (Informations clés) et 40 (Aides financières)
// du PPTX ExecEd.
import { Icon } from 'astro-icon/components';
import { splitHighlight } from '@/utils/highlight';

interface InfoCard {
  /** Icône Phosphor (ex: "ph:certificate", "ph:calendar-blank"). */
  icon: string;
  /** Label affiché en CAPS lettrées au-dessus de la valeur. */
  label: string;
  /** Valeur ou description courte (1 à 2 phrases max). */
  value: string;
}
interface Props {
  title: string;
  italicPart?: string;
  /** Description optionnelle affichée sous le titre. */
  subtitle?: string;
  /** Auto-fit : cards larges, 2 colonnes sur une slide 1920. */
  cards: InfoCard[];
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  cards,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);
---
<section class="info-cards-grid" data-layout="info-cards-grid">
  <header class="info-cards-grid__header">
    <div class="info-cards-grid__brand">
      <p class="info-cards-grid__brand-main">{brand}</p>
      {brandSub && <p class="info-cards-grid__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="info-cards-grid__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="info-cards-grid__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="info-cards-grid__body">
    <h2 class="info-cards-grid__title">
      {titleParts
        ? <>{titleParts.before}<em class="info-cards-grid__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
        : title}
    </h2>
    {subtitle && <p class="info-cards-grid__subtitle">{subtitle}</p>}

    <div class="info-cards-grid__grid">
      {cards.map((card) => (
        <article class="info-cards-grid__card">
          <span class="info-cards-grid__icon" aria-hidden="true">
            <Icon name={card.icon} />
          </span>
          <p class="info-cards-grid__label">{card.label}</p>
          <p class="info-cards-grid__value">{card.value}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .info-cards-grid {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom. */
  .info-cards-grid__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .info-cards-grid__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
  }
  .info-cards-grid__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
  }
  .info-cards-grid__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .info-cards-grid__body {
    flex: 1 1 auto !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    padding-top: 32px;
  }

  .info-cards-grid__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(64px, 6vw, 100px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .info-cards-grid__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .info-cards-grid__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    line-height: 1.45;
    font-weight: 400;
    margin: 0 0 48px;
    color: var(--c-muted);
    max-width: 1100px;
    text-align: left;
  }

  /* Cards larges : 2 colonnes sur 1920, auto-fit. */
  .info-cards-grid__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(560px, 1fr));
    gap: 28px;
  }

  .info-cards-grid__card {
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 6%, transparent);
    padding: 36px 44px;
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--c-ink) 8%, transparent);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .info-cards-grid__icon {
    width: 44px;
    height: 44px;
    color: var(--c-accent);
    margin-bottom: 4px;
  }
  .info-cards-grid__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .info-cards-grid__label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 0;
    color: var(--c-muted);
  }
  .info-cards-grid__value {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
    color: var(--c-ink);
  }
</style>
