---
// src/components/slides/InfoCardsGrid.astro
// Grille de mini-cards "info" : icône Phosphor + LABEL CAPS + valeur ou
// description courte. Format de référence pour synthétiser des chiffres-
// clés ou des modalités pratiques (durée, prix, format, prérequis).
// Inspiration slides 35 (Informations clés) et 40 (Aides financières)
// du PPTX ExecEd.
import { Icon } from 'astro-icon/components';

interface InfoCard {
  /** Icône Phosphor (ex: "ph:certificate", "ph:calendar-blank"). */
  icon: string;
  /** Label affiché en CAPS lettrées au-dessus de la valeur. */
  label: string;
  /** Valeur ou description courte (1 à 2 phrases max). */
  value: string;
}
interface Props {
  title: string;
  italicPart?: string;
  /** Auto-fit : 2 colonnes par défaut, peut s'étendre selon largeur. */
  cards: InfoCard[];
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  cards,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="info-cards-grid" data-layout="info-cards-grid">
  <header class="info-cards-grid__header">
    <div class="info-cards-grid__brand">
      <p class="info-cards-grid__brand-main">{brand}</p>
      {brandSub && <p class="info-cards-grid__brand-sub">{brandSub}</p>}
    </div>
  </header>

  <div class="info-cards-grid__body">
    <h2 class="info-cards-grid__title">
      {italicPart
        ? <>{title.split(italicPart)[0]}<em class="info-cards-grid__title-italic">{italicPart}</em>{title.split(italicPart)[1]}</>
        : title}
    </h2>

    <div class="info-cards-grid__grid">
      {cards.map((card) => (
        <article class="info-cards-grid__card">
          <span class="info-cards-grid__icon" aria-hidden="true">
            <Icon name={card.icon} />
          </span>
          <p class="info-cards-grid__label">{card.label}</p>
          <p class="info-cards-grid__value">{card.value}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .info-cards-grid {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 64px 96px !important;
    background: #FAF8F3;
    color: #191919;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  .info-cards-grid__header {
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(25, 25, 25, 0.12);
  }
  .info-cards-grid__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: #191919;
  }
  .info-cards-grid__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: #6B6F84;
  }

  .info-cards-grid__body {
    flex: 1 1 auto !important;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
    padding-top: 32px;
  }

  .info-cards-grid__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(72px, 7vw, 116px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0 0 56px;
    color: #191919;
    text-wrap: balance;
    text-align: left;
  }
  .info-cards-grid__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .info-cards-grid__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 24px;
  }

  .info-cards-grid__card {
    background: #FFFFFF;
    border: 1px solid rgba(25, 25, 25, 0.06);
    padding: 24px 28px;
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px rgba(25, 25, 25, 0.08);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .info-cards-grid__icon {
    width: 28px;
    height: 28px;
    color: #191919;
    margin-bottom: 4px;
  }
  .info-cards-grid__icon :global(svg) {
    width: 100%;
    height: 100%;
  }
  .info-cards-grid__label {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 0;
    color: #6B6F84;
  }
  .info-cards-grid__value {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 500;
    line-height: 1.45;
    margin: 0;
    color: #191919;
  }
</style>
