---
// src/components/slides/Erd.astro
// Diagramme entité-relation PLEIN CADRE (façon ImageFull) : le canvas pointillé
// prend tout le slide (1920x1080), les entités sont posées dessus, et une box de
// légende dans un coin (défaut bas-gauche) explique le concept / l'étape. Aucun
// bandeau marque ni titre en haut : comme ImageFull, le diagramme parle seul.
//
// Design des boîtes et arêtes : repris du repo lm-diagrams (ReactFlow + TableNode)
// pour la STRUCTURE (boîtes radius 12px avec barre d'accent en tête, lignes de
// champs nom | type avec badges PK/FK, ombres douces, connecteurs COURBÉS
// smoothstep avec flèche fermée). Les COULEURS sont 100% TOKENISÉES (var(--c-…)) :
// l'ERD suit le thème du deck (accent rouge en ExecEd, jaune en LM), pas de hex.
//
// Réutilisable : on passe `entities` (positions x/y dans la scène 1920x1080) et
// `relations` (chemins smoothstep calculés au build). state d'entité : 'normal'
// | 'accent' (mise en avant) | 'ghost' (estompée). La légende reprend title (gras)
// + subtitle (description) + caption (petite ligne, ex. l'étape).
import { splitHighlight } from '@/utils/highlight';

interface ErdField { name: string; type?: string; key?: 'pk' | 'fk'; }
interface ErdEntity {
  name: string;
  x: number;
  y: number;
  group?: string;
  state?: 'normal' | 'accent' | 'ghost';
  fields: ErdField[];
}
interface ErdRelation { from: string; to: string; label?: string; dashed?: boolean; }

interface Props {
  /** Titre de la légende (gras), dans la box. */
  title?: string;
  italicPart?: string;
  /** Description de la légende, sous le titre : explique le concept. */
  subtitle?: string;
  /** Petite ligne sous la description (ex. "Étape 1 sur 5"). */
  caption?: string;
  /** Coin de la box légende (défaut bas-gauche). */
  captionPosition?: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
  entities: ErdEntity[];
  relations?: ErdRelation[];
  /** Acceptés pour compat (non rendus : le plein cadre n'a pas de bandeau marque). */
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  caption,
  captionPosition = 'bottom-left',
  entities,
  relations = [],
} = Astro.props;
const titleParts = splitHighlight(title, italicPart);

// Scène = slide entier (espace de design 1920x1080).
const STAGE_W = 1920;
const STAGE_H = 1080;
const NODE_W = 340;
const HEAD_H = 56;
const ROW_H = 32;
// Hauteur exacte (le CSS fige header et lignes => handles alignés au pixel).
const nodeH = (e: ErdEntity) => HEAD_H + e.fields.length * ROW_H;

const byName = new Map(entities.map((e) => [e.name, e]));

type Side = 'left' | 'right' | 'top' | 'bottom';
function handle(e: ErdEntity, side: Side) {
  const h = nodeH(e);
  if (side === 'left') return { x: e.x, y: e.y + h / 2 };
  if (side === 'right') return { x: e.x + NODE_W, y: e.y + h / 2 };
  if (side === 'top') return { x: e.x + NODE_W / 2, y: e.y };
  return { x: e.x + NODE_W / 2, y: e.y + h };
}

const R = 12; // rayon des coins arrondis (routage smoothstep)
type Pt = { x: number; y: number };
function hPath(s: Pt, t: Pt) {
  if (Math.abs(t.y - s.y) < 1) return `M ${s.x},${s.y} L ${t.x},${t.y}`;
  const midX = (s.x + t.x) / 2;
  const dS = midX >= s.x ? 1 : -1;
  const dT = t.x >= midX ? 1 : -1;
  const vy = t.y >= s.y ? 1 : -1;
  const r = Math.max(0, Math.min(R, Math.abs(t.y - s.y) / 2, Math.abs(midX - s.x), Math.abs(t.x - midX)));
  return [
    `M ${s.x},${s.y}`,
    `L ${midX - dS * r},${s.y}`,
    `Q ${midX},${s.y} ${midX},${s.y + vy * r}`,
    `L ${midX},${t.y - vy * r}`,
    `Q ${midX},${t.y} ${midX + dT * r},${t.y}`,
    `L ${t.x},${t.y}`,
  ].join(' ');
}
function vPath(s: Pt, t: Pt) {
  if (Math.abs(t.x - s.x) < 1) return `M ${s.x},${s.y} L ${t.x},${t.y}`;
  const midY = (s.y + t.y) / 2;
  const dS = midY >= s.y ? 1 : -1;
  const dT = t.y >= midY ? 1 : -1;
  const hx = t.x >= s.x ? 1 : -1;
  const r = Math.max(0, Math.min(R, Math.abs(t.x - s.x) / 2, Math.abs(midY - s.y), Math.abs(t.y - midY)));
  return [
    `M ${s.x},${s.y}`,
    `L ${s.x},${midY - dS * r}`,
    `Q ${s.x},${midY} ${s.x + hx * r},${midY}`,
    `L ${t.x - hx * r},${midY}`,
    `Q ${t.x},${midY} ${t.x},${midY + dT * r}`,
    `L ${t.x},${t.y}`,
  ].join(' ');
}

const edges = relations
  .map((r) => {
    const a = byName.get(r.from);
    const b = byName.get(r.to);
    if (!a || !b) return null;
    const ac = { x: a.x + NODE_W / 2, y: a.y + nodeH(a) / 2 };
    const bc = { x: b.x + NODE_W / 2, y: b.y + nodeH(b) / 2 };
    const horizontal = Math.abs(bc.x - ac.x) >= Math.abs(bc.y - ac.y);
    let s: Pt;
    let t: Pt;
    let d: string;
    if (horizontal) {
      const right = bc.x >= ac.x;
      s = handle(a, right ? 'right' : 'left');
      t = handle(b, right ? 'left' : 'right');
      d = hPath(s, t);
    } else {
      const down = bc.y >= ac.y;
      s = handle(a, down ? 'bottom' : 'top');
      t = handle(b, down ? 'top' : 'bottom');
      d = vPath(s, t);
    }
    const ghost = a.state === 'ghost' || b.state === 'ghost';
    return {
      d,
      dashed: !!r.dashed,
      ghost,
      label: r.label ?? '',
      mx: (s.x + t.x) / 2,
      my: (s.y + t.y) / 2,
    };
  })
  .filter((e): e is NonNullable<typeof e> => e !== null);

const hasCaption = !!(title || subtitle || caption);
---
<section class:list={['erd', `erd--cap-${captionPosition}`]} data-layout="erd">
  <svg class="erd__edges" viewBox={`0 0 ${STAGE_W} ${STAGE_H}`} preserveAspectRatio="none" aria-hidden="true">
    <defs>
      <marker id="erd-arrow" markerWidth="14" markerHeight="14" refX="10" refY="6" orient="auto" markerUnits="userSpaceOnUse">
        <path d="M2,2 L11,6 L2,10 Z" class="erd-arrow-head" />
      </marker>
    </defs>
    {edges.map((e) => (
      <path
        class:list={['erd-edge', { 'erd-edge--dashed': e.dashed, 'erd-edge--ghost': e.ghost }]}
        d={e.d}
        marker-end="url(#erd-arrow)"
      />
    ))}
  </svg>

  {edges.filter((e) => e.label).map((e) => (
    <span class:list={['erd-label', { 'erd-label--ghost': e.ghost }]} style={`left:${e.mx}px;top:${e.my}px`}>{e.label}</span>
  ))}

  {entities.map((e) => (
    <article
      class:list={['erd-node', e.state === 'accent' && 'erd-node--accent', e.state === 'ghost' && 'erd-node--ghost']}
      style={`left:${e.x}px;top:${e.y}px;width:${NODE_W}px`}
    >
      <div class="erd-node__head" style={`height:${HEAD_H}px`}>
        <span class="erd-node__title">{e.name}</span>
        {e.group && <span class="erd-node__group">{e.group}</span>}
      </div>
      <div class="erd-node__body">
        {e.fields.map((f) => (
          <div class="erd-node__row" style={`height:${ROW_H}px`}>
            <span class="erd-node__col-name">
              {f.key === 'pk' && <span class="erd-badge erd-badge--pk">PK</span>}
              {f.key === 'fk' && <span class="erd-badge erd-badge--fk">FK</span>}
              <span class="erd-node__col-label">{f.name}</span>
            </span>
            {f.type && <span class="erd-node__col-type">{f.type}</span>}
          </div>
        ))}
      </div>
    </article>
  ))}

  {hasCaption && (
    <div class="erd__caption">
      <span class="erd__caption-dot" aria-hidden="true"></span>
      <div class="erd__caption-body">
        {title && (
          <p class="erd__caption-title">
            {titleParts
              ? <>{titleParts.before}<em class="erd__caption-italic">{titleParts.match}</em>{titleParts.after}</>
              : title}
          </p>
        )}
        {subtitle && <p class="erd__caption-text">{subtitle}</p>}
        {caption && <p class="erd__caption-foot">{caption}</p>}
      </div>
    </div>
  )}
</section>

<style>
  /* Plein cadre : pas de padding, canvas pointillé "ReactFlow" sur tout le slide.
     Couleurs 100% tokenisées => suit le thème (rouge ExecEd / jaune LM). */
  .erd {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    display: block !important;
    background-color: var(--c-surface);
    background-image: radial-gradient(circle, color-mix(in srgb, var(--c-ink) 15%, transparent) 1.4px, transparent 1.5px);
    background-size: 28px 28px;
    background-position: 14px 14px;
    color: var(--c-ink);
  }

  .erd__edges {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    z-index: 0;
  }
  .erd-edge {
    stroke: color-mix(in srgb, var(--c-ink) 80%, transparent);
    stroke-width: 1.6;
    fill: none;
  }
  .erd-edge--dashed {
    stroke: var(--c-accent);
    stroke-dasharray: 7 6;
  }
  .erd-edge--ghost {
    stroke: color-mix(in srgb, var(--c-ink) 18%, transparent);
  }
  .erd-arrow-head {
    fill: color-mix(in srgb, var(--c-ink) 80%, transparent);
  }

  .erd-label {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 2;
    font-family: 'Space Grotesk', 'Hanken Grotesk', monospace;
    font-size: 14px;
    font-weight: 600;
    color: var(--c-muted);
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
    padding: 2px 9px;
    border-radius: 5px;
    white-space: nowrap;
    box-shadow: 0 1px 3px color-mix(in srgb, var(--c-ink) 6%, transparent);
  }
  .erd-label--ghost {
    opacity: 0.4;
  }

  /* ====== Noeud entité : structure TableNode (lm-diagrams), couleurs tokenisées ====== */
  .erd-node {
    position: absolute;
    z-index: 1;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--c-ink) 6%, transparent), 0 1px 3px color-mix(in srgb, var(--c-ink) 4%, transparent);
  }
  .erd-node--accent {
    border-color: var(--c-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-accent) 25%, transparent), 0 8px 20px color-mix(in srgb, var(--c-ink) 10%, transparent);
  }
  .erd-node--ghost {
    opacity: 0.42;
    box-shadow: none;
  }

  .erd-node__head {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1px;
    padding: 0 16px;
    border-top: 4px solid var(--c-accent);
    background: linear-gradient(180deg, color-mix(in srgb, var(--c-ink) 3%, transparent) 0%, transparent 100%);
  }
  .erd-node__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.2px;
    color: var(--c-ink);
  }
  .erd-node__group {
    font-family: 'Space Grotesk', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-muted);
  }

  .erd-node__body {
    display: flex;
    flex-direction: column;
  }
  .erd-node__row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 0 16px;
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 6%, transparent);
  }
  .erd-node__col-name {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--c-ink);
  }
  .erd-node__col-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .erd-node__col-type {
    font-family: 'Space Grotesk', monospace;
    font-size: 14px;
    font-weight: 500;
    color: var(--c-muted);
    white-space: nowrap;
  }

  .erd-badge {
    flex: 0 0 auto;
    font-family: 'Space Grotesk', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    padding: 2px 6px;
    border-radius: 4px;
  }
  .erd-badge--pk {
    background: var(--c-accent);
    color: var(--c-on-accent);
  }
  .erd-badge--fk {
    background: color-mix(in srgb, var(--c-ink) 9%, transparent);
    color: var(--c-muted);
  }

  /* ====== Légende (box dans un coin, façon ImageFull) ====== */
  .erd__caption {
    position: absolute;
    z-index: 3;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin: 0;
    max-width: 680px;
    padding: 22px 28px;
    background: var(--c-surface);
    border: 1px solid color-mix(in srgb, var(--c-ink) 8%, transparent);
    border-radius: 4px;
    box-shadow: 0 6px 20px -6px color-mix(in srgb, var(--c-ink) 16%, transparent);
  }
  .erd--cap-top-left .erd__caption { top: 48px; left: 64px; }
  .erd--cap-top-right .erd__caption { top: 48px; right: 64px; }
  .erd--cap-bottom-left .erd__caption { bottom: 56px; left: 64px; }
  .erd--cap-bottom-right .erd__caption { bottom: 56px; right: 64px; }
  .erd__caption-dot {
    flex: 0 0 auto;
    width: 10px;
    height: 10px;
    margin-top: 13px;
    border-radius: 50%;
    background: var(--c-accent);
  }
  .erd__caption-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .erd__caption-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 30px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--c-ink);
    margin: 0;
  }
  .erd__caption-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .erd__caption-text {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--c-muted);
    margin: 0;
  }
  .erd__caption-foot {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.35;
    color: var(--c-faint);
    margin: 4px 0 0;
  }
</style>
