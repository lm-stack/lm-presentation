---
// src/components/slides/NumberedSplit.astro
// Liste numérotée "ExecEd-style" : header full-width standard (brand gauche +
// logo LM droite + border-bottom pleine largeur), puis sous le header un split
// 62/38 : cards numérotées (gros chiffre Bungee Outline) à gauche qui débordent
// volontairement sur l'image (ou le motif damier) à droite.
// Inspiration slide 30 du PPTX ExecEd (Public cible).
import '@fontsource/bungee-outline/latin.css';

interface NumberedItem {
  /** Texte ou titre de l'item. */
  text: string;
}
interface Props {
  title: string;
  italicPart?: string;
  subtitle?: string;
  items: NumberedItem[];
  /** Image décorative affichée à droite (sinon motif damier). */
  image?: string;
  brand?: string;
  brandSub?: string;
}
const {
  title,
  italicPart,
  subtitle,
  items,
  image,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;
---
<section class="numbered-split" data-layout="numbered-split">
  {image
    ? <div class="numbered-split__image" aria-hidden="true"><img src={image} alt="" loading="lazy" decoding="async" /><div class="numbered-split__image-overlay"></div></div>
    : <div class="numbered-split__bg-right" aria-hidden="true"></div>}

  <header class="numbered-split__header">
    <div class="numbered-split__brand-text">
      <p class="numbered-split__brand-main">{brand}</p>
      {brandSub && <p class="numbered-split__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="numbered-split__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo-white-letter.svg" class="numbered-split__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="numbered-split__content">
    <div class="numbered-split__main">
      <h2 class="numbered-split__title">
        {italicPart
          ? <>{title.split(italicPart)[0]}<em class="numbered-split__title-italic"><span class="underline">{italicPart}</span></em>{title.split(italicPart)[1]}</>
          : title}
      </h2>

      {subtitle && (
        <p class="numbered-split__subtitle">{subtitle}</p>
      )}

      <ol class="numbered-split__list">
        {items.map((item, i) => (
          <li class="numbered-split__item">
            <span class="numbered-split__number">{String(i + 1).padStart(2, '0')}</span>
            <p class="numbered-split__item-text">{item.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .numbered-split {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 0 !important;
    background: linear-gradient(180deg, #FFFFFF 0%, #EFEFF2 100%);
    color: #191919;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width intangible : brand gauche + logo LM droite + border-bottom
     pleine largeur. z-index 2 pour rester au-dessus de l'image et des cards.
     Les colonnes (texte + image) commencent EN DESSOUS. */
  .numbered-split__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 44px 96px 40px;
    border-bottom: 1px solid rgba(25, 25, 25, 0.12);
  }
  .numbered-split__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: #191919;
    text-align: left;
  }
  .numbered-split__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: #6B6F84;
    text-align: left;
  }
  .numbered-split__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  /* Zone de contenu sous le header : texte à gauche (62%), image/damier
     à droite (38%, en absolu, derrière). */
  .numbered-split__content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    min-height: 0;
  }

  .numbered-split__image,
  .numbered-split__bg-right {
    position: absolute;
    top: 0;
    right: 0;
    width: 38%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
  }
  .numbered-split__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px) saturate(0.7);
    transform: scale(1.08);
  }
  .numbered-split__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.2) 100%);
  }
  .numbered-split__bg-right {
    background-image:
      linear-gradient(45deg, rgba(25, 25, 25, 0.05) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(25, 25, 25, 0.05) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(25, 25, 25, 0.05) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(25, 25, 25, 0.05) 75%);
    background-size: 24px 24px;
    background-position: 0 0, 0 12px, 12px -12px, -12px 0;
  }

  /* Bloc texte à gauche (62%), centré verticalement, au-dessus de l'image. */
  .numbered-split__main {
    position: relative;
    z-index: 1;
    width: 62%;
    height: 100%;
    padding: 32px 96px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 0;
  }

  .numbered-split__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(60px, 6vw, 96px);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: #191919;
    text-wrap: balance;
    text-align: left;
  }
  .numbered-split__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }

  .numbered-split__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    font-weight: 500;
    color: #6B6F84;
    margin: 24px 0 64px;
  }

  /* Les cards débordent volontairement vers la droite, par-dessus l'image
     (ou le motif damier en l'absence d'image). z-index 1 du bloc gauche les
     fait passer au-dessus du fond ; l'overflow hidden coupe au bord de slide. */
  .numbered-split__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 132%;
  }
  .numbered-split__item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 18px 28px;
    background: #FFFFFF;
    border: 1px solid rgba(25, 25, 25, 0.08);
    border-radius: 4px;
    box-shadow: 0 4px 12px -4px rgba(25, 25, 25, 0.08);
  }
  /* Numéros en Bungee Outline, identiques au slide Agenda (ProgrammeHero)
     et à AboutHero : gros chiffre contour, sans pastille. */
  .numbered-split__number {
    flex: 0 0 auto;
    min-width: 100px;
    font-family: 'Bungee Outline', sans-serif;
    font-weight: 400;
    font-size: 80px;
    line-height: 1;
    letter-spacing: 0;
    color: #191919;
    text-align: left;
  }
  .numbered-split__item-text {
    flex: 1 1 auto;
    margin: 0;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 26px;
    line-height: 1.45;
    color: #191919;
  }
</style>
