---
// src/components/slides/AgendaFull.astro
// Agenda dense, 6 a 8 points sur deux colonnes. Header marque + logo LM (RÈGLE),
// fond pearl, titre body + sous-titre, puis deux colonnes numerotees : grand
// numero decoratif, horaire en pill accent, titre, description. Tokenise.
import { splitHighlight } from '@/utils/highlight';

interface Item {
  time?: string;
  title: string;
  description?: string;
  duration?: string;
}

interface Props {
  title?: string;
  italicPart?: string;
  subtitle?: string;
  items: Item[];
  brand?: string;
  brandSub?: string;
}

const {
  title = 'Programme du jour',
  italicPart,
  subtitle,
  items,
  brand = 'Titre de la présentation',
  brandSub,
} = Astro.props;

// 6 a 8 items, on coupe a 8.
const safeItems = items.slice(0, 8);
const count = safeItems.length;
const splitAt = Math.ceil(count / 2);
const colA = safeItems.slice(0, splitAt);
const colB = safeItems.slice(splitAt);
const titleParts = splitHighlight(title, italicPart);
---
<section class="agenda-full" data-layout="agenda-full">
  <header class="agenda-full__header">
    <div class="agenda-full__brand-text">
      <p class="agenda-full__brand-main">{brand}</p>
      {brandSub && <p class="agenda-full__brand-sub">{brandSub}</p>}
    </div>
    <a href="https://lausanne.marketing" target="_blank" rel="noopener" class="agenda-full__brand-logo-link" aria-label="Lausanne Marketing">
      <img src="/assets/lm-logo.svg" class="agenda-full__brand-logo" alt="Lausanne Marketing" />
    </a>
  </header>

  <div class="agenda-full__body">
    <div class="agenda-full__heading">
      <h2 class="agenda-full__title">
        {titleParts
          ? <>{titleParts.before}<em class="agenda-full__title-italic"><span class="underline">{titleParts.match}</span></em>{titleParts.after}</>
          : title}
      </h2>
      {subtitle && <p class="agenda-full__subtitle">{subtitle}</p>}
    </div>

    <div class="agenda-full__grid">
      {[colA, colB].map((col, ci) => (
        <ol class="agenda-full__col" style={`--col-offset: ${ci * splitAt};`}>
          {col.map((item, i) => {
            const idx = ci * splitAt + i + 1;
            return (
              <li class="agenda-full__item">
                <span class="agenda-full__num" aria-hidden="true">{String(idx).padStart(2, '0')}</span>
                <div class="agenda-full__content">
                  <div class="agenda-full__meta">
                    {item.time && <span class="agenda-full__time">{item.time}</span>}
                    {item.duration && <span class="agenda-full__duration">{item.duration}</span>}
                  </div>
                  <h3 class="agenda-full__item-title">{item.title}</h3>
                  {item.description && (
                    <p class="agenda-full__desc">{item.description}</p>
                  )}
                </div>
              </li>
            );
          })}
        </ol>
      ))}
    </div>
  </div>
</section>

<style>
  .agenda-full {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    padding: 44px 96px 64px !important;
    background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
    color: var(--c-ink);
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
  }

  /* Header full-width : brand gauche + logo LM droite + border-bottom (RÈGLE). */
  .agenda-full__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 40px;
    border-bottom: 1px solid color-mix(in srgb, var(--c-ink) 12%, transparent);
  }
  .agenda-full__brand-main {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0;
    color: var(--c-ink);
    text-align: left;
  }
  .agenda-full__brand-sub {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-brand-sub);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 4px 0 0;
    color: var(--c-muted);
    text-align: left;
  }
  .agenda-full__brand-logo {
    height: 48px;
    width: auto;
    display: block;
    flex: 0 0 auto;
  }

  .agenda-full__body {
    flex: 1 1 auto !important;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    padding-top: 28px;
  }
  .agenda-full__heading { flex: 0 0 auto; }
  .agenda-full__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-hero-m);
    line-height: var(--lh-title);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--c-ink);
    text-wrap: balance;
    text-align: left;
  }
  .agenda-full__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
  }
  .agenda-full__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    line-height: var(--lh-lead);
    font-weight: 500;
    color: var(--c-muted);
    margin: 12px 0 0;
    max-width: var(--measure-l);
    text-align: left;
  }

  .agenda-full__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 80px;
    row-gap: 0;
    width: 100%;
    align-items: start;
  }
  .agenda-full__col {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .agenda-full__item {
    position: relative;
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 20px;
    padding: 18px 0;
    align-items: start;
  }
  .agenda-full__item + .agenda-full__item {
    border-top: 1px solid color-mix(in srgb, var(--c-ink) 10%, transparent);
  }

  /* Numero monumental decoratif (exception taille : grand numero, sans token),
     soulignement accent fin pour signer la charte LM. */
  .agenda-full__num {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 64px;
    font-weight: 800;
    line-height: 0.9;
    color: color-mix(in srgb, var(--c-ink) 12%, transparent);
    letter-spacing: -0.04em;
    font-feature-settings: 'tnum';
    position: relative;
    padding-bottom: 8px;
  }
  .agenda-full__num::after {
    content: '';
    position: absolute;
    left: 4px;
    bottom: 0;
    width: 32px;
    height: 3px;
    background: var(--c-accent);
  }

  .agenda-full__content { min-width: 0; }
  .agenda-full__meta {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }
  .agenda-full__time {
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-label);
    font-weight: 700;
    color: var(--c-on-accent);
    background: var(--c-accent);
    padding: 3px 10px;
    border-radius: 3px;
    letter-spacing: 0.02em;
    font-feature-settings: 'tnum';
  }
  .agenda-full__duration {
    font-family: 'Space Grotesk', monospace;
    font-size: var(--fs-source);
    font-weight: 700;
    color: var(--c-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .agenda-full__item-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--fs-lead);
    font-weight: 700;
    color: var(--c-ink);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .agenda-full__desc {
    font-size: var(--fs-body);
    color: var(--c-muted);
    margin: 6px 0 0;
    line-height: var(--lh-body);
  }
</style>
