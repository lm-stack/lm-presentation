---
// src/components/slides/AgendaFull.astro
// Agenda dense, 6 à 8 points sur deux colonnes éditoriales.
// Numéros XXL en gris très clair derrière le texte, titres bold noir,
// horaires en pill jaune, séparateur hairline.
import SlideTitle from '@/components/SlideTitle.astro';

interface Item {
  time?: string;
  title: string;
  description?: string;
  duration?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  highlight?: string;
  items: Item[];
}

const {
  title = 'Programme du jour',
  subtitle,
  highlight,
  items,
} = Astro.props;

// 6 à 8 items, on coupe à 8.
const safeItems = items.slice(0, 8);
const count = safeItems.length;
// Colonnes équilibrées : 8 → 4/4, 7 → 4/3, 6 → 3/3.
const splitAt = Math.ceil(count / 2);
const colA = safeItems.slice(0, splitAt);
const colB = safeItems.slice(splitAt);
---
<section class="agenda-full" data-layout="agenda-full">
  <SlideTitle title={title} subtitle={subtitle} highlight={highlight} />

  <div class="agenda-full__grid">
    {[colA, colB].map((col, ci) => (
      <ol class="agenda-full__col" style={`--col-offset: ${ci * splitAt};`}>
        {col.map((item, i) => {
          const idx = ci * splitAt + i + 1;
          return (
            <li class="agenda-full__item">
              <span class="agenda-full__num" aria-hidden="true">{String(idx).padStart(2, '0')}</span>
              <div class="agenda-full__content">
                <div class="agenda-full__meta">
                  {item.time && <span class="agenda-full__time">{item.time}</span>}
                  {item.duration && <span class="agenda-full__duration">{item.duration}</span>}
                </div>
                <h3 class="agenda-full__title">{item.title}</h3>
                {item.description && (
                  <p class="agenda-full__desc">{item.description}</p>
                )}
              </div>
            </li>
          );
        })}
      </ol>
    ))}
  </div>
</section>

<style>
  .agenda-full__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 80px;
    row-gap: 0;
    max-width: 1600px;
    width: 100%;
    margin: 12px auto 0;
    align-items: start;
  }

  .agenda-full__col {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .agenda-full__item {
    position: relative;
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 20px;
    padding: 18px 0;
    align-items: start;
  }
  .agenda-full__item + .agenda-full__item {
    border-top: 1px solid rgba(25, 25, 25, 0.1);
  }

  /* Numéro monumental : Hanken Grotesk 900, gris très clair. Soulignement jaune
     fin sous le numéro pour signer la charte LM. */
  .agenda-full__num {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 64px;
    font-weight: 800;
    line-height: 0.9;
    color: rgba(25, 25, 25, 0.12);
    letter-spacing: -0.04em;
    font-feature-settings: 'tnum';
    position: relative;
    padding-bottom: 8px;
  }
  .agenda-full__num::after {
    content: '';
    position: absolute;
    left: 4px;
    bottom: 0;
    width: 32px;
    height: 3px;
    background: #FFD838;
  }

  .agenda-full__content {
    min-width: 0;
  }

  .agenda-full__meta {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .agenda-full__time {
    font-family: 'Space Grotesk', monospace;
    font-size: 13px;
    font-weight: 700;
    color: #191919;
    background: #FFD838;
    padding: 3px 10px;
    border-radius: 3px;
    letter-spacing: 0.02em;
    font-feature-settings: 'tnum';
  }

  .agenda-full__duration {
    font-family: 'Space Grotesk', monospace;
    font-size: 12px;
    font-weight: 700;
    color: #6B6F84;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .agenda-full__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 23px;
    font-weight: 700;
    color: #191919;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .agenda-full__desc {
    font-size: 16px;
    color: #6B6F84;
    margin: 6px 0 0;
    line-height: 1.45;
  }
</style>
