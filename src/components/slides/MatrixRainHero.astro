---
// src/components/slides/MatrixRainHero.astro
// Slide d'ambiance "Matrix rain" : un canvas plein cadre où des colonnes de
// caractères tombent (effet du film Matrix), avec un titre / sous-titre
// optionnels en surimpression. Slide plein cadre sans header marque (l'effet
// parle seul), comme une BigImageHero en hideBrand.
// L'animation se met en pause quand la slide n'est pas visible
// (IntersectionObserver) pour ne pas tourner dans le vide sous Reveal.
import { splitHighlight } from '@/utils/highlight';

interface Props {
  /** Titre optionnel affiché par-dessus la pluie. */
  title?: string;
  italicPart?: string;
  /** Sous-titre optionnel. */
  subtitle?: string;
}
const { title, italicPart, subtitle } = Astro.props;
const titleParts = title ? splitHighlight(title, italicPart) : null;
---
<section class="matrix-rain-hero" data-layout="matrix-rain-hero">
  <canvas class="matrix-rain-hero__canvas" data-matrix-canvas></canvas>
  {(title || subtitle) && (
    <div class="matrix-rain-hero__overlay">
      {title && (
        <h2 class="matrix-rain-hero__title">
          {titleParts
            ? <>{titleParts.before}<em class="matrix-rain-hero__title-italic">{titleParts.match}</em>{titleParts.after}</>
            : title}
        </h2>
      )}
      {subtitle && <p class="matrix-rain-hero__subtitle">{subtitle}</p>}
    </div>
  )}
</section>

<style>
  .matrix-rain-hero {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #000000;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
  }
  .matrix-rain-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .matrix-rain-hero__overlay {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 96px;
    max-width: 1500px;
  }
  .matrix-rain-hero__overlay::before {
    content: "";
    position: absolute;
    inset: -80px -120px;
    z-index: -1;
    background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.78) 0%, rgba(0, 0, 0, 0.45) 55%, transparent 100%);
  }
  .matrix-rain-hero__title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: clamp(72px, 7vw, 120px);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    color: #FFFFFF;
    text-shadow: 0 0 32px rgba(0, 255, 102, 0.55), 0 0 8px rgba(0, 255, 102, 0.4);
    text-wrap: balance;
  }
  .matrix-rain-hero__title-italic {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
    color: #4DFF8F;
  }
  .matrix-rain-hero__subtitle {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 30px;
    line-height: 1.4;
    font-weight: 400;
    margin: 28px 0 0;
    color: rgba(255, 255, 255, 0.82);
    text-shadow: 0 0 16px rgba(0, 0, 0, 0.8);
  }
</style>

<script>
  // Effet "Matrix rain" : colonnes de caractères qui tombent sur un canvas.
  // À chaque frame, un voile noir translucide crée la traînée, puis on dessine
  // un caractère vert en tête de chaque colonne. Pause hors-vue via
  // IntersectionObserver (pas de calcul quand la slide n'est pas affichée).
  function initMatrixRain() {
    const canvas = document.querySelector('[data-matrix-canvas]');
    if (!canvas || !canvas.getContext) return;
    const ctx = canvas.getContext('2d');
    const W = (canvas.width = 1920);
    const H = (canvas.height = 1080);

    const fontSize = 28;
    const columns = Math.floor(W / fontSize);
    const drops = new Array(columns).fill(0).map(() => Math.floor(Math.random() * -60));
    const glyphs = 'アカサタナハマヤラワガザダバパイキシチニヒミリギジヂビピウクスツヌフムユルグズヅプ0123456789UTMSOURCEMEDIUMCAMPAIGN=&?_'.split('');

    let active = true;
    const section = canvas.closest('section');
    if (section && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => { active = e.isIntersecting; }),
        { threshold: 0.15 }
      );
      io.observe(section);
    }

    function draw() {
      if (active) {
        // Traînée : voile noir translucide par-dessus la frame précédente.
        ctx.fillStyle = 'rgba(0, 0, 0, 0.07)';
        ctx.fillRect(0, 0, W, H);
        ctx.font = fontSize + "px 'Consolas', 'SFMono-Regular', monospace";

        for (let i = 0; i < drops.length; i++) {
          const ch = glyphs[Math.floor(Math.random() * glyphs.length)];
          const x = i * fontSize;
          const y = drops[i] * fontSize;
          // Tête de colonne plus claire (effet lueur), traîne en vert.
          ctx.fillStyle = Math.random() > 0.92 ? '#CFFFE0' : '#00FF66';
          ctx.fillText(ch, x, y);
          if (y > H && Math.random() > 0.975) drops[i] = 0;
          drops[i]++;
        }
      }
      requestAnimationFrame(draw);
    }
    draw();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMatrixRain);
  } else {
    initMatrixRain();
  }
</script>
