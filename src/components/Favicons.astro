---
// Bloc <link rel="icon"> partagé par tous les <head> du site (Deck, Handout,
// parcours, Site). En thème ExecEd : un seul favicon SVG. Sinon : la série
// PNG/ICO Lausanne Marketing. Factorisé pour qu'un changement de favicon ne
// se fasse qu'à un seul endroit.
interface Props {
  scheme?: 'lm' | 'execed';
}
const { scheme = 'lm' } = Astro.props;
---
{scheme === 'execed' ? (
  <link rel="icon" type="image/svg+xml" href="/favicon-execed.svg" />
) : (
  <Fragment>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
    <link rel="shortcut icon" href="/favicon.png" />
  </Fragment>
)}
