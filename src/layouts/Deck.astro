---
// src/layouts/Deck.astro
import '@/styles/slides.css';
import PdfModal from '@/components/deck/PdfModal.astro';
import FontsPreload from '@/components/FontsPreload.astro';

interface Props {
  title: string;
  subtitle?: string;
  short?: string;
  description?: string;
  cover?: string;
  updated?: string;
}

const { title, subtitle, short, description, cover, updated } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <FontsPreload />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
    <link rel="shortcut icon" href="/favicon.png" />
    <title>{title} : Lausanne Marketing</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {cover && <meta property="og:image" content={new URL(cover, Astro.site).toString()} />}
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="fr_FR" />
  </head>
  <body>
    <button type="button" class="deck-menu-pill" id="deck-menu-pill" title="Informations du cours" aria-label="Afficher les informations du cours" aria-expanded="false">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
        <path d="M224 128a8 8 0 0 1-8 8H40a8 8 0 0 1 0-16h176a8 8 0 0 1 8 8M40 72h176a8 8 0 0 0 0-16H40a8 8 0 0 0 0 16m176 112H40a8 8 0 0 0 0 16h176a8 8 0 0 0 0-16" />
      </svg>
    </button>
    <aside class="deck-menu" id="deck-menu" hidden aria-label="Informations du cours">
      <button type="button" class="deck-menu__close" id="deck-menu-close" title="Fermer" aria-label="Fermer le menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M205.66 194.34a8 8 0 0 1-11.32 11.32L128 139.31l-66.34 66.35a8 8 0 0 1-11.32-11.32L116.69 128 50.34 61.66a8 8 0 0 1 11.32-11.32L128 116.69l66.34-66.35a8 8 0 0 1 11.32 11.32L139.31 128Z" />
        </svg>
      </button>
      <a href="/parcours/" class="deck-menu__back-parcours" id="deck-menu-back-parcours" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M224 128a8 8 0 0 1-8 8H59.31l58.35 58.34a8 8 0 0 1-11.32 11.32l-72-72a8 8 0 0 1 0-11.32l72-72a8 8 0 0 1 11.32 11.32L59.31 120H216a8 8 0 0 1 8 8" />
        </svg>
        <span>Retourner au parcours</span>
      </a>
      <span class="deck-menu__eyebrow"><span class="underline">Lausanne Marketing</span></span>
      <h1 class="deck-menu__title">{title}</h1>
      {subtitle && <p class="deck-menu__subtitle">{subtitle}</p>}
      {updated && (
        <p class="deck-menu__meta">
          <span>Mis à jour : {updated}</span>
        </p>
      )}
      <nav class="deck-menu__toc" id="deck-menu-toc" aria-label="Sommaire" hidden>
        <p class="deck-menu__toc-label">Sommaire</p>
        <ol class="deck-menu__toc-list" id="deck-menu-toc-list"></ol>
      </nav>
    </aside>
    <div class="deck-toolbar">
      <a href="/parcours/" class="deck-icon-btn deck-back-parcours" id="deck-back-parcours" title="Retourner au parcours" aria-label="Retourner au parcours" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M224 128a8 8 0 0 1-8 8H59.31l58.35 58.34a8 8 0 0 1-11.32 11.32l-72-72a8 8 0 0 1 0-11.32l72-72a8 8 0 0 1 11.32 11.32L59.31 120H216a8 8 0 0 1 8 8" />
        </svg>
      </a>
      <button type="button" class="deck-icon-btn" id="deck-search-btn" title="Rechercher dans le deck (/)" aria-label="Rechercher dans le deck">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M229.66 218.34l-50.07-50.06a88.11 88.11 0 1 0-11.31 11.31l50.06 50.07a8 8 0 0 0 11.32-11.32M40 112a72 72 0 1 1 72 72 72.08 72.08 0 0 1-72-72" />
        </svg>
      </button>
      <button type="button" class="deck-icon-btn" id="deck-download-btn" title="Télécharger en PDF" aria-label="Télécharger la présentation en PDF">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M224 152v56a16 16 0 0 1-16 16H48a16 16 0 0 1-16-16v-56a8 8 0 0 1 16 0v56h160v-56a8 8 0 0 1 16 0Zm-101.66 5.66a8 8 0 0 0 11.32 0l40-40a8 8 0 0 0-11.32-11.32L136 132.69V40a8 8 0 0 0-16 0v92.69l-26.34-26.35a8 8 0 0 0-11.32 11.32Z" />
        </svg>
      </button>
      <button type="button" class="deck-icon-btn" id="deck-present-btn" title="Mode présentation plein écran" aria-label="Basculer en mode présentation plein écran">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M232 56v40a8 8 0 0 1-16 0V64h-32a8 8 0 0 1 0-16h40a8 8 0 0 1 8 8M72 200H40v-32a8 8 0 0 0-16 0v40a8 8 0 0 0 8 8h40a8 8 0 0 0 0-16m152-40a8 8 0 0 0-8 8v32h-32a8 8 0 0 0 0 16h40a8 8 0 0 0 8-8v-40a8 8 0 0 0-8-8M32 104a8 8 0 0 0 8-8V64h32a8 8 0 0 0 0-16H32a8 8 0 0 0-8 8v40a8 8 0 0 0 8 8" />
        </svg>
      </button>
    </div>
    <div class="deck-search" id="deck-search" hidden role="search" aria-label="Recherche dans le deck">
      <svg class="deck-search__icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
        <path d="M229.66 218.34l-50.07-50.06a88.11 88.11 0 1 0-11.31 11.31l50.06 50.07a8 8 0 0 0 11.32-11.32M40 112a72 72 0 1 1 72 72 72.08 72.08 0 0 1-72-72" />
      </svg>
      <input
        type="text"
        class="deck-search__input"
        id="deck-search-input"
        placeholder="Rechercher dans toutes les slides"
        autocomplete="off"
        spellcheck="false"
        aria-label="Terme de recherche"
        data-search-skip
      />
      <span class="deck-search__count" id="deck-search-count" aria-live="polite" data-search-skip>0 / 0</span>
      <button type="button" class="deck-search__nav" id="deck-search-prev" title="Match précédent (Maj+Entrée)" aria-label="Match précédent" data-search-skip>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M213.66 165.66a8 8 0 0 1-11.32 0L128 91.31l-74.34 74.35a8 8 0 0 1-11.32-11.32l80-80a8 8 0 0 1 11.32 0l80 80a8 8 0 0 1 0 11.32" />
        </svg>
      </button>
      <button type="button" class="deck-search__nav" id="deck-search-next" title="Match suivant (Entrée)" aria-label="Match suivant" data-search-skip>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M213.66 101.66l-80 80a8 8 0 0 1-11.32 0l-80-80a8 8 0 0 1 11.32-11.32L128 164.69l74.34-74.35a8 8 0 0 1 11.32 11.32" />
        </svg>
      </button>
      <button type="button" class="deck-search__close" id="deck-search-close" title="Fermer (Echap)" aria-label="Fermer la recherche" data-search-skip>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M205.66 194.34a8 8 0 0 1-11.32 11.32L128 139.31l-66.34 66.35a8 8 0 0 1-11.32-11.32L116.69 128 50.34 61.66a8 8 0 0 1 11.32-11.32L128 116.69l66.34-66.35a8 8 0 0 1 11.32 11.32L139.31 128Z" />
        </svg>
      </button>
    </div>
    <div class="deck-stage">
      <div class="reveal">
        <div class="slides">
          <slot />
        </div>
      </div>
    </div>
    <footer class="deck-footer">
      <button type="button" class="deck-nav-btn deck-nav-prev" title="Slide précédente" aria-label="Slide précédente">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M165.66 202.34a8 8 0 0 1-11.32 11.32l-80-80a8 8 0 0 1 0-11.32l80-80a8 8 0 0 1 11.32 11.32L91.31 128Z" />
        </svg>
      </button>
      <div class="deck-footer__center">
        <span class="deck-brand">Lausanne Marketing</span>
        <span class="deck-sep">•</span>
        <span class="deck-title">{short ?? title}</span>
        <span class="deck-sep">•</span>
        <span class="deck-counter"><span class="reveal-current">1</span> / <span class="reveal-total">1</span></span>
      </div>
      <button type="button" class="deck-nav-btn deck-nav-next" title="Slide suivante" aria-label="Slide suivante">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="m181.66 133.66-80 80a8 8 0 0 1-11.32-11.32L164.69 128 90.34 53.66a8 8 0 0 1 11.32-11.32l80 80a8 8 0 0 1 0 11.32Z" />
        </svg>
      </button>
    </footer>

    <PdfModal />

    <div class="presenter-badge" aria-hidden="true">Présentateur</div>

    <script>
      // Orchestrateur : chaque sous-systeme du deck (presenter, reveal, chrome,
      // search, polls) vit dans son propre module sous src/scripts/deck/. Ce
      // bloc se contente de lire les params runtime (URL, env) et d'enchainer
      // les inits dans le bon ordre.
      import { initPresenterMode } from '@/scripts/deck/presenter';
      import { initReveal } from '@/scripts/deck/reveal-init';
      import {
        initDeckMenu,
        initParcoursBackLink,
        initPdfButton,
        initFullscreenToggle,
        initPresentButton,
        initToc,
      } from '@/scripts/deck/deck-chrome';
      import { initDeckSearch } from '@/scripts/deck/deck-search';
      import { initPollSlides } from '@/scripts/deck/polls';

      // Presenter d'abord : si #presenter=SECRET est dans l'URL, on le lit, on
      // pose la classe body.is-presenter et on nettoie le fragment AVANT que
      // Reveal n'attache son propre handler hashchange.
      const presenterKey = initPresenterMode();

      const LM_POLLS_URL = import.meta.env.PUBLIC_LM_POLLS_URL || 'https://lm-polls.hello-cb2.workers.dev';
      const DECK_SLUG = window.location.pathname.split('/').filter(Boolean)[1] || 'unknown';

      // Inits qui ne dependent pas de Reveal : on les lance immediatement, en
      // synchrone. Pas de point d'attente, le chrome est interactif avant que
      // Reveal n'ait fini d'initialiser ses transitions.
      initDeckMenu();
      initParcoursBackLink();
      initPdfButton();
      initFullscreenToggle();

      // Reveal en arriere-plan : quand pret, on cable les inits qui dependent
      // de l'instance deck (present button, TOC, recherche full-text).
      initReveal().then((deck) => {
        if (!deck) return;
        initPresentButton(deck);
        initToc(deck);
        initDeckSearch(deck);
      });

      // Polls : independants de Reveal mais attendent que le DOM soit pret pour
      // que les <section data-layout="poll|wordcloud"> existent.
      const startPolls = () => initPollSlides({ lmPollsUrl: LM_POLLS_URL, deckSlug: DECK_SLUG, presenterKey });
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => void startPolls());
      } else {
        void startPolls();
      }
    </script>
  </body>
</html>
