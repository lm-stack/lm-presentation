---
// src/layouts/Handout.astro
// Layout handout sans Reveal.js. Reçoit les <section> via <slot />,
// les groupe par paquets de 2 ou 3, et les arrange en pages A4 portrait
// imprimables. Le scale des slides Reveal (1920x1080) vers le slot
// est calculé en JS après le mount.
import '@/styles/handout.css';

interface Props {
  title: string;
  mode: '1' | '2' | '3';
}

const { title, mode } = Astro.props;
const perPage = mode === '1' ? 1 : mode === '2' ? 2 : 4;
// Taille de page par mode (utilisee par @page CSS).
// Le worker lm-pdf passe preferCSSPageSize:true donc Puppeteer respecte size.
// Sans cette regle, certaines builds Cloudflare Browser Rendering ignorent
// page.pdf({ landscape:true }) et impriment en portrait par defaut.
// Mode 1up : format custom 297x167mm = ratio 16:9 exact, slide pleine page sans blanc.
// Mode 2up/3up : A4 portrait standard.
const pageSize = mode === '1' ? '297mm 167mm' : '210mm 297mm';
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`${title} : handout ${mode}up : Lausanne Marketing`}</title>
    <meta name="robots" content="noindex" />
    <style set:html={`@page { size: ${pageSize}; margin: 0; }`}></style>
  </head>
  <body>
    <main
      class="handout-doc"
      data-mode={mode}
      data-per-page={perPage}
    >
      <!-- Les sections du MDX sont injectées ici. Le script post-mount -->
      <!-- les regroupe en pages, scale les slides, et insère les zones lignes. -->
      <div id="handout-source" hidden>
        <slot />
      </div>
      <div id="handout-pages"></div>
    </main>

    <script define:vars={{ mode, perPage }}>
      // Post-mount : groupe les <section> sources par paquets, scale, pagine.
      const source = document.getElementById('handout-source');
      const target = document.getElementById('handout-pages');
      if (!source || !target) {
        // garde-fou : ne rien faire
      } else {
        // Mode handout = impression. Toutes les images sont au-dessus du fold
        // car la page est paginee en A4 statiques (pas scroll). Le `lazy` natif
        // serait satisfait par networkidle0 sur la slide 1 mais pas sur les
        // slides hors viewport au moment du goto() de Puppeteer : les images
        // lazy restent non chargees et le fond noir #191919 du media remonte.
        // On force eager avant la pagination pour que toutes les images soient
        // demarrees au document.load et que networkidle0 attende leur reseau.
        source.querySelectorAll('img[loading="lazy"]').forEach((img) => {
          img.loading = 'eager';
        });

        const sections = Array.from(source.querySelectorAll(':scope > section'));
        // Largeur d'un slot : depend du mode.
        // Mode 1up : page custom 297x167mm pleine (pas de padding) = ~1123px @ 96dpi.
        // Mode 2up : portrait A4 190mm utile = ~718px.
        // Mode 3up : 60% de 190mm = 114mm = ~431px.
        const slotPxByMode = mode === '1' ? 1123 : mode === '2' ? 718 : 431;
        const scale = slotPxByMode / 1920;

        const groups = [];
        for (let i = 0; i < sections.length; i += perPage) {
          groups.push(sections.slice(i, i + perPage));
        }

        for (const group of groups) {
          const page = document.createElement('div');
          page.className = `handout-page handout-page--${mode}up`;

          if (mode === '3') {
            // mode 3 : pour chaque slide, 2 cells (slide + zone lignes)
            for (const sec of group) {
              page.appendChild(makeSlideContainer(sec, scale));
              const lines = document.createElement('div');
              lines.className = 'handout-lines';
              for (let i = 0; i < 6; i++) {
                const line = document.createElement('div');
                line.className = 'handout-line';
                lines.appendChild(line);
              }
              page.appendChild(lines);
            }
          } else {
            // mode 1 ou 2 : juste les slides
            for (const sec of group) {
              page.appendChild(makeSlideContainer(sec, scale));
            }
          }
          target.appendChild(page);
        }

        // Cleanup source après extraction.
        source.remove();
      }

      function makeSlideContainer(section, scale) {
        const slot = document.createElement('div');
        slot.className = 'handout-slide';
        const inner = document.createElement('div');
        inner.className = 'handout-slide__inner';
        // BUG observe : transform:scale + page-break-after:always sur plusieurs pages
        // empilees casse la pagination dans page.pdf() de Chrome (le contenu transforme
        // ne remplit que ~62% de la page au lieu du 100% attendu). CSS `zoom` evite ce
        // bug parce qu'il scale aussi la layout box, pas seulement le rendu visuel.
        inner.style.zoom = scale;
        // Move la section originale dans le slot pour preserver les styles Reveal.
        inner.appendChild(section);
        slot.appendChild(inner);
        return slot;
      }
    </script>
  </body>
</html>
