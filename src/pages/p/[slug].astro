---
// src/pages/p/[slug].astro
import { getCollection, render } from 'astro:content';
import Deck from '@/layouts/Deck.astro';
import DeckEnding from '@/components/DeckEnding.astro';

export async function getStaticPaths() {
  const decks = await getCollection('presentations');
  const parcoursList = await getCollection('parcours');

  return decks.map((d) => {
    // parcours : pour le lien retour vers le portail (Deck layout). La logique
    // de slide de fin (Questions / Merci) est dans <DeckEnding>, partagée avec
    // la route handout.
    const parcours = parcoursList.find((p) => p.data.decks.includes(d.id));
    return {
      params: { slug: d.id },
      props: { entry: d, parcours: parcours ?? null },
    };
  });
}

const { entry, parcours } = Astro.props;
// Retour parcours : seulement si le portail /parcours/<slug> existe vraiment
// (parcours listé). Un parcours unlisted n'a pas de page : on éviterait un 404.
const parcoursSlug = parcours && !parcours.data.unlisted ? parcours.id : undefined;
const { Content } = await render(entry);

function formatDate(d: Date) {
  const day = String(d.getDate()).padStart(2, '0');
  const month = String(d.getMonth() + 1).padStart(2, '0');
  return `${day}.${month}.${d.getFullYear()}`;
}
const updatedLabel = entry.data.updated ?? formatDate(entry.data.date);
---
<Deck
  title={entry.data.title}
  subtitle={entry.data.subtitle}
  short={entry.data.short}
  description={entry.data.description}
  cover={entry.data.cover}
  updated={updatedLabel}
  scheme={entry.data.scheme}
  parcoursSlug={parcoursSlug}
>
  <Content />
  <DeckEnding entry={entry} />
</Deck>
